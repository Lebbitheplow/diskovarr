NODE_ENV=development
PLEX_URL=http://your-plex-server:32400
PLEX_TOKEN=your_plex_admin_token
PLEX_SERVER_ID=your_plex_machine_identifier
PLEX_SERVER_NAME=Your Server Name
PLEX_MOVIES_SECTION_ID=1
PLEX_TV_SECTION_ID=2
TAUTULLI_URL=http://your-tautulli:8181
TAUTULLI_API_KEY=your_tautulli_api_key
SESSION_SECRET=change_this_to_a_random_string
ADMIN_PASSWORD=change_this_to_a_secure_password
PORT=3232

# Logging Options: ERROR, WARN, INFO, DEBUG (default: INFO)
# Set DEBUG to see all HTTP requests, cache hits/misses, and scoring detail.
# Set WARN to quiet the logs in production.
LOG_LEVEL=INFO
