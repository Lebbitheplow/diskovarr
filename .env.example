# ──────────────────────────────────────────────────────────────────────────────
# Diskovarr — root `.env`
#
# This file ONLY contains build-time variables consumed by the React frontend
# via Vite (anything prefixed with `VITE_`). It is read during `npm run build`
# and `npm run dev`.
#
# For RUNTIME configuration of the Express backend (Plex credentials, admin
# password, ports, integrations, etc.), see `server/.env.example`. Docker
# users typically set those via the `environment:` block in `docker-compose.yml`
# rather than an `.env` file.
# ──────────────────────────────────────────────────────────────────────────────

# URL of the Diskovarr backend server (Express/Node) for the Vite dev proxy.
# Only used during `npm run dev`; ignored in production where the server
# serves the built React app directly.
VITE_BACKEND_URL=http://localhost:3233

# App version shown in the About modal.
VITE_APP_VERSION=2.5.0

# Set to 'false' to hide the Diskovarr Requests (Explore) tab.
VITE_DISCOVER_ENABLED=true
