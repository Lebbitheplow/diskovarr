# URL of the Diskovarr backend server (Express/Node)
# This is the server that handles auth, API calls, and serves the database.
VITE_BACKEND_URL=http://localhost:3233

# App version shown in the About modal
VITE_APP_VERSION=2.0.0

# Set to 'false' to hide the Diskovarr Requests (Explore) tab
VITE_DISCOVER_ENABLED=true
