<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="none" aria-hidden="true">
          <rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="currentColor"/>
          <rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="currentColor"/>
          <rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="currentColor"/>
          <rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="currentColor"/>
          <circle cx="15" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
          <line x1="18.5" y1="12.5" x2="22" y2="16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="logo-text">Diskovarr</span>
    </a>

    <div class="nav-tabs">
      <a href="/" class="nav-tab <%= currentPath === '/' ? 'active' : '' %>">Diskovarr</a>
      <% if (typeof discoverEnabled !== 'undefined' && discoverEnabled) { %>
        <a href="/explore" class="nav-tab <%= currentPath === '/explore' ? 'active' : '' %>">Diskovarr Requests</a>
      <% } %>
      <a href="/discover" class="nav-tab <%= currentPath === '/discover' ? 'active' : '' %>"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="13" height="13" fill="none" aria-hidden="true" style="vertical-align:-1px;margin-right:4px"><line x1="2" y1="4" x2="14" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="4" y1="8" x2="12" y2="8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><line x1="6" y1="12" x2="10" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>Filter</a>
    </div>

    <!-- Desktop: nav action buttons + bell + user button -->
    <div class="nav-user">
      <div class="nav-bell-wrap" style="position:relative">
        <button class="nav-bell-btn" id="nav-bell-btn" aria-label="Notifications" style="background:none;border:none;cursor:pointer;padding:4px 6px;border-radius:6px;color:var(--text-secondary);font-size:1.1rem;display:flex;align-items:center;gap:4px;transition:color 0.15s" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text-secondary)'">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
          </svg>
          <span id="nav-bell-badge" style="display:none;background:#ff5252;color:#fff;font-size:0.65rem;font-weight:700;padding:1px 5px;border-radius:10px;min-width:16px;text-align:center"></span>
        </button>
        <div id="nav-bell-dropdown" style="display:none;position:absolute;right:0;top:calc(100% + 8px);width:320px;background:var(--bg-secondary);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,0.5);z-index:9000;max-height:400px;overflow-y:auto">
          <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border)">
            <span style="font-size:0.85rem;font-weight:600">Notifications</span>
            <button onclick="markAllRead()" style="background:none;border:none;cursor:pointer;font-size:0.78rem;color:var(--accent)">Mark all read</button>
          </div>
          <div id="nav-bell-list" style="padding:8px 0"></div>
        </div>
      </div>
      <button class="nav-user-btn" id="nav-user-btn" aria-label="Open menu" aria-expanded="false">
        <% if (thumb) { %>
          <img src="/api/poster?path=<%= encodeURIComponent(thumb) %>" alt="<%= username %>"
            onerror="this.outerHTML='<span class=\'nav-fab-initial\'><%= username.charAt(0).toUpperCase() %></span>'">
        <% } else { %>
          <span class="nav-fab-initial"><%= username.charAt(0).toUpperCase() %></span>
        <% } %>
      </button>
    </div>

  </div>
</nav>

<!-- Mobile floating menu button (bottom-right corner) -->
<button class="nav-fab" id="nav-fab" aria-label="Open menu" aria-expanded="false">
  <% if (thumb) { %>
    <img src="/api/poster?path=<%= encodeURIComponent(thumb) %>" alt="<%= username %>" onerror="this.outerHTML='<span class=\'nav-fab-initial\'><%= username.charAt(0).toUpperCase() %></span>'">
  <% } else { %>
    <span class="nav-fab-initial"><%= username.charAt(0).toUpperCase() %></span>
  <% } %>
</button>

<!-- Mobile popup menu (slides up from FAB) -->
<div class="nav-fab-menu" id="nav-fab-menu" aria-hidden="true">
  <div class="nav-fab-menu-user">
    <% if (thumb) { %>
      <img class="nav-fab-menu-avatar" src="/api/poster?path=<%= encodeURIComponent(thumb) %>" alt="<%= username %>" onerror="this.style.display='none'">
    <% } else { %>
      <div class="nav-fab-menu-avatar-placeholder"><%= username.charAt(0).toUpperCase() %></div>
    <% } %>
    <span class="nav-fab-menu-username"><%= username %></span>
  </div>
  <a href="/settings" class="nav-fab-menu-link">&#9881; Settings</a>
  <a href="/watchlist" class="nav-fab-menu-link">◈ Watchlist</a>
  <a href="/queue" class="nav-fab-menu-link">&#9776; Queue</a>
  <a href="/admin" class="nav-fab-menu-link">&#9881; Admin</a>
  <button class="nav-fab-menu-link nav-fab-menu-info" id="nav-info-btn-mobile">ℹ About</button>
  <a href="/auth/logout" class="nav-fab-menu-link nav-fab-menu-signout">Sign out</a>
</div>

<div class="nav-overlay" id="nav-overlay"></div>

<!-- Changelog modal -->
<div class="info-modal-backdrop" id="changelog-modal" aria-hidden="true">
  <div class="info-modal-card" role="dialog" aria-modal="true" style="max-width:520px">
    <button class="info-modal-close" id="changelog-modal-close" aria-label="Close">✕</button>
    <div class="info-modal-logo">
      <span class="logo-text">Changelog</span>
    </div>
    <div class="info-modal-sections" id="changelog-entries">
      <% changelog.forEach(function(entry) { %>
      <div class="info-modal-section">
        <div class="info-modal-section-title">v<%= entry.version %> <span style="font-weight:400;color:var(--text-secondary);font-size:0.78rem"><%= entry.date %></span></div>
        <ul style="margin:6px 0 0;padding-left:18px;display:flex;flex-direction:column;gap:4px">
          <% entry.changes.forEach(function(c) { %><li style="font-size:0.84rem"><%= c %></li><% }); %>
        </ul>
      </div>
      <% }); %>
    </div>
  </div>
</div>

<!-- Info modal -->
<div class="info-modal-backdrop" id="info-modal" aria-hidden="true">
  <div class="info-modal-card" role="dialog" aria-modal="true">
    <button class="info-modal-close" id="info-modal-close" aria-label="Close">✕</button>
    <div class="info-modal-logo">
      <span class="logo-icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="none" aria-hidden="true">
          <rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="currentColor"/>
          <rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="currentColor"/>
          <rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="currentColor"/>
          <rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="currentColor"/>
          <circle cx="15" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
          <line x1="18.5" y1="12.5" x2="22" y2="16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="logo-text">Diskovarr</span>
      <button id="info-version-btn" class="info-modal-version">v<%= appVersion %></button>
    </div>
    <p class="info-modal-tagline">Personalized Plex recommendations based on your watch history.</p>
    <div class="info-modal-sections">
      <div class="info-modal-section">
        <div class="info-modal-section-title">Diskovarr</div>
        <p>Your personalized recommendation feed. Diskovarr analyzes your Plex watch history — directors, actors, studios, and genres you enjoy — to surface content you haven't seen yet. Dismiss anything you're not interested in and it won't appear again.</p>
      </div>
      <% if (typeof discoverEnabled !== 'undefined' && discoverEnabled) { %>
      <div class="info-modal-section">
        <div class="info-modal-section-title">Diskovarr Requests</div>
        <p>Recommendations for content <strong>not yet in the library</strong>, picked based on your watch history. Use the search bar to find any specific title and request it directly. Click <em>Request</em> on any title to send it to Overseerr (or Radarr/Sonarr) for download. Requested items are tracked so you won't be prompted to request them again.</p>
      </div>
      <% } %>
      <div class="info-modal-section">
        <div class="info-modal-section-title">Filter</div>
        <p>Browse the full library with filters for type (movies, TV, anime), genre, decade, and minimum rating. Sort by recommendation score, rating, year, or recently added.</p>
      </div>
      <div class="info-modal-section">
        <div class="info-modal-section-title">Watchlist</div>
        <p>Save anything you want to watch later. Items sync to your <strong>Plex Watchlist</strong> and appear in the Plex app under Discover → Watchlist. Remove items here and they'll be removed from Plex too.</p>
      </div>
      <div class="info-modal-section">
        <div class="info-modal-section-title">Queue</div>
        <p>Track and manage your media requests. View the status of everything you've requested — pending, approved, or denied. Admins can review all users' requests, approve or deny them with an optional note, and edit the target service or seasons for TV shows.</p>
      </div>
    </div>
  </div>
</div>

<script>
  // ── Dynamic favicon — reflects current accent color ───────────────
  (function () {
    var accent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#e5a00d';
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="-3 -3 30 30">'
      + '<rect x="-3" y="-3" width="30" height="30" rx="5" fill="#0f0f0f"/>'
      + '<rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="' + accent + '"/>'
      + '<rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="' + accent + '"/>'
      + '<rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="' + accent + '"/>'
      + '<rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="' + accent + '"/>'
      + '<circle cx="15" cy="9" r="5" fill="none" stroke="' + accent + '" stroke-width="2"/>'
      + '<line x1="18.5" y1="12.5" x2="22" y2="16" stroke="' + accent + '" stroke-width="2.5" stroke-linecap="round"/>'
      + '</svg>';
    var blob = new Blob([svg], { type: 'image/svg+xml' });
    var url = URL.createObjectURL(blob);
    var link = document.querySelector('link[rel*="icon"]');
    if (link) link.href = url;
  })();

  // ── FAB menu (mobile FAB + desktop user button) ────────────────────
  (function () {
    var menu = document.getElementById('nav-fab-menu');
    var overlay = document.getElementById('nav-overlay');
    if (!menu) return;

    function open() {
      menu.classList.add('open');
      menu.setAttribute('aria-hidden', 'false');
      overlay.classList.add('open');
      var fab = document.getElementById('nav-fab');
      if (fab) { fab.classList.add('open'); fab.setAttribute('aria-expanded', 'true'); }
      var userBtn = document.getElementById('nav-user-btn');
      if (userBtn) { userBtn.classList.add('open'); userBtn.setAttribute('aria-expanded', 'true'); }
    }
    function close() {
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('open');
      var fab = document.getElementById('nav-fab');
      if (fab) { fab.classList.remove('open'); fab.setAttribute('aria-expanded', 'false'); }
      var userBtn = document.getElementById('nav-user-btn');
      if (userBtn) { userBtn.classList.remove('open'); userBtn.setAttribute('aria-expanded', 'false'); }
    }

    ['nav-fab', 'nav-user-btn'].forEach(function(id) {
      var btn = document.getElementById(id);
      if (btn) btn.addEventListener('click', function() {
        menu.classList.contains('open') ? close() : open();
      });
    });
    overlay.addEventListener('click', close);
  })();

  // Info modal + Changelog modal
  (function () {
    var modal = document.getElementById('info-modal');
    var overlay = document.getElementById('nav-overlay');
    var changelogModal = document.getElementById('changelog-modal');

    function openInfo() {
      modal.classList.add('open');
      modal.setAttribute('aria-hidden', 'false');
      overlay.classList.add('open');
      // Close FAB menu if open
      var menu = document.getElementById('nav-fab-menu');
      if (menu) {
        menu.classList.remove('open');
        var fab = document.getElementById('nav-fab');
        if (fab) fab.classList.remove('open');
        var userBtn = document.getElementById('nav-user-btn');
        if (userBtn) userBtn.classList.remove('open');
      }
    }
    function closeInfo() {
      modal.classList.remove('open');
      modal.setAttribute('aria-hidden', 'true');
      overlay.classList.remove('open');
    }

    ['nav-info-btn', 'nav-info-btn-mobile'].forEach(function (id) {
      var btn = document.getElementById(id);
      if (btn) btn.addEventListener('click', openInfo);
    });
    document.getElementById('info-modal-close').addEventListener('click', closeInfo);
    overlay.addEventListener('click', function() {
      closeInfo();
      if (changelogModal) {
        changelogModal.classList.remove('open');
        changelogModal.setAttribute('aria-hidden', 'true');
      }
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeInfo(); });

    // Version button opens changelog
    var versionBtn = document.getElementById('info-version-btn');
    if (versionBtn && changelogModal) {
      versionBtn.addEventListener('click', function() {
        closeInfo();
        changelogModal.classList.add('open');
        changelogModal.setAttribute('aria-hidden', 'false');
        overlay.classList.add('open');
      });
    }
    // Changelog close button
    var changelogClose = document.getElementById('changelog-modal-close');
    if (changelogClose && changelogModal) {
      changelogClose.addEventListener('click', function() {
        changelogModal.classList.remove('open');
        changelogModal.setAttribute('aria-hidden', 'true');
        overlay.classList.remove('open');
      });
    }
  })();

  // ── Notification bell ────────────────────────────────────────
  (function() {
    var btn = document.getElementById('nav-bell-btn');
    var dropdown = document.getElementById('nav-bell-dropdown');
    var badge = document.getElementById('nav-bell-badge');
    var list = document.getElementById('nav-bell-list');
    if (!btn) return;
    var open = false;

    function updateBell() {
      fetch('/api/notifications?countOnly=1').then(function(r) { return r.json(); }).then(function(d) {
        if (d.unreadCount > 0) {
          badge.style.display = 'inline-block';
          badge.textContent = d.unreadCount > 99 ? '99+' : d.unreadCount;
        } else {
          badge.style.display = 'none';
        }
      }).catch(function(){});
    }

    function loadNotifications() {
      fetch('/api/notifications').then(function(r) { return r.json(); }).then(function(d) {
        if (d.unreadCount > 0) {
          badge.style.display = 'inline-block';
          badge.textContent = d.unreadCount > 99 ? '99+' : d.unreadCount;
        } else {
          badge.style.display = 'none';
        }
        var unreadNotifs = d.notifications || [];
        var readNotifs = d.recentRead || [];
        if (unreadNotifs.length === 0 && readNotifs.length === 0) {
          list.innerHTML = '<div style="padding:20px;text-align:center;font-size:0.82rem;color:var(--text-secondary)">No notifications</div>';
          return;
        }
        function agoString(created_at) {
          var ago = Math.floor((Date.now()/1000 - created_at) / 60);
          return ago < 60 ? ago + 'm ago' : Math.floor(ago/60) + 'h ago';
        }
        var readHtml = readNotifs.map(function(n) {
          var agoStr = agoString(n.created_at);
          return '<div style="padding:10px 16px;border-bottom:1px solid var(--border);opacity:0.45;cursor:default">'
            + '<div style="font-size:0.82rem;font-weight:500">' + n.title + '</div>'
            + (n.body ? '<div style="font-size:0.75rem;color:var(--text-secondary);margin-top:2px">' + n.body + '</div>' : '')
            + '<div style="font-size:0.72rem;color:var(--text-secondary);margin-top:4px">' + agoStr + ' · read</div>'
            + '</div>';
        }).join('');
        list.innerHTML = unreadNotifs.map(function(n) {
          var agoStr = agoString(n.created_at);
          return '<div style="padding:10px 16px;border-bottom:1px solid var(--border);cursor:pointer" onclick="bellItemClick(\''+n.type+'\','+n.id+')">'
            + '<div style="font-size:0.82rem;font-weight:500">' + n.title + '</div>'
            + (n.body ? '<div style="font-size:0.75rem;color:var(--text-secondary);margin-top:2px">' + n.body + '</div>' : '')
            + '<div style="font-size:0.72rem;color:var(--text-secondary);margin-top:4px">' + agoStr + '</div>'
            + '</div>';
        }).join('') + readHtml;
      }).catch(function(){});
    }

    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      open = !open;
      dropdown.style.display = open ? 'block' : 'none';
      if (open) loadNotifications();
    });
    document.addEventListener('click', function() {
      if (open) { open = false; dropdown.style.display = 'none'; }
    });
    dropdown.addEventListener('click', function(e) { e.stopPropagation(); });

    updateBell();
    setInterval(updateBell, 60000);
  })();

  function markAllRead() {
    fetch('/api/notifications/read', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({all:true}) })
      .then(function() {
        document.getElementById('nav-bell-badge').style.display = 'none';
        document.getElementById('nav-bell-list').innerHTML = '<div style="padding:20px;text-align:center;font-size:0.82rem;color:var(--text-secondary)">No notifications</div>';
      });
  }

  function bellItemClick(type, id) {
    fetch('/api/notifications/read', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ids:[id]}) });
    if (type === 'request_pending' || type === 'request_approved' || type === 'request_denied' ||
        type === 'request_auto_approved' || type === 'request_process_failed') {
      window.location.href = '/queue';
    } else if (type === 'request_available') {
      window.location.href = '/queue?filter=available';
    }
  }
</script>
