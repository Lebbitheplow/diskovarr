<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Search — Diskovarr</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <%- include('partials/pwa-head') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=33">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>">
</head>
<body>
  <%- include('partials/nav', { username, thumb, currentPath, discoverEnabled }) %>

  <main class="main-content">
    <div class="search-page-header">
      <button class="search-back-btn" aria-label="Back"
        onclick="if(history.length>1){history.back()}else{window.location.href='<%= landingPage === 'explore' ? '/explore' : '/' %>'}">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" width="16" height="16" aria-hidden="true">
          <path d="M12 4L6 10L12 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Back
      </button>
      <div class="search-page-query-wrap">
        <form class="search-page-form" id="search-page-form" action="/search" method="get" autocomplete="off">
          <div class="search-page-input-wrap">
            <svg class="search-page-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" width="17" height="17" fill="none" aria-hidden="true">
              <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="1.8"/>
              <line x1="12.5" y1="12.5" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
            <input type="search" name="q" id="search-page-input" class="search-page-input"
              value="<%= query %>" placeholder="Search movies &amp; TV shows…" spellcheck="false">
            <% if (query) { %>
              <button type="button" class="search-page-clear" id="search-page-clear" aria-label="Clear">✕</button>
            <% } %>
          </div>
        </form>
      </div>
    </div>

    <div id="search-results-header" style="display:none" class="search-results-meta">
      <span id="search-results-count"></span>
    </div>

    <div class="card-grid" id="search-grid">
      <% if (query) { %>
        <% for(let i = 0; i < 12; i++) { %>
          <div class="card card-skeleton">
            <div class="skeleton-poster shimmer"></div>
            <div class="skeleton-info">
              <div class="skeleton-line shimmer" style="width:80%"></div>
              <div class="skeleton-line shimmer" style="width:50%"></div>
            </div>
          </div>
        <% } %>
      <% } else { %>
        <div class="search-empty" style="grid-column:1/-1">
          <p>Enter a search term above to find movies and TV shows.</p>
        </div>
      <% } %>
    </div>

    <div id="search-load-more-wrap" style="display:none; text-align:center; padding:32px 0">
      <button class="btn-load-more" id="btn-search-load-more">Load more</button>
    </div>
  </main>

  <!-- Detail modal (shared between library and non-library items) -->
  <div class="detail-modal-wrap" id="detail-modal" aria-hidden="true">
    <div class="detail-modal-card" role="dialog" aria-modal="true">
      <button class="detail-modal-close" id="detail-modal-close" aria-label="Close">✕</button>
      <div class="detail-modal-hero" id="detail-modal-hero"></div>
      <div class="detail-modal-body">
        <img class="detail-modal-poster" id="detail-modal-poster" src="" alt="">
        <div class="detail-modal-info">
          <div class="detail-modal-title" id="detail-modal-title"></div>
          <div class="detail-modal-meta" id="detail-modal-meta"></div>
          <div class="detail-modal-reasons" id="detail-modal-reasons"></div>
          <div class="detail-modal-genres" id="detail-modal-genres"></div>
          <p class="detail-modal-overview" id="detail-modal-overview"></p>
          <div class="detail-modal-credits" id="detail-modal-credits"></div>
          <div class="detail-modal-actions" id="detail-modal-actions"></div>
        </div>
      </div>
      <div class="detail-modal-trailer" id="detail-modal-trailer"></div>
    </div>
  </div>

  <!-- Request confirm dialog -->
  <div class="request-dialog-backdrop" id="request-dialog" aria-hidden="true">
    <div class="request-dialog-card" role="dialog" aria-modal="true">
      <div class="request-dialog-body">
        <div class="request-dialog-title" id="request-dialog-title">Request this title?</div>
        <div class="request-dialog-sub" id="request-dialog-sub"></div>
        <div class="request-dialog-actions" id="request-dialog-actions">
          <button class="btn-dialog-cancel" id="request-dialog-cancel">Cancel</button>
        </div>
      </div>
      <img class="request-dialog-poster" id="request-dialog-poster" src="" alt="" aria-hidden="true">
    </div>
  </div>

  <script>
    window.SEARCH_CONFIG = {
      userId: "<%= userId %>",
      query: <%- JSON.stringify(query) %>,
      services: {
        overseerr: <%= services.overseerr ? 'true' : 'false' %>,
        radarr: <%= services.radarr ? 'true' : 'false' %>,
        sonarr: <%= services.sonarr ? 'true' : 'false' %>,
      },
      hasAnyService: <%= hasAnyService ? 'true' : 'false' %>,
      requestsEnabled: <%= requestsEnabled ? 'true' : 'false' %>,
      individualSeasonsEnabled: <%= individualSeasonsEnabled ? 'true' : 'false' %>,
      directRequestAccess: "<%= directRequestAccess %>",
      isOwner: <%= isOwner ? 'true' : 'false' %>,
    };
  </script>
  <script src="/js/watchlist.js?v=8"></script>
  <script src="/js/search-app.js?v=12"></script>
</body>
</html>
