<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f0f0f" id="meta-theme-color">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Diskovarr">
  <link rel="apple-touch-icon" href="/icons/icon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/admin.css?v=22">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>" id="theme-css">
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="none" aria-hidden="true">
            <rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="currentColor"/>
            <rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="currentColor"/>
            <rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="currentColor"/>
            <rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="currentColor"/>
            <circle cx="15" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
            <line x1="18.5" y1="12.5" x2="22" y2="16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="logo-text">Diskovarr</span>
        <span class="admin-badge">admin</span>
      </a>
      <div class="nav-user">
        <a href="/" class="nav-logout">← App</a>
        <form method="POST" action="/admin/logout" style="display:inline">
          <button type="submit" class="nav-logout" style="background:none;border:none;cursor:pointer">Sign out</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <div class="hero">
      <h1 class="hero-title">Admin Panel</h1>
      <p class="hero-sub">Library sync, cache management, and system status</p>
    </div>

    <div id="toast" class="toast" style="display:none"></div>

    <!-- ── Version strip ────────────────────────────────────────── -->
    <div class="version-strip">
      <span class="version-badge">v<%= appVersion %></span>
      <% if (updateAvailable) { %>
        <a class="version-update-badge" href="https://github.com/Lebbitheplow/diskovarr/releases/latest" target="_blank" rel="noopener">
          ↑ v<%= latestVersion %> available
        </a>
      <% } else if (latestVersion) { %>
        <span class="version-uptodate">up to date</span>
      <% } %>
    </div>

    <!-- ── Tab navigation ───────────────────────────────────────── -->
    <div class="admin-tabs">
      <button class="admin-tab active" data-tab="settings">General</button>
      <button class="admin-tab" data-tab="users">Users</button>
      <button class="admin-tab" data-tab="connections">Connections</button>
    </div>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- GENERAL TAB                                                -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div class="admin-tab-panel" id="panel-settings">

      <!-- ── App Options ───────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">App Options</h2>
        </div>
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#fff;margin-bottom:8px">Set Landing Page</p>
        <p class="section-desc" style="margin-bottom:20px">
          Controls app-wide behavior and navigation defaults.
        </p>
        <div style="display:flex;align-items:center;gap:16px">
          <span id="lbl-landing-home" class="<%= landingPage !== 'explore' ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr</span>
          <label class="slide-toggle slide-toggle-choice">
            <input type="checkbox" id="toggle-landing-page"
              <%= landingPage === 'explore' ? 'checked' : '' %>
              onchange="onLandingPageChange(this.checked)">
            <span class="slide-track"></span>
          </label>
          <span id="lbl-landing-explore" class="<%= landingPage === 'explore' ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr Requests</span>
        </div>
        <p class="section-desc" style="margin-top:10px;font-size:0.82rem">
          Sets which page users land on after signing in. Diskovarr = personalized recommendation feed. Diskovarr Requests = content not yet in the library.
        </p>
      </section>

      <!-- ── Theme Color ────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Theme Color</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Pick an accent color. Changes apply immediately across the whole app.
        </p>
        <div class="color-picker-row">
          <div class="color-preview-strip" id="color-swatches"></div>
          <div class="color-wheel-wrap">
            <label for="custom-color-input">Custom</label>
            <input type="color" id="custom-color-input" title="Pick any color">
          </div>
          <button class="btn-admin btn-primary" id="btn-apply-color" onclick="applyColor()">Apply</button>
        </div>
      </section>

      <!-- ── Library Sync ─────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Library Sync</h2>
          <div style="display:flex;align-items:center;gap:16px">
            <div class="conn-toggle-row" style="margin:0">
              <span class="conn-toggle-sublabel" style="color:#fff;font-size:12px">Auto-Sync (every 2h)</span>
              <label class="slide-toggle">
                <input type="checkbox" id="autosync-toggle" <%= autoSyncEnabled ? 'checked' : '' %> onchange="onAutoSyncChange(this.checked)">
                <span class="slide-track"></span>
              </label>
            </div>
            <div id="sync-status-badge" class="status-badge <%= syncInProgress ? 'status-syncing' : 'status-idle' %>">
              <% if (syncInProgress) { %><span class="sync-spinner"></span><% } %>
              <span id="sync-status-text"><%= syncInProgress ? 'Syncing…' : 'Idle' %></span>
            </div>
          </div>
        </div>

        <div class="admin-grid">
          <div class="stat-card">
            <div class="stat-label">Movies</div>
            <div class="stat-value" id="stat-movies"><%= stats.library.movies.toLocaleString() %></div>
            <div class="stat-sub">
              Last sync: <span id="stat-movies-sync"><%= stats.library.lastSyncMovies ? relativeTime(stats.library.lastSyncMovies) : 'Never' %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-label">TV &amp; Anime</div>
            <div class="stat-value" id="stat-tv"><%= stats.library.tv.toLocaleString() %></div>
            <div class="stat-sub">
              Last sync: <span id="stat-tv-sync"><%= stats.library.lastSyncTV ? relativeTime(stats.library.lastSyncTV) : 'Never' %></span>
            </div>
          </div>
        </div>

        <div id="sync-progress-msg" class="sync-progress-msg" style="display:<%= syncInProgress ? 'block' : 'none' %>">
          Syncing libraries… TV &amp; Anime can take up to 2 minutes.
        </div>

        <div class="admin-actions">
          <button class="btn-admin btn-primary" id="btn-sync-now" onclick="syncLibrary()" <%= syncInProgress ? 'disabled' : '' %>>
            <span>↻</span> Sync Library Now
          </button>
        </div>

        <% if (lastSyncError) { %>
          <div class="error-banner" style="margin-top:16px">Last sync error: <%= lastSyncError %></div>
        <% } %>
      </section>


      <!-- ── Stats ─────────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Stats</h2>
        </div>
        <div class="admin-grid">
          <div class="stat-card">
            <div class="stat-label">Total Library Items</div>
            <div class="stat-value"><%= (stats.library.movies + stats.library.tv).toLocaleString() %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Total Dismissals</div>
            <div class="stat-value" id="stat-dismissals"><%= stats.dismissals.toLocaleString() %></div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Active Users (synced)</div>
            <div class="stat-value"><%= stats.users.length %></div>
          </div>
        </div>
      </section>

      <!-- ── Logging ───────────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <div>
            <h2 class="section-title">Logging</h2>
            <p class="section-desc" style="margin-top:4px">
              When enabled, Diskovarr writes timestamped logs to stdout/stderr.<br>
              View with: <code style="font-size:0.78rem;background:var(--bg-elevated);padding:1px 5px;border-radius:4px;border:1px solid var(--border)">sudo journalctl -u diskovarr -f</code>
              &nbsp;or&nbsp;
              <code style="font-size:0.78rem;background:var(--bg-elevated);padding:1px 5px;border-radius:4px;border:1px solid var(--border)">docker logs diskovarr -f</code>
            </p>
          </div>
          <label class="slide-toggle" style="flex-shrink:0">
            <input type="checkbox" id="logging-toggle"
              <%= loggingEnabled ? 'checked' : '' %>
              onchange="onLoggingChange(this.checked)">
            <span class="slide-track"></span>
          </label>
        </div>
      </section>

    </div><!-- /panel-settings -->

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- USERS TAB                                                  -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div class="admin-tab-panel" id="panel-users" hidden>

      <!-- ── Server Owner & Watchlist Mode ─────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Server Owner &amp; Watchlist Mode</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Select which Plex account is the server owner. The owner can use <strong>Diskovarr Playlist mode</strong>, which syncs watchlist items to a private "Diskovarr" server playlist instead of the native Plex.tv Watchlist — useful if your Watchlist triggers download automation (e.g. pd_zurg). All other users always use the Plex.tv Watchlist.
        </p>

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap">
          <label style="font-size:0.9rem;color:var(--text-secondary);white-space:nowrap">Server owner account:</label>
          <select id="owner-user-select" class="btn-admin" style="padding:6px 10px;cursor:pointer;min-width:200px">
            <option value="">— not set —</option>
            <% for (const u of knownUsers) { %>
              <option value="<%= u.user_id %>" <%= ownerUserId === u.user_id ? 'selected' : '' %>>
                <%= u.username %> (<%= u.user_id %>)
              </option>
            <% } %>
          </select>
          <button class="btn-admin btn-primary" onclick="saveOwnerUser()">Save</button>
          <% if (ownerUserId) { %>
            <span class="stat-sub" style="margin:0">
              Current: <strong><%= knownUsers.find(u => u.user_id === ownerUserId)?.username || ownerUserId %></strong>
            </span>
          <% } %>
        </div>

        <div style="display:flex;align-items:center;gap:12px">
          <span id="lbl-watchlist-opt" class="<%= watchlistMode !== 'playlist' ? 'service-label-active' : 'service-label-inactive' %>">Plex Watchlist</span>
          <label class="slide-toggle slide-toggle-choice">
            <input type="checkbox" id="toggle-watchlist-mode"
              <%= watchlistMode === 'playlist' ? 'checked' : '' %>
              onchange="onWatchlistModeChange(this.checked)">
            <span class="slide-track"></span>
          </label>
          <span id="lbl-playlist-opt" class="<%= watchlistMode === 'playlist' ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr Playlist</span>
        </div>
      </section>

      <!-- ── Users & Watch Sync ─────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Users &amp; Watch Sync</h2>
        </div>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:16px">
            <div class="conn-toggle-row" style="margin:0">
              <span class="conn-toggle-sublabel" style="color:#fff;font-size:13px;font-weight:500">Individual Requests</span>
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-individual-seasons"
                  <%= individualSeasonsEnabled ? 'checked' : '' %>
                  onchange="onIndividualSeasonsChange(this.checked)">
                <span class="slide-track"></span>
              </label>
            </div>
            <span class="section-desc" style="margin:0;font-size:0.82rem">When enabled, TV show requests present a season selector instead of requesting all seasons at once.</span>
          </div>
        </div>

        <% if (stats.users.length === 0) { %>
          <p class="empty-state" style="padding:20px 0">No users have synced yet.</p>
        <% } else { %>
          <div class="user-table-wrap">
          <div class="user-table" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 1fr 180px' : '' %>">
            <div class="user-table-header" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 1fr 180px' : '' %>">
              <span>User</span>
              <span>Watched Items</span>
              <span>Last Sync</span>
              <span>Actions</span>
              <% if (connections.discoverEnabled) { %><span>Override Global Limits</span><% } %>
            </div>
            <% for (const user of stats.users) { %>
              <div class="user-table-row" id="user-row-<%= user.user_id %>" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 1fr 180px' : '' %>">
                <span class="user-id">
                  <% if (user.thumb) { %>
                    <img src="<%= user.thumb %>" class="user-avatar-sm" alt="" onerror="this.style.display='none'">
                  <% } %>
                  <span><%= user.username %></span>
                  <span class="user-id-sub"><%= user.user_id %></span>
                </span>
                <span class="watched-count-cell" data-count="<%= user.watched_count %>"><%= user.watched_count.toLocaleString() %> items</span>
                <span><%= user.last_sync ? relativeTime(user.last_sync) : 'Never' %></span>
                <div class="user-actions">
                  <button class="btn-admin btn-sm" onclick="syncWatched('<%= user.user_id %>')">↻ Re-sync Watched</button>
                  <button class="btn-admin btn-sm btn-danger" onclick="clearWatched('<%= user.user_id %>')">✕ Clear Watched</button>
                  <button class="btn-admin btn-sm btn-danger" onclick="clearDismissals('<%= user.user_id %>')">✕ Clear Dismissals</button>
                </div>
                <% if (connections.discoverEnabled) { %>
                  <%
                    const uOverride = userLimitOverrides[user.user_id];
                    const uOverrideOn = uOverride && uOverride.overrideEnabled;
                  %>
                  <div style="display:flex;align-items:center;gap:8px">
                    <label class="slide-toggle">
                      <input type="checkbox" id="user-override-toggle-<%= user.user_id %>"
                        <%= uOverrideOn ? 'checked' : '' %>
                        onchange="onUserOverrideToggle('<%= user.user_id %>', '<%= user.username %>', this.checked)">
                      <span class="slide-track"></span>
                    </label>
                    <button id="user-limits-btn-<%= user.user_id %>"
                      class="btn-admin btn-sm"
                      style="<%= uOverrideOn ? '' : 'display:none' %>"
                      onclick="openLimitsModal('<%= user.user_id %>', '<%= user.username %>')">⚙ Set Limits</button>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
          </div><!-- /.user-table-wrap -->
        <% } %>

        <div class="admin-actions" style="margin-top:16px">
          <button class="btn-admin btn-danger" onclick="confirmAction('Clear ALL watched caches for all users?', clearAllWatched)">
            Clear All Watched Caches
          </button>
          <button class="btn-admin btn-danger" onclick="confirmAction('Clear ALL dismissals for all users?', clearAllDismissals)">
            Clear All Dismissals
          </button>
          <button class="btn-admin" onclick="clearRecCache()">↺ Clear Rec Cache (All Users)</button>
        </div>
      </section>

      <% if (connections.discoverEnabled) { %>
      <!-- ── Global Request Limits ─────────────────────────────── -->
      <section class="admin-section" id="section-request-limits">
        <div class="admin-section-header">
          <h2 class="section-title">Global Request Limits</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Default limits applied to each user individually. Users with the override toggle enabled above can have custom limits set via <strong>⚙ Set Limits</strong>.
        </p>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px">

          <!-- Movies row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="limit-movie-unlimited"
                <%= globalLimits.movieLimit === 0 ? 'checked' : '' %>
                onchange="onMovieUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="limit-movie-fields" style="display:<%= globalLimits.movieLimit === 0 ? 'none' : 'flex' %>;align-items:center;gap:8px">
              <input type="number" id="limit-movie-count" min="1" max="9999" class="btn-admin limit-num"
                value="<%= globalLimits.movieLimit || 1 %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">movies per</span>
              <input type="number" id="limit-movie-days" min="1" max="365" class="btn-admin limit-num"
                value="<%= globalLimits.movieWindowDays %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

          <!-- TV Seasons row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">TV Seasons</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="limit-season-unlimited"
                <%= globalLimits.seasonLimit === 0 ? 'checked' : '' %>
                onchange="onSeasonUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="limit-season-fields" style="display:<%= globalLimits.seasonLimit === 0 ? 'none' : 'flex' %>;align-items:center;gap:8px">
              <input type="number" id="limit-season-count" min="1" max="9999" class="btn-admin limit-num"
                value="<%= globalLimits.seasonLimit || 1 %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">seasons per</span>
              <input type="number" id="limit-season-days" min="1" max="365" class="btn-admin limit-num"
                value="<%= globalLimits.seasonWindowDays %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

        </div>
        <button class="btn-admin btn-primary" onclick="saveGlobalLimits()">Save</button>
      </section>
      <% } %>

    </div><!-- /panel-users -->

    <!-- Per-user limits modal -->
    <div id="user-limits-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.7);align-items:center;justify-content:center">
      <div style="background:var(--bg-secondary);border-radius:14px;padding:28px;width:min(480px,90vw);border:1px solid var(--border);position:relative">
        <button onclick="closeLimitsModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer">✕</button>
        <h3 style="margin:0 0 4px;font-size:1.05rem">Custom Request Limits</h3>
        <p id="user-limits-modal-name" style="margin:0 0 20px;color:var(--text-secondary);font-size:0.88rem"></p>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:24px">

          <!-- Movies row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="user-limit-movie-unlimited" onchange="onUserMovieUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="user-limit-movie-fields" style="display:flex;align-items:center;gap:8px">
              <input type="number" id="user-limit-movie-count" min="1" max="9999" class="btn-admin limit-num" value="1">
              <span style="font-size:0.88rem;color:var(--text-secondary)">movies per</span>
              <input type="number" id="user-limit-movie-days" min="1" max="365" class="btn-admin limit-num" value="7">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

          <!-- TV Seasons row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">TV Seasons</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="user-limit-season-unlimited" onchange="onUserSeasonUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="user-limit-season-fields" style="display:flex;align-items:center;gap:8px">
              <input type="number" id="user-limit-season-count" min="1" max="9999" class="btn-admin limit-num" value="1">
              <span style="font-size:0.88rem;color:var(--text-secondary)">seasons per</span>
              <input type="number" id="user-limit-season-days" min="1" max="365" class="btn-admin limit-num" value="7">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end">
          <button class="btn-admin" onclick="closeLimitsModal()">Cancel</button>
          <button class="btn-admin btn-primary" onclick="saveUserLimits()">Save</button>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS TAB                                            -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <%
      function svcHost(url) {
        if (!url) return '';
        try { const u = new URL(url); return u.protocol + '//' + u.hostname; } catch(e) { return url; }
      }
      function svcPort(url) {
        if (!url) return '';
        try { const u = new URL(url); return u.port || ''; } catch(e) { return ''; }
      }
    %>
    <div class="admin-tab-panel" id="panel-connections" hidden>

      <section class="admin-section">
        <p class="section-desc" style="margin-bottom:24px">
