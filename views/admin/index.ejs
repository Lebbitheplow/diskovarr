<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — Admin</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f0f0f" id="meta-theme-color">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Diskovarr">
  <link rel="apple-touch-icon" href="/icons/icon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=31">
  <link rel="stylesheet" href="/css/admin.css?v=29">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>" id="theme-css">
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="none" aria-hidden="true">
            <rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="currentColor"/>
            <rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="currentColor"/>
            <rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="currentColor"/>
            <rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="currentColor"/>
            <circle cx="15" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
            <line x1="18.5" y1="12.5" x2="22" y2="16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="logo-text">Diskovarr</span>
        <span class="admin-badge">admin</span>
      </a>
      <div class="nav-user">
        <a href="/" class="nav-logout">← App</a>
        <form method="POST" action="/admin/logout" style="display:inline">
          <button type="submit" class="nav-logout" style="background:none;border:none;cursor:pointer">Sign out</button>
        </form>
      </div>
    </div>
  </nav>

  <main class="main-content">
    <div class="hero">
      <h1 class="hero-title">Admin Panel</h1>
      <p class="hero-sub">Connections, users, requests, and system settings</p>
    </div>

    <div id="toast" class="toast" style="display:none"></div>

    <!-- ── Version strip ────────────────────────────────────────── -->
    <div class="version-strip">
      <span class="version-badge">v<%= appVersion %></span>
      <% if (updateAvailable) { %>
        <a class="version-update-badge" href="https://github.com/Lebbitheplow/diskovarr/releases/latest" target="_blank" rel="noopener">
          ↑ v<%= latestVersion %> available
        </a>
      <% } else if (latestVersion) { %>
        <span class="version-uptodate">up to date</span>
      <% } %>
    </div>

    <!-- ── Tab navigation ───────────────────────────────────────── -->
    <div class="admin-tabs">
      <button class="admin-tab active" data-tab="settings">General</button>
      <button class="admin-tab" data-tab="users">Users</button>
      <button class="admin-tab" data-tab="connections">Connections</button>
      <button class="admin-tab" data-tab="notifications">Notifications</button>
    </div>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- GENERAL TAB                                                -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div class="admin-tab-panel" id="panel-settings">

      <!-- ── App Options ───────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">App Options</h2>
        </div>
        <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:#fff;margin-bottom:8px">Set Landing Page</p>
        <p class="section-desc" style="margin-bottom:20px">
          Controls app-wide behavior and navigation defaults.
        </p>
        <div style="display:flex;align-items:center;gap:16px">
          <span id="lbl-landing-home" class="<%= landingPage !== 'explore' ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr</span>
          <label class="slide-toggle slide-toggle-choice" title="<%= !connections.discoverEnabled ? 'Enable Diskovarr Requests in Connections first' : '' %>">
            <input type="checkbox" id="toggle-landing-page"
              <%= landingPage === 'explore' ? 'checked' : '' %>
              <%= !connections.discoverEnabled ? 'disabled' : '' %>
              onchange="onLandingPageChange(this.checked)">
            <span class="slide-track"></span>
          </label>
          <span id="lbl-landing-explore" class="<%= landingPage === 'explore' && connections.discoverEnabled ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr Requests</span>
        </div>
        <p class="section-desc" style="margin-top:10px;font-size:0.82rem">
          Sets which page users land on after signing in. Diskovarr = personalized recommendation feed. Diskovarr Requests = content not yet in the library.
        </p>
        <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--border)">
          <label class="settings-label" style="font-size:0.85rem;font-weight:500;color:#fff;display:block;margin-bottom:6px">
            App Public URL
            <span style="color:var(--text-muted);font-weight:400"> — required for Discord bot avatar</span>
          </label>
          <p style="font-size:0.78rem;color:var(--text-secondary);margin:0 0 8px">
            The externally reachable URL of this Diskovarr instance (e.g. <code style="font-size:0.75rem">https://diskovarr.yourdomain.com</code>).
          </p>
          <div style="display:flex;gap:8px;align-items:center">
            <input type="url" id="app-public-url" class="conn-input" style="max-width:380px"
              placeholder="https://diskovarr.yourdomain.com"
              onfocus="if(!this.value.trim())this.value='https://'"
              value="<%= appPublicUrl %>">
            <button class="btn-admin btn-primary" onclick="saveAppPublicUrl()">Save</button>
          </div>
        </div>
      </section>

      <!-- ── Theme Color ────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Theme Color</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Pick an accent color. Changes apply immediately across the whole app.
        </p>
        <div class="color-picker-row">
          <div class="color-preview-strip" id="color-swatches"></div>
          <div class="color-wheel-wrap">
            <label for="custom-color-input">Custom</label>
            <input type="color" id="custom-color-input" title="Pick any color">
          </div>
          <button class="btn-admin btn-primary" id="btn-apply-color" onclick="applyColor()">Apply</button>
        </div>
      </section>

      <!-- ── Library Sync ─────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Library Sync</h2>
          <div style="display:flex;align-items:center;gap:16px">
            <div class="conn-toggle-row" style="margin:0">
              <span class="conn-toggle-sublabel" style="color:#fff;font-size:12px">Auto-Sync (every 2h)</span>
              <label class="slide-toggle">
                <input type="checkbox" id="autosync-toggle" <%= autoSyncEnabled ? 'checked' : '' %> onchange="onAutoSyncChange(this.checked)">
                <span class="slide-track"></span>
              </label>
            </div>
            <div id="sync-status-badge" class="status-badge <%= syncInProgress ? 'status-syncing' : 'status-idle' %>">
              <% if (syncInProgress) { %><span class="sync-spinner"></span><% } %>
              <span id="sync-status-text"><%= syncInProgress ? 'Syncing…' : 'Idle' %></span>
            </div>
          </div>
        </div>

        <div class="admin-grid">
          <div class="stat-card">
            <div class="stat-label">Movies</div>
            <div class="stat-value" id="stat-movies"><%= stats.library.movies.toLocaleString() %></div>
            <div class="stat-sub">
              Last sync: <span id="stat-movies-sync"><%= stats.library.lastSyncMovies ? relativeTime(stats.library.lastSyncMovies) : 'Never' %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-label">TV &amp; Anime</div>
            <div class="stat-value" id="stat-tv"><%= stats.library.tv.toLocaleString() %></div>
            <div class="stat-sub">
              Last sync: <span id="stat-tv-sync"><%= stats.library.lastSyncTV ? relativeTime(stats.library.lastSyncTV) : 'Never' %></span>
            </div>
          </div>
          <div class="stat-card">
            <div class="stat-label">Total</div>
            <div class="stat-value" id="stat-total"><%= (stats.library.movies + stats.library.tv).toLocaleString() %></div>
          </div>
        </div>

        <div id="sync-progress-msg" class="sync-progress-msg" style="display:<%= syncInProgress ? 'block' : 'none' %>">
          Syncing libraries… TV &amp; Anime can take up to 2 minutes.
        </div>

        <div class="admin-actions">
          <button class="btn-admin btn-primary" id="btn-sync-now" onclick="syncLibrary()" <%= syncInProgress ? 'disabled' : '' %>>
            <span>↻</span> Sync Library Now
          </button>
        </div>

        <% if (lastSyncError) { %>
          <div class="error-banner" style="margin-top:16px">Last sync error: <%= lastSyncError %></div>
        <% } %>
      </section>


      <!-- ── Logging ───────────────────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <div>
            <h2 class="section-title">Verbose Logging</h2>
            <p class="section-desc" style="margin-top:4px">
              When enabled, Diskovarr writes detailed HTTP request logs and debug output. Basic info/warn/error logs are always written.<br>
              View with: <code style="font-size:0.78rem;background:var(--bg-elevated);padding:1px 5px;border-radius:4px;border:1px solid var(--border)">sudo journalctl -u diskovarr -f</code>
              &nbsp;or&nbsp;
              <code style="font-size:0.78rem;background:var(--bg-elevated);padding:1px 5px;border-radius:4px;border:1px solid var(--border)">docker logs diskovarr -f</code>
            </p>
          </div>
          <label class="slide-toggle" style="flex-shrink:0">
            <input type="checkbox" id="verbose-logging-toggle"
              <%= verboseLoggingEnabled ? 'checked' : '' %>
              onchange="onVerboseLoggingChange(this.checked)">
            <span class="slide-track"></span>
          </label>
        </div>
      </section>

      <!-- ── API Key ──────────────────────────────────────────── -->
      <section class="admin-section">
        <div class="section-header">
          <h2 class="section-title">API Key</h2>
        </div>
        <p class="section-desc">Use this key to authenticate external applications with Diskovarr's API. Send it as an <code>Authorization: Bearer &lt;key&gt;</code> or <code>X-Api-Key</code> header. The key grants admin-level access to all API endpoints.</p>

        <div class="conn-field-group" style="max-width:520px;margin-bottom:0.75rem">
          <span class="conn-field-label">API Key</span>
          <div class="conn-input-wrap">
            <input type="password" id="settings-api-key" class="conn-input" readonly
              value="<%= hasApiKey ? '••••••••' : '' %>"
              placeholder="No key generated yet">
            <div class="conn-input-btns">
              <% if (hasApiKey) { %>
                <button type="button" class="conn-input-icon-btn" id="api-key-eye-btn"
                  onclick="toggleFieldVis('settings-api-key', this)" title="Show / hide"></button>
                <button type="button" class="conn-input-icon-btn" id="api-key-copy-btn"
                  onclick="copyApiKey()" title="Copy to clipboard"></button>
              <% } %>
            </div>
          </div>
        </div>
        <button class="btn-admin btn-primary" onclick="generateApiKey()">
          <%= hasApiKey ? 'Regenerate Key' : 'Generate API Key' %>
        </button>

        <!-- Inline API endpoint reference -->
        <details style="margin-top:1.5rem">
          <summary style="cursor:pointer;font-size:0.85rem;color:var(--text-secondary);user-select:none">API Endpoint Reference</summary>
          <div class="api-docs" style="margin-top:0.75rem;font-size:0.82rem;line-height:1.7">
            <p style="margin-bottom:0.5rem;color:var(--text-secondary)">All endpoints require authentication. Prefix with your Diskovarr base URL.</p>
            <table class="api-docs-table">
              <thead><tr><th>Method</th><th>Path</th><th>Description</th></tr></thead>
              <tbody>
                <tr><td>GET</td><td>/api/recommendations</td><td>Personalized recommendations for authenticated user</td></tr>
                <tr><td>GET</td><td>/api/search?q=&lt;query&gt;</td><td>Full-text library search with pagination</td></tr>
                <tr><td>GET</td><td>/api/discover</td><td>Browse library with type/genre/decade/rating filters</td></tr>
                <tr><td>GET</td><td>/api/watchlist</td><td>Authenticated user's watchlist</td></tr>
                <tr><td>POST</td><td>/api/request</td><td>Submit a media request (body: tmdbId, mediaType, seasons)</td></tr>
                <tr><td>GET</td><td>/api/queue</td><td>All requests — pending, approved, denied (admin)</td></tr>
                <tr><td>PUT</td><td>/api/queue/:id</td><td>Edit request service or seasons (admin)</td></tr>
                <tr><td>POST</td><td>/api/queue/:id/approve</td><td>Approve a pending request (admin)</td></tr>
                <tr><td>POST</td><td>/api/queue/:id/deny</td><td>Deny a request with optional note (admin)</td></tr>
                <tr><td>DELETE</td><td>/api/queue/:id</td><td>Delete a request (admin)</td></tr>
              </tbody>
            </table>
          </div>
        </details>
      </section>

    </div><!-- /panel-settings -->

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- USERS TAB                                                  -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div class="admin-tab-panel" id="panel-users" hidden>

      <!-- ── Server Owner & Watchlist Mode ─────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Server Owner &amp; Watchlist Mode</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Select which Plex account is the server owner. The owner can use <strong>Diskovarr Playlist mode</strong>, which syncs watchlist items to a private "Diskovarr" server playlist instead of the native Plex.tv Watchlist — useful if your Watchlist triggers download automation (e.g. pd_zurg). All other users always use the Plex.tv Watchlist.
        </p>

        <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap">
          <label style="font-size:0.9rem;color:var(--text-secondary);white-space:nowrap">Server owner account:</label>
          <select id="owner-user-select" class="btn-admin" style="padding:6px 10px;cursor:pointer;min-width:200px">
            <option value="">— not set —</option>
            <% for (const u of knownUsers) { %>
              <option value="<%= u.user_id %>" <%= ownerUserId === u.user_id ? 'selected' : '' %>>
                <%= u.username %> (<%= u.user_id %>)
              </option>
            <% } %>
          </select>
          <button class="btn-admin btn-primary" onclick="saveOwnerUser()">Save</button>
          <% if (ownerUserId) { %>
            <span class="stat-sub" style="margin:0">
              Current: <strong><%= knownUsers.find(u => u.user_id === ownerUserId)?.username || ownerUserId %></strong>
            </span>
          <% } %>
        </div>

        <div style="display:flex;align-items:center;gap:12px">
          <span id="lbl-watchlist-opt" class="<%= watchlistMode !== 'playlist' ? 'service-label-active' : 'service-label-inactive' %>">Plex Watchlist</span>
          <label class="slide-toggle slide-toggle-choice">
            <input type="checkbox" id="toggle-watchlist-mode"
              <%= watchlistMode === 'playlist' ? 'checked' : '' %>
              onchange="onWatchlistModeChange(this.checked)">
            <span class="slide-track"></span>
          </label>
          <span id="lbl-playlist-opt" class="<%= watchlistMode === 'playlist' ? 'service-label-active' : 'service-label-inactive' %>">Diskovarr Playlist</span>
        </div>
      </section>

      <!-- ── Users & Watch Sync ─────────────────────────────── -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Users &amp; Watch Sync</h2>
        </div>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:16px">
            <div class="conn-toggle-row" style="margin:0">
              <span class="conn-toggle-sublabel" style="color:#fff;font-size:13px;font-weight:500">Individual Requests</span>
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-individual-seasons"
                  <%= individualSeasonsEnabled ? 'checked' : '' %>
                  onchange="onIndividualSeasonsChange(this.checked)">
                <span class="slide-track"></span>
              </label>
            </div>
            <span class="section-desc" style="margin:0;font-size:0.82rem">When enabled, TV show requests present a season selector instead of requesting all seasons at once.</span>
          </div>
        </div>

        <% if (stats.users.length === 0) { %>
          <p class="empty-state" style="padding:20px 0">No users have synced yet.</p>
        <% } else { %>
          <div class="user-table-wrap">
          <div class="user-table" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 120px' : '' %>">
            <div class="user-table-header" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 120px' : '' %>">
              <span>User</span>
              <span>Watched Items</span>
              <span>Last Visit</span>
              <% if (connections.discoverEnabled) { %><span>Settings</span><% } %>
            </div>
            <% for (const user of stats.users) { %>
              <div class="user-table-row" id="user-row-<%= user.user_id %>" style="<%= connections.discoverEnabled ? 'grid-template-columns: minmax(140px,1fr) 110px 120px 120px' : '' %>">
                <span class="user-id">
                  <% if (user.thumb) { %>
                    <img src="<%= user.thumb %>" class="user-avatar-sm" alt="" onerror="this.style.display='none'">
                  <% } %>
                  <span><%= user.username %></span>
                  <span class="user-id-sub"><%= user.user_id %></span>
                </span>
                <span class="watched-count-cell" data-count="<%= user.watched_count %>"><%= user.watched_count.toLocaleString() %> items</span>
                <span><%= user.last_login ? relativeTime(user.last_login) : 'Never' %></span>
                <% if (connections.discoverEnabled) { %>
                  <div>
                    <a class="btn-admin btn-sm" href="/admin/user-settings/<%= user.user_id %>">Edit</a>
                  </div>
                <% } %>
              </div>
            <% } %>
          </div>
          </div><!-- /.user-table-wrap -->
          <% if (userTotalPages > 1) { %>
          <div style="display:flex;align-items:center;gap:10px;margin-top:16px;font-size:0.85rem;color:var(--text-secondary)">
            <% if (userPage > 1) { %>
              <a class="btn-admin btn-sm" href="/admin?userPage=<%= userPage - 1 %>&userPerPage=<%= userPerPage %>#users-tab">&#8249; Prev</a>
            <% } %>
            <span>Page <%= userPage %> of <%= userTotalPages %> (<%= totalUsers %> users)</span>
            <% if (userPage < userTotalPages) { %>
              <a class="btn-admin btn-sm" href="/admin?userPage=<%= userPage + 1 %>&userPerPage=<%= userPerPage %>#users-tab">Next &#8250;</a>
            <% } %>
            <select onchange="window.location='/admin?userPage=1&userPerPage='+this.value+'#users-tab'" style="padding:4px 8px;border-radius:5px;border:1px solid var(--border);background:var(--bg-elevated);color:var(--text);font-size:0.82rem">
              <option value="10" <%= userPerPage === 10 ? 'selected' : '' %>>10/page</option>
              <option value="25" <%= userPerPage === 25 ? 'selected' : '' %>>25/page</option>
              <option value="50" <%= userPerPage === 50 ? 'selected' : '' %>>50/page</option>
            </select>
          </div>
          <% } %>
        <% } %>

        <div class="admin-actions" style="margin-top:16px">
          <button class="btn-admin btn-danger" onclick="confirmAction('Clear ALL watched caches for all users?', clearAllWatched)">
            Clear All Watched Caches
          </button>
          <button class="btn-admin btn-danger" onclick="confirmAction('Clear ALL dismissals for all users?', clearAllDismissals)">
            Clear All Dismissals
          </button>
          <button class="btn-admin" onclick="clearRecCache()">↺ Clear Rec Cache (All Users)</button>
        </div>
      </section>

      <% if (connections.discoverEnabled) { %>
      <!-- ── Global Request Limits ─────────────────────────────── -->
      <section class="admin-section" id="section-request-limits">
        <div class="admin-section-header">
          <h2 class="section-title">Global Request Limits</h2>
        </div>
        <p class="section-desc" style="margin-bottom:20px">
          Default limits applied to each user individually. Users with the override toggle enabled above can have custom limits set via <strong>⚙ Set Limits</strong>.
        </p>

        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px">

          <!-- Movies row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="limit-movie-unlimited"
                <%= globalLimits.movieLimit === 0 ? 'checked' : '' %>
                onchange="onMovieUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="limit-movie-fields" style="display:<%= globalLimits.movieLimit === 0 ? 'none' : 'flex' %>;align-items:center;gap:8px">
              <input type="number" id="limit-movie-count" min="1" max="9999" class="btn-admin limit-num"
                value="<%= globalLimits.movieLimit || 1 %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">movies per</span>
              <input type="number" id="limit-movie-days" min="1" max="365" class="btn-admin limit-num"
                value="<%= globalLimits.movieWindowDays %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

          <!-- TV Seasons row -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">TV Seasons</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="limit-season-unlimited"
                <%= globalLimits.seasonLimit === 0 ? 'checked' : '' %>
                onchange="onSeasonUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="limit-season-fields" style="display:<%= globalLimits.seasonLimit === 0 ? 'none' : 'flex' %>;align-items:center;gap:8px">
              <input type="number" id="limit-season-count" min="1" max="9999" class="btn-admin limit-num"
                value="<%= globalLimits.seasonLimit || 1 %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">seasons per</span>
              <input type="number" id="limit-season-days" min="1" max="365" class="btn-admin limit-num"
                value="<%= globalLimits.seasonWindowDays %>">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>

        </div>
        <button class="btn-admin btn-primary" onclick="saveGlobalLimits()">Save</button>

        <!-- Auto-approve toggles -->
        <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border)">
          <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-secondary);margin:0 0 14px">Auto Approve Requests</p>
          <p class="section-desc" style="margin-bottom:14px;font-size:0.82rem">
            When enabled, requests go directly to the configured service. When disabled, requests enter the queue for review. Per-user overrides can be set via <strong>Edit</strong>.
          </p>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div style="display:flex;align-items:center;gap:14px">
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-auto-approve-movies"
                  onchange="onAutoApproveChange('movies', this.checked)">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            </div>
            <div style="display:flex;align-items:center;gap:14px">
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-auto-approve-tv"
                  onchange="onAutoApproveChange('tv', this.checked)">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.9rem;color:#fff;font-weight:500">TV Shows</span>
            </div>
          </div>
        </div>

        <!-- Auto-Request Watchlist subsection -->
        <div style="margin-top:24px;padding-top:20px;border-top:1px solid var(--border)">
          <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-secondary);margin:0 0 14px">Auto-Request Watchlist</p>
          <p class="section-desc" style="margin-bottom:14px;font-size:0.82rem">
            When enabled, items added to a user's Plex watchlist are automatically submitted as requests (if not already in the library). Per-user overrides can be set via <strong>Edit</strong>.
          </p>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div style="display:flex;align-items:center;gap:14px">
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-auto-request-movies" onchange="onAutoRequestChange('movies', this.checked)">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            </div>
            <div style="display:flex;align-items:center;gap:14px">
              <label class="slide-toggle">
                <input type="checkbox" id="toggle-auto-request-tv" onchange="onAutoRequestChange('tv', this.checked)">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.9rem;color:#fff;font-weight:500">TV Shows</span>
            </div>
          </div>
        </div>
      </section>
      <% } %>

    </div><!-- /panel-users -->

    <!-- User settings modal (replaces per-user limits modal) -->
    <div id="user-settings-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.75);align-items:center;justify-content:center">
      <div style="background:var(--bg-secondary);border-radius:14px;padding:28px;width:min(520px,92vw);border:1px solid var(--border);position:relative;max-height:90vh;overflow-y:auto">
        <button onclick="closeUserSettingsModal()" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer">✕</button>
        <h3 style="margin:0 0 4px;font-size:1.05rem">User Settings</h3>
        <p id="user-settings-modal-name" style="margin:0 0 20px;color:var(--text-secondary);font-size:0.88rem"></p>

        <!-- Override limits toggle -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border)">
          <label class="slide-toggle">
            <input type="checkbox" id="ums-override-toggle" onchange="onUmsOverrideChange(this.checked)">
            <span class="slide-track"></span>
          </label>
          <span style="font-size:0.9rem;color:#fff;font-weight:500">Override global request limits</span>
        </div>

        <div id="ums-limits-fields" style="display:none;flex-direction:column;gap:14px;margin-bottom:20px">
          <!-- Movies -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">Movies</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="ums-movie-unlimited" onchange="onUmsMovieUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="ums-movie-fields" style="display:flex;align-items:center;gap:8px">
              <input type="number" id="ums-movie-count" min="1" max="9999" class="btn-admin limit-num" value="1">
              <span style="font-size:0.88rem;color:var(--text-secondary)">movies per</span>
              <input type="number" id="ums-movie-days" min="1" max="365" class="btn-admin limit-num" value="7">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>
          <!-- TV Seasons -->
          <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap">
            <span style="min-width:84px;font-size:0.9rem;color:#fff;font-weight:500">TV Seasons</span>
            <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:0.88rem;color:var(--text-secondary);user-select:none">
              <input type="checkbox" class="themed-checkbox" id="ums-season-unlimited" onchange="onUmsSeasonUnlimitedChange(this.checked)">
              Unlimited
            </label>
            <div id="ums-season-fields" style="display:flex;align-items:center;gap:8px">
              <input type="number" id="ums-season-count" min="1" max="9999" class="btn-admin limit-num" value="1">
              <span style="font-size:0.88rem;color:var(--text-secondary)">seasons per</span>
              <input type="number" id="ums-season-days" min="1" max="365" class="btn-admin limit-num" value="7">
              <span style="font-size:0.88rem;color:var(--text-secondary)">days</span>
            </div>
          </div>
        </div>

        <!-- Auto-approve overrides -->
        <div style="margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--border)">
          <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            <label class="slide-toggle">
              <input type="checkbox" id="ums-auto-approve-override" onchange="onUmsAutoApproveOverrideChange(this.checked)">
              <span class="slide-track"></span>
            </label>
            <span style="font-size:0.9rem;color:#fff;font-weight:500">Override global approval settings</span>
          </div>
          <div id="ums-auto-approve-fields" style="display:none;flex-direction:column;gap:10px;padding-left:4px">
            <div style="display:flex;align-items:center;gap:12px">
              <label class="slide-toggle">
                <input type="checkbox" id="ums-auto-approve-movies-toggle">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.88rem;color:var(--text-secondary)">Auto-approve movie requests</span>
            </div>
            <div style="display:flex;align-items:center;gap:12px">
              <label class="slide-toggle">
                <input type="checkbox" id="ums-auto-approve-tv-toggle">
                <span class="slide-track"></span>
              </label>
              <span style="font-size:0.88rem;color:var(--text-secondary)">Auto-approve TV Show requests</span>
            </div>
          </div>
        </div>

        <!-- Admin privileges -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:24px">
          <label class="slide-toggle">
            <input type="checkbox" id="ums-is-admin">
            <span class="slide-track"></span>
          </label>
          <span style="font-size:0.9rem;color:#fff;font-weight:500">Elevated privileges (queue access)</span>
        </div>

        <!-- User actions -->
        <div style="margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)">
          <div style="font-size:0.82rem;font-weight:600;color:var(--text-secondary);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.05em">Actions</div>
          <div style="display:flex;gap:8px;flex-wrap:wrap">
            <button class="btn-admin btn-sm" onclick="syncWatched(_umsUserId)">↻ Re-sync Watched</button>
            <button class="btn-admin btn-sm btn-danger" onclick="clearWatched(_umsUserId)">✕ Clear Watched</button>
            <button class="btn-admin btn-sm btn-danger" onclick="clearDismissals(_umsUserId)">✕ Clear Dismissals</button>
            <button class="btn-admin btn-sm btn-danger" onclick="clearUserRequests(_umsUserId)">✕ Clear Requests</button>
          </div>
        </div>

        <div style="display:flex;gap:10px;justify-content:flex-end">
          <button class="btn-admin" onclick="closeUserSettingsModal()">Cancel</button>
          <button class="btn-admin btn-primary" onclick="saveUserSettings()">Save</button>
        </div>
      </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- CONNECTIONS TAB                                            -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <%
      function svcHost(url) {
        if (!url) return '';
        try { const u = new URL(url); return u.protocol + '//' + u.hostname; } catch(e) { return url; }
      }
      function svcPort(url) {
        if (!url) return '';
        try { const u = new URL(url); return u.port || ''; } catch(e) { return ''; }
      }
    %>
    <div class="admin-tab-panel" id="panel-connections" hidden>

      <section class="admin-section">
        <p class="section-desc" style="margin-bottom:24px">
          Configure external metadata sources and request services. Fill in the URL and API key for a service, then flip its toggle to enable it. Settings are saved automatically when the toggle changes.
        </p>

        <!-- Plex -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">Plex</span>
              <span class="conn-block-desc">Your Plex Media Server — required for library sync and authentication</span>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-host">
              <span class="conn-field-label">Address</span>
              <input type="text" id="conn-plex-host" class="conn-input"
                placeholder="http://localhost"
                value="<%= svcHost(connections.plexUrl) %>">
            </div>
            <div class="conn-field-group conn-field-port">
              <span class="conn-field-label">Port <span class="conn-field-optional">optional</span></span>
              <input type="number" id="conn-plex-port" class="conn-input conn-input-port"
                placeholder="32400" min="1" max="65535"
                value="<%= svcPort(connections.plexUrl) %>"
                oninput="this.value=this.value.replace(/[^0-9]/g,'')">
            </div>
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">Token</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-plex-token" class="conn-input"
                  placeholder="Plex Token"
                  value="<%= connections.plexToken ? '••••••••' : '' %>"
                  autocomplete="new-password">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-plex-token', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testCoreService('plex')">Test</button>
            <button class="btn-admin btn-primary conn-action-btn" onclick="saveCoreService('plex')">Save</button>
          </div>
        </div>

        <!-- Tautulli -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">Tautulli</span>
              <span class="conn-block-desc">Watch history source — required for personalized recommendations</span>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-host">
              <span class="conn-field-label">Address</span>
              <input type="text" id="conn-tautulli-host" class="conn-input"
                placeholder="http://localhost"
                value="<%= svcHost(connections.tautulliUrl) %>">
            </div>
            <div class="conn-field-group conn-field-port">
              <span class="conn-field-label">Port <span class="conn-field-optional">optional</span></span>
              <input type="number" id="conn-tautulli-port" class="conn-input conn-input-port"
                placeholder="8181" min="1" max="65535"
                value="<%= svcPort(connections.tautulliUrl) %>"
                oninput="this.value=this.value.replace(/[^0-9]/g,'')">
            </div>
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">API Key</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-tautulli-key" class="conn-input"
                  placeholder="API Key"
                  value="<%= connections.tautulliApiKey ? '••••••••' : '' %>"
                  autocomplete="new-password">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-tautulli-key', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testCoreService('tautulli')">Test</button>
            <button class="btn-admin btn-primary conn-action-btn" onclick="saveCoreService('tautulli')">Save</button>
          </div>
        </div>

        <!-- TMDB + Diskovarr Requests toggle -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">TMDB</span>
              <span class="conn-block-desc">The Movie Database — metadata source for Diskovarr Requests</span>
            </div>
            <div class="conn-toggle-wrap">
              <div class="conn-toggle-stack">
                <span class="conn-toggle-sublabel" style="color:#fff">Diskovarr Requests Tab</span>
                <div class="conn-toggle-row">
                  <span class="conn-toggle-label" id="lbl-discover"><%= connections.discoverEnabled ? 'Enabled' : 'Disabled' %></span>
                  <label class="slide-toggle" title="<%= !connections.tmdbApiKey ? 'Save a TMDB API key first' : '' %>">
                    <input type="checkbox" id="toggle-discover"
                      <%= connections.discoverEnabled ? 'checked' : '' %>
                      <%= !connections.tmdbApiKey ? 'disabled' : '' %>
                      onchange="onToggleChange('discover')">
                    <span class="slide-track"></span>
                  </label>
                </div>
              </div>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">API Key</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-tmdb-key" class="conn-input"
                  placeholder="API Key (v3 auth)"
                  value="<%= connections.tmdbApiKey ? '••••••••' : '' %>"
                  autocomplete="new-password"
                  oninput="onFieldInput('discover')">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-tmdb-key', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testConnection('tmdb')">Test</button>
            <button class="btn-admin btn-primary conn-action-btn" onclick="saveTmdbKey()">Save Key</button>
          </div>
        </div>

        <!-- Default request service toggle — only shown when both sides are configured -->
        <% const hasBothSides = connections.overseerrEnabled && connections.overseerrUrl &&
             ((connections.radarrEnabled && connections.radarrUrl) || (connections.sonarrEnabled && connections.sonarrUrl)); %>
        <div class="conn-block" id="default-service-block" style="<%= hasBothSides ? '' : 'display:none' %>">
          <div class="conn-block-header" style="border-bottom:none;padding-bottom:0">
            <div class="conn-block-meta">
              <span class="conn-block-name">Default app for requests</span>
              <span class="conn-block-desc" id="default-service-desc">
                <%= (connections.defaultRequestService === 'direct') ? 'Sonarr/Radarr is the default' : 'Overseerr is the default' %>
              </span>
            </div>
            <div class="conn-toggle-wrap" style="gap:10px;align-items:center">
              <span id="lbl-overseerr-opt" class="<%= (connections.defaultRequestService !== 'direct') ? 'service-label-active' : 'service-label-inactive' %>">Overseerr</span>
              <label class="slide-toggle slide-toggle-choice">
                <input type="checkbox" id="toggle-default-service"
                  <%= (connections.defaultRequestService === 'direct') ? 'checked' : '' %>
                  onchange="onDefaultServiceChange(this.checked)">
                <span class="slide-track"></span>
              </label>
              <span id="lbl-sonarr-opt" class="<%= (connections.defaultRequestService === 'direct') ? 'service-label-active' : 'service-label-inactive' %>">Sonarr/Radarr</span>
            </div>
          </div>
          <div class="conn-block-header" style="border-bottom:none;padding-top:10px;margin-top:10px;border-top:1px solid var(--border)">
            <div class="conn-block-meta">
              <span class="conn-block-name" style="font-size:0.88rem">Alternate Request App Access</span>
              <span class="conn-block-desc">Controls who can see the secondary request service (Advanced button). "Admin" hides it from regular users.</span>
            </div>
            <div class="conn-toggle-wrap" style="gap:10px;align-items:center">
              <span id="lbl-direct-all" class="<%= directRequestAccess !== 'admin' ? 'service-label-active' : 'service-label-inactive' %>">All Users</span>
              <label class="slide-toggle slide-toggle-choice">
                <input type="checkbox" id="toggle-direct-request-access"
                  <%= directRequestAccess === 'admin' ? 'checked' : '' %>
                  onchange="onDirectRequestAccessChange(this.checked)">
                <span class="slide-track"></span>
              </label>
              <span id="lbl-direct-admin" class="<%= directRequestAccess === 'admin' ? 'service-label-active' : 'service-label-inactive' %>">Admin</span>
            </div>
          </div>
        </div>

        <!-- Overseerr -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">Overseerr</span>
              <span class="conn-block-desc">Media request management</span>
            </div>
            <div class="conn-toggle-wrap">
              <span class="conn-toggle-label" id="lbl-overseerr"><%= connections.overseerrEnabled ? 'Enabled' : 'Disabled' %></span>
              <label class="slide-toggle" title="<%= (!connections.overseerrUrl || !connections.overseerrApiKey) ? 'Enter URL and API key first' : '' %>">
                <input type="checkbox" id="toggle-overseerr"
                  <%= connections.overseerrEnabled ? 'checked' : '' %>
                  <%= (!connections.overseerrUrl || !connections.overseerrApiKey) ? 'disabled' : '' %>
                  onchange="onToggleChange('overseerr')">
                <span class="slide-track"></span>
              </label>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-host">
              <span class="conn-field-label">Address</span>
              <input type="text" id="conn-overseerr-host" class="conn-input"
                placeholder="http://localhost"
                value="<%= svcHost(connections.overseerrUrl) %>"
                oninput="onFieldInput('overseerr')">
            </div>
            <div class="conn-field-group conn-field-port">
              <span class="conn-field-label">Port <span class="conn-field-optional">optional</span></span>
              <input type="number" id="conn-overseerr-port" class="conn-input conn-input-port"
                placeholder="5055" min="1" max="65535"
                value="<%= svcPort(connections.overseerrUrl) %>"
                oninput="this.value=this.value.replace(/[^0-9]/g,'');onFieldInput('overseerr')">
            </div>
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">API Key</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-overseerr-key" class="conn-input"
                  placeholder="API Key"
                  value="<%= connections.overseerrApiKey ? '••••••••' : '' %>"
                  autocomplete="new-password"
                  oninput="onFieldInput('overseerr')">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-overseerr-key', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testConnection('overseerr')">Test</button>
          </div>
        </div>

        <!-- Radarr -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">Radarr</span>
              <span class="conn-block-desc">Movies — direct fallback if Overseerr is not used</span>
            </div>
            <div class="conn-toggle-wrap">
              <span class="conn-toggle-label" id="lbl-radarr"><%= connections.radarrEnabled ? 'Enabled' : 'Disabled' %></span>
              <label class="slide-toggle" title="<%= (!connections.radarrUrl || !connections.radarrApiKey) ? 'Enter URL and API key first' : (!connections.radarrQualityProfileId ? 'Test connection and select a quality profile first' : '') %>">
                <input type="checkbox" id="toggle-radarr"
                  <%= connections.radarrEnabled ? 'checked' : '' %>
                  <%= (!connections.radarrUrl || !connections.radarrApiKey || !connections.radarrQualityProfileId) ? 'disabled' : '' %>
                  onchange="onToggleChange('radarr')">
                <span class="slide-track"></span>
              </label>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-host">
              <span class="conn-field-label">Address</span>
              <input type="text" id="conn-radarr-host" class="conn-input"
                placeholder="http://localhost"
                value="<%= svcHost(connections.radarrUrl) %>"
                oninput="onFieldInput('radarr')">
            </div>
            <div class="conn-field-group conn-field-port">
              <span class="conn-field-label">Port <span class="conn-field-optional">optional</span></span>
              <input type="number" id="conn-radarr-port" class="conn-input conn-input-port"
                placeholder="7878" min="1" max="65535"
                value="<%= svcPort(connections.radarrUrl) %>"
                oninput="this.value=this.value.replace(/[^0-9]/g,'');onFieldInput('radarr')">
            </div>
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">API Key</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-radarr-key" class="conn-input"
                  placeholder="API Key"
                  value="<%= connections.radarrApiKey ? '••••••••' : '' %>"
                  autocomplete="new-password"
                  oninput="onFieldInput('radarr')">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-radarr-key', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testConnection('radarr')">Test</button>
          </div>
          <div class="conn-quality-row" id="quality-row-radarr" style="<%= connections.radarrQualityProfileId ? 'display:block' : 'display:none' %>">
            <div class="conn-quality-header">
              <span class="conn-quality-label">Quality Profile</span>
              <span class="conn-quality-required">required to enable</span>
            </div>
            <div class="conn-quality-field">
              <select id="radarr-quality-profile" class="conn-select" onchange="onQualityProfileChange('radarr')">
                <option value="">— select a profile —</option>
                <% if (connections.radarrQualityProfileId) { %>
                  <option value="<%= connections.radarrQualityProfileId %>" selected><%= connections.radarrQualityProfileName || '(saved — re-test to reload list)' %></option>
                <% } %>
              </select>
            </div>
          </div>
        </div>

        <!-- Sonarr -->
        <div class="conn-block">
          <div class="conn-block-header">
            <div class="conn-block-meta">
              <span class="conn-block-name">Sonarr</span>
              <span class="conn-block-desc">TV Shows — direct fallback if Overseerr is not used</span>
            </div>
            <div class="conn-toggle-wrap">
              <span class="conn-toggle-label" id="lbl-sonarr"><%= connections.sonarrEnabled ? 'Enabled' : 'Disabled' %></span>
              <label class="slide-toggle" title="<%= (!connections.sonarrUrl || !connections.sonarrApiKey) ? 'Enter URL and API key first' : (!connections.sonarrQualityProfileId ? 'Test connection and select a quality profile first' : '') %>">
                <input type="checkbox" id="toggle-sonarr"
                  <%= connections.sonarrEnabled ? 'checked' : '' %>
                  <%= (!connections.sonarrUrl || !connections.sonarrApiKey || !connections.sonarrQualityProfileId) ? 'disabled' : '' %>
                  onchange="onToggleChange('sonarr')">
                <span class="slide-track"></span>
              </label>
            </div>
          </div>
          <div class="conn-block-fields">
            <div class="conn-field-group conn-field-host">
              <span class="conn-field-label">Address</span>
              <input type="text" id="conn-sonarr-host" class="conn-input"
                placeholder="http://localhost"
                value="<%= svcHost(connections.sonarrUrl) %>"
                oninput="onFieldInput('sonarr')">
            </div>
            <div class="conn-field-group conn-field-port">
              <span class="conn-field-label">Port <span class="conn-field-optional">optional</span></span>
              <input type="number" id="conn-sonarr-port" class="conn-input conn-input-port"
                placeholder="8989" min="1" max="65535"
                value="<%= svcPort(connections.sonarrUrl) %>"
                oninput="this.value=this.value.replace(/[^0-9]/g,'');onFieldInput('sonarr')">
            </div>
            <div class="conn-field-group conn-field-key">
              <span class="conn-field-label">API Key</span>
              <div class="conn-input-wrap">
                <input type="password" id="conn-sonarr-key" class="conn-input"
                  placeholder="API Key"
                  value="<%= connections.sonarrApiKey ? '••••••••' : '' %>"
                  autocomplete="new-password"
                  oninput="onFieldInput('sonarr')">
                <div class="conn-input-btns">
                  <button type="button" class="conn-input-icon-btn" onclick="toggleFieldVis('conn-sonarr-key', this)" title="Show / hide"></button>
                </div>
              </div>
            </div>
            <button class="btn-admin conn-action-btn" onclick="testConnection('sonarr')">Test</button>
          </div>
          <div class="conn-quality-row" id="quality-row-sonarr" style="<%= connections.sonarrQualityProfileId ? 'display:block' : 'display:none' %>">
            <div class="conn-quality-header">
              <span class="conn-quality-label">Quality Profile</span>
              <span class="conn-quality-required">required to enable</span>
            </div>
            <div class="conn-quality-field">
              <select id="sonarr-quality-profile" class="conn-select" onchange="onQualityProfileChange('sonarr')">
                <option value="">— select a profile —</option>
                <% if (connections.sonarrQualityProfileId) { %>
                  <option value="<%= connections.sonarrQualityProfileId %>" selected><%= connections.sonarrQualityProfileName || '(saved — re-test to reload list)' %></option>
                <% } %>
              </select>
            </div>
          </div>
        </div>

      </section>
    </div><!-- /panel-connections -->

    <!-- ══════════════════════════════════════════════════════════ -->
    <!-- NOTIFICATIONS TAB                                          -->
    <!-- ══════════════════════════════════════════════════════════ -->
    <div class="admin-tab-panel" id="panel-notifications" hidden>

      <!-- Broadcast Message -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Broadcast Message</h2>
        </div>
        <p class="section-desc" style="margin-bottom:16px">Send a custom message to all users via all configured notification channels (in-app bell, Discord, and Pushover).</p>
        <textarea id="broadcast-msg" class="conn-input" rows="3" placeholder="Type a message to send to all users..." style="resize:vertical;min-height:80px;font-family:inherit;width:100%;box-sizing:border-box"></textarea>
        <div style="display:flex;align-items:center;gap:12px;margin-top:10px">
          <button class="btn-admin btn-primary" id="broadcast-btn" onclick="broadcastNotification()">Notify All Users</button>
          <span id="broadcast-result" style="font-size:0.82rem"></span>
        </div>
      </section>

      <!-- Discord Agent -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Discord Agent <button type="button" class="agent-info-btn" onclick="openAgentInfo('discord')" title="How to configure">&#9432;</button></h2>
          <label class="slide-toggle" style="flex-shrink:0">
            <input type="checkbox" id="discord-enabled" onchange="saveDiscordAgent()">
            <span class="slide-track"></span>
          </label>
        </div>
        <p class="section-desc" style="margin-bottom:16px">Send Discord notifications via a shared channel webhook or direct messages to individual users via a bot.</p>

        <!-- Mode selector -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:20px">
          <span id="lbl-discord-webhook" class="service-label-active">Webhook</span>
          <label class="slide-toggle slide-toggle-choice">
            <input type="checkbox" id="toggle-discord-mode" onchange="setDiscordMode(this.checked ? 'bot' : 'webhook')">
            <span class="slide-track"></span>
          </label>
          <span id="lbl-discord-bot" class="service-label-inactive">Bot Token</span>
        </div>

        <!-- Webhook mode fields -->
        <div id="discord-webhook-panel" style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px">
          <div><label class="conn-label">Webhook URL</label><input type="url" id="discord-webhook" class="conn-input" placeholder="https://discord.com/api/webhooks/..."></div>
          <div><label class="conn-label">Notification Role ID <span style="color:var(--text-muted);font-weight:400">(optional, for @mentions)</span></label><input type="text" id="discord-roleid" class="conn-input" placeholder="Role ID"></div>
          <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" id="discord-mentions" class="themed-checkbox"> Enable @role mentions</label>
        </div>

        <!-- Bot token mode fields -->
        <div id="discord-bot-panel" style="display:none;flex-direction:column;gap:12px;margin-bottom:20px">
          <div><label class="conn-label">Bot Token</label><input type="password" id="discord-bottoken" class="conn-input" placeholder="Bot token from Discord Developer Portal" autocomplete="off"></div>
          <div id="discord-bot-webhook-row" style="margin-top:4px">
            <div class="toggle-row">
              <label class="slide-toggle">
                <input type="checkbox" id="discord-bot-use-webhook"
                  onchange="document.getElementById('discord-bot-webhook-field').style.display=this.checked?'block':'none'">
                <span class="slide-track"></span>
              </label>
              <span class="toggle-label" style="font-size:0.85rem">Also post admin notifications to shared channel</span>
            </div>
            <div id="discord-bot-webhook-field" style="display:none;margin-top:8px">
              <label class="conn-label">Shared Channel Webhook URL
                <span style="color:var(--text-muted);font-weight:400">(for admin announcements)</span>
              </label>
              <input type="url" id="discord-bot-webhook" class="conn-input" placeholder="https://discord.com/api/webhooks/...">
            </div>
          </div>
        </div>

        <!-- Shared fields -->
        <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px">
          <div><label class="conn-label">Bot Username <span style="color:var(--text-muted);font-weight:400">(optional)</span></label><input type="text" id="discord-botname" class="conn-input" placeholder="Diskovarr"></div>
          <!-- Bot Avatar Upload -->
          <div>
            <label class="conn-label">Bot Avatar <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
            <div style="display:flex;align-items:center;gap:12px;margin-top:4px">
              <img id="discord-avatar-preview" src="/discord-avatar.png" width="48" height="48"
                style="border-radius:50%;object-fit:cover;border:2px solid var(--border);flex-shrink:0">
              <div style="display:flex;flex-direction:column;gap:6px">
                <div style="display:flex;gap:8px;align-items:center">
                  <label for="discord-avatar-file" class="btn-admin btn-sm" style="cursor:pointer;margin:0">Choose Image</label>
                  <input type="file" id="discord-avatar-file" accept="image/png,image/jpeg,image/gif" style="display:none">
                  <button type="button" id="discord-avatar-clear" class="btn-admin btn-sm btn-danger" style="display:none">Remove</button>
                </div>
                <span style="font-size:0.75rem;color:var(--text-muted)">PNG/JPG/GIF · 128×128 recommended · max 2 MB · leave blank for auto-generated logo</span>
              </div>
            </div>
            <div style="margin-top:8px">
              <label class="conn-label" style="font-size:0.78rem;color:var(--text-muted)">Or use a URL instead</label>
              <input type="text" id="discord-avatar-url" class="conn-input" placeholder="https://example.com/avatar.png" style="margin-top:2px">
            </div>
          </div>
          <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" id="discord-poster" class="themed-checkbox" checked> Embed poster image in notifications</label>
        </div>

        <div style="margin-bottom:16px">
          <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-secondary);margin:0 0 10px">Notification Types</p>
          <div style="display:flex;flex-direction:column;gap:8px">
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_pending" checked> New request pending <span style="color:var(--text-muted);font-size:0.78rem">(admin)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_auto_approved" checked> Request auto-approved <span style="color:var(--text-muted);font-size:0.78rem">(admin)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_approved" checked> Request approved <span style="color:var(--text-muted);font-size:0.78rem">(requester)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_denied" checked> Request denied <span style="color:var(--text-muted);font-size:0.78rem">(requester)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_available"> Request available in library <span style="color:var(--text-muted);font-size:0.78rem">(requester)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="request_process_failed"> Request processing error <span style="color:var(--text-muted);font-size:0.78rem">(admin)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="issue_new" checked> New issue reported <span style="color:var(--text-muted);font-size:0.78rem">(admin)</span></label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox discord-type" value="issue_updated" checked> Issue status updated <span style="color:var(--text-muted);font-size:0.78rem">(requester)</span></label>
          </div>
        </div>

        <!-- Test section -->
        <div id="discord-test-webhook-row" style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn-admin btn-primary" onclick="saveDiscordAgent()">Save</button>
          <button class="btn-admin" onclick="testDiscord()">Send Test</button>
        </div>
        <div id="discord-test-bot-row" style="display:none;gap:10px;flex-wrap:wrap;align-items:flex-end">
          <div>
            <label class="conn-label" style="margin-bottom:4px">Your Discord User ID <span style="color:var(--text-muted);font-weight:400">(to receive test DM)</span></label>
            <input type="text" id="discord-test-userid" class="conn-input" style="max-width:240px" placeholder="Discord user ID">
          </div>
          <div style="display:flex;gap:10px">
            <button class="btn-admin btn-primary" onclick="saveDiscordAgent()">Save</button>
            <button class="btn-admin" onclick="testDiscord()">Send Test DM</button>
          </div>
        </div>

        <!-- Invite link (shown to users in settings) -->
        <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--border)">
          <label class="conn-label">Discord Server Invite Link <span style="color:var(--text-muted);font-weight:400">(optional — shown to users in their settings)</span></label>
          <input type="url" id="discord-invite-link" class="conn-input" placeholder="https://discord.gg/...">
          <p style="font-size:0.78rem;color:var(--text-secondary);margin-top:6px">Use a non-expiring invite so users can join the server to receive bot DMs.</p>
        </div>
      </section>

      <!-- Pushover Agent -->
      <section class="admin-section">
        <div class="admin-section-header">
          <h2 class="section-title">Pushover Agent <button type="button" class="agent-info-btn" onclick="openAgentInfo('pushover')" title="How to configure">&#9432;</button></h2>
          <label class="slide-toggle" style="flex-shrink:0">
            <input type="checkbox" id="pushover-enabled" onchange="savePushoverAgent()">
            <span class="slide-track"></span>
          </label>
        </div>
        <p class="section-desc" style="margin-bottom:20px">Send push notifications via Pushover to your devices.</p>
        <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:20px">
          <div><label class="conn-label">Application API Token</label><input type="text" id="pushover-token" class="conn-input" placeholder="App token from pushover.net"></div>
          <div><label class="conn-label">User or Group Key</label><input type="text" id="pushover-userkey" class="conn-input" placeholder="User/group key"></div>
        </div>
        <div style="margin-bottom:16px">
          <p style="font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text-secondary);margin:0 0 10px">Notification Types</p>
          <div style="display:flex;flex-direction:column;gap:8px">
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="request_pending" checked> New request pending</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="request_approved" checked> Request approved</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="request_denied" checked> Request denied</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="request_available" checked> Request available in library</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="request_process_failed"> Request processing error</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="issue_new" checked> New issue reported</label>
            <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem"><input type="checkbox" class="themed-checkbox pushover-type" value="issue_updated" checked> Issue status updated</label>
          </div>
        </div>
        <div style="display:flex;gap:10px">
          <button class="btn-admin btn-primary" onclick="savePushoverAgent()">Save</button>
          <button class="btn-admin" onclick="testPushover()">Send Test</button>
        </div>
      </section>

    </div><!-- /panel-notifications -->

    <!-- ── Discord info modal ───────────────────────────────────── -->
    <div id="agent-info-discord" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,0.75);align-items:center;justify-content:center" onclick="if(event.target===this)closeAgentInfo('discord')">
      <div style="background:var(--bg-secondary);border-radius:14px;padding:28px;width:min(560px,92vw);border:1px solid var(--border);position:relative;max-height:88vh;overflow-y:auto">
        <button onclick="closeAgentInfo('discord')" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer;line-height:1" title="Close">&times;</button>
        <h3 style="margin:0 0 16px;font-size:1.05rem">Configuring Discord Notifications</h3>
        <div style="font-size:0.88rem;line-height:1.7;color:var(--text-secondary);display:flex;flex-direction:column;gap:14px">
          <div style="background:var(--bg-elevated);border-radius:8px;padding:12px">
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Mode: Webhook (shared channel)</p>
            <p style="margin:0 0 6px">All notifications go to a single Discord channel. Users can optionally add their own personal webhook for private-channel delivery.</p>
            <p style="font-weight:500;color:var(--text-primary);margin:0 0 2px">Setup:</p>
            <p style="margin:0">In your Discord server → <strong>Server Settings → Integrations → Webhooks</strong> → <em>New Webhook</em> → pick a channel → copy the URL. Paste it in the Webhook URL field above.</p>
          </div>
          <div style="background:var(--bg-elevated);border-radius:8px;padding:12px">
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Mode: Bot Token (individual DMs)</p>
            <p style="margin:0 0 6px">The bot sends each user a personal DM. Each user enters their Discord User ID in their profile settings.</p>
            <p style="font-weight:500;color:var(--text-primary);margin:0 0 2px">Setup:</p>
            <ol style="margin:0;padding-left:18px">
              <li>Go to <strong>discord.com/developers/applications</strong> → <em>New Application</em></li>
              <li>Open the <strong>Bot</strong> tab → <em>Add Bot</em> → copy the <strong>Token</strong></li>
              <li>Enable <strong>Message Content Intent</strong> on the Bot tab</li>
              <li>Invite the bot to your server: OAuth2 → URL Generator → scope: <code style="font-size:0.78rem;background:var(--bg-secondary);padding:1px 4px;border-radius:3px">bot</code>, permission: <em>Send Messages</em></li>
              <li>Each user finds their Discord User ID (Developer Mode → right-click profile → Copy User ID) and enters it in their Diskovarr settings</li>
            </ol>
            <p style="margin:8px 0 0"><strong>Admin channel toggle</strong> — enable "Also post admin notifications to shared channel" to mirror admin-type alerts (pending requests, errors) to a shared Discord channel webhook alongside the bot DMs.</p>
            <p style="margin:6px 0 0"><strong>Server Invite Link</strong> — set a non-expiring Discord invite link; users will see a "Join Server" prompt in their settings page so they can join your server before the bot can DM them.</p>
            <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;padding:10px 12px;margin-top:10px">
              <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Finding your Discord User ID (to test DMs)</p>
              <p style="margin:0 0 6px">The User ID is a <strong>17–19 digit number</strong> — not your username (e.g. <code style="font-size:0.78rem;background:var(--bg-secondary);padding:1px 4px;border-radius:3px">185234567891234560</code>).</p>
              <ol style="margin:0;padding-left:18px">
                <li>In Discord, open <strong>Settings → Advanced</strong> and enable <strong>Developer Mode</strong></li>
                <li>Find any message you've sent, then <strong>right-click your avatar or username</strong> on that message</li>
                <li>Click <strong>Copy User ID</strong> from the context menu</li>
                <li>Paste the numeric ID into your Diskovarr <strong>Notification Settings</strong> page and save</li>
              </ol>
              <p style="margin:6px 0 0;color:var(--text-secondary)"><strong>Note:</strong> The bot must be in a Discord server that you are also a member of — it cannot DM users with no mutual server.</p>
              <div style="background:var(--bg-secondary);border:1px solid var(--border);border-radius:6px;padding:10px 12px;margin-top:8px">
                <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Inviting the bot to your server</p>
                <ol style="margin:0;padding-left:18px">
                  <li>Go to <strong>discord.com/developers/applications</strong> → select your app</li>
                  <li>Open <strong>OAuth2 → URL Generator</strong></li>
                  <li>Under <strong>Scopes</strong> check <code style="font-size:0.78rem;background:var(--bg-elevated);padding:1px 4px;border-radius:3px">bot</code></li>
                  <li>Under <strong>Bot Permissions</strong> check <em>Send Messages</em></li>
                  <li>Copy the generated URL, open it in your browser, and add the bot to your server</li>
                </ol>
              </div>
            </div>
          </div>
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Bot avatar</p>
            <p style="margin:0">Leave the Avatar URL blank and Diskovarr will automatically set the bot's avatar to the Diskovarr logo in your server's accent colour. Or supply a custom image URL to override it. The <strong>App Public URL</strong> (set in General Settings) must be configured for the auto-generated avatar endpoint to work.</p>
          </div>
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Notification types</p>
            <p style="margin:0"><strong>New request pending / Auto-approved</strong> — admin alerts for incoming requests. <strong>Approved / Denied</strong> — notify the requester when an admin acts. <strong>Available</strong> — notify when content appears in Plex. <strong>Request processing error</strong> — admin alert when a request fails to submit to Radarr/Sonarr/Overseerr.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Pushover info modal ───────────────────────────────────── -->
    <div id="agent-info-pushover" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,0.75);align-items:center;justify-content:center" onclick="if(event.target===this)closeAgentInfo('pushover')">
      <div style="background:var(--bg-secondary);border-radius:14px;padding:28px;width:min(500px,92vw);border:1px solid var(--border);position:relative;max-height:88vh;overflow-y:auto">
        <button onclick="closeAgentInfo('pushover')" style="position:absolute;top:14px;right:16px;background:none;border:none;color:var(--text-secondary);font-size:1.3rem;cursor:pointer;line-height:1" title="Close">&times;</button>
        <h3 style="margin:0 0 16px;font-size:1.05rem">Configuring Pushover Notifications</h3>
        <div style="font-size:0.88rem;line-height:1.7;color:var(--text-secondary);display:flex;flex-direction:column;gap:12px">
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">1. Create a Pushover application</p>
            <p style="margin:0">Log in at <strong>pushover.net</strong>, go to <em>Your Applications</em> → <em>Create an Application/API Token</em>. Name it (e.g. "Diskovarr") and copy the <strong>API Token</strong>.</p>
          </div>
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">2. Find your User Key</p>
            <p style="margin:0">Your <strong>User Key</strong> is shown on your Pushover dashboard homepage. Use a <strong>Group Key</strong> instead to deliver to multiple users at once.</p>
          </div>
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">3. Install the Pushover app</p>
            <p style="margin:0">Install Pushover on your iOS or Android device and log in. Notifications will be pushed there in real time.</p>
          </div>
          <div>
            <p style="font-weight:600;color:var(--text-primary);margin:0 0 4px">Notification types</p>
            <p style="margin:0"><strong>New request pending</strong> — admin alert for incoming requests. <strong>Request approved/denied</strong> — notifies the requester when an admin acts.</p>
          </div>
          <div>
            <p style="margin:0">Per-user Pushover keys (for individual delivery) can be set from each user's settings page.</p>
          </div>
        </div>
      </div>
    </div>

  </main>

  <script>
    // ── Relative time helper ───────────────────────────────────────
    function fmtTime(unixTs) {
      if (!unixTs) return 'Never';
      const diff = Math.floor(Date.now() / 1000) - unixTs;
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return Math.floor(diff / 86400) + 'd ago';
    }

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast ' + (isError ? 'toast-error' : 'toast-success');
      t.style.display = 'block';
      clearTimeout(t._timer);
      t._timer = setTimeout(() => { t.style.display = 'none'; }, 4000);
    }

    function confirmAction(msg, fn) {
      if (confirm(msg)) fn();
    }

    async function apiFetch(url, method) {
      const res = await fetch(url, { method: method || 'POST' });
      return res.json();
    }

