    async function broadcastNotification() {
      const msg = document.getElementById('broadcast-msg').value.trim();
      if (!msg) return;
      const btn = document.getElementById('broadcast-btn');
      const result = document.getElementById('broadcast-result');
      btn.disabled = true;
      result.textContent = '';
      try {
        const r = await fetch('/admin/notifications/broadcast', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ message: msg }),
        });
        const data = await r.json();
        if (data.success) {
          result.textContent = `Sent to ${data.userCount} user${data.userCount !== 1 ? 's' : ''}`;
          result.style.color = 'var(--accent)';
          document.getElementById('broadcast-msg').value = '';
        } else {
          result.textContent = data.error || 'Failed to send';
          result.style.color = '#ff5252';
        }
      } catch (err) {
        result.textContent = 'Error: ' + err.message;
        result.style.color = '#ff5252';
      } finally {
        btn.disabled = false;
      }
    }

    async function saveDiscordAgent() {
      if (document.getElementById('discord-enabled').checked && _discordMode === 'bot') {
        var publicUrl = (document.getElementById('app-public-url') || {}).value || '';
        if (!publicUrl.trim()) {
          document.getElementById('discord-enabled').checked = false;
          showToast('Set the App Public URL in General Settings before enabling bot mode', true);
          return;
        }
      }
      // Upload/clear avatar first if changed
      if (_discordAvatarDataUri || _discordAvatarClear) {
        try {
          var avatarBody = _discordAvatarClear ? { clear: true } : { imageDataUri: _discordAvatarDataUri };
          var ar = await fetch('/admin/settings/discord-avatar', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(avatarBody) });
          var ad = await ar.json();
          if (!ad.success) { showToast('Avatar upload failed: ' + (ad.error || 'unknown'), true); return; }
          _discordAvatarDataUri = null;
          _discordAvatarClear   = false;
        } catch(e) { showToast('Avatar upload error: ' + e.message, true); return; }
      }
      var types = Array.from(document.querySelectorAll('.discord-type:checked')).map(function(el){return el.value;});
      fetch('/admin/settings/discord', {
        method: 'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
          enabled:            document.getElementById('discord-enabled').checked,
          mode:               _discordMode,
          webhookUrl:         document.getElementById('discord-webhook').value,
          botToken:           document.getElementById('discord-bottoken').value,
          botUsername:        document.getElementById('discord-botname').value,
          notificationRoleId: document.getElementById('discord-roleid').value,
          enableMentions:     document.getElementById('discord-mentions').checked,
          embedPoster:        document.getElementById('discord-poster').checked,
          notificationTypes:  types,
          inviteLink:         document.getElementById('discord-invite-link').value,
          botWebhookUrl:      document.getElementById('discord-bot-webhook').value,
          botUseWebhook:      document.getElementById('discord-bot-use-webhook').checked,
          botAvatarUrl:       document.getElementById('discord-avatar-url').value,
        }),
      }).then(r=>r.json()).then(d=>{ if(d.success) showToast('Discord settings saved'); else showToast('Save failed',true); }).catch(()=>showToast('Save failed',true));
    }

    async function testDiscord() {
      var mode = _discordMode;
      try {
        var body = { mode, botUsername: document.getElementById('discord-botname').value };
        if (mode === 'bot') {
          body.botToken = document.getElementById('discord-bottoken').value;
          body.discordUserId = document.getElementById('discord-test-userid').value;
          if (!body.botToken) return showToast('Enter bot token first', true);
          if (!body.discordUserId) return showToast('Enter your Discord User ID for the test DM', true);
        } else {
          body.webhookUrl = document.getElementById('discord-webhook').value;
          if (!body.webhookUrl) return showToast('Enter webhook URL first', true);
        }
        var r = await fetch('/admin/settings/discord/test', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
        var d = await r.json();
        showToast(d.message || (d.ok ? 'Sent!' : 'Failed'), !d.ok);
      } catch(e) { showToast('Error: '+e.message, true); }
    }

    function savePushoverAgent() {
      var types = Array.from(document.querySelectorAll('.pushover-type:checked')).map(function(el){return el.value;});
      fetch('/admin/settings/pushover', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({
          enabled: document.getElementById('pushover-enabled').checked,
          appToken: document.getElementById('pushover-token').value,
          userKey: document.getElementById('pushover-userkey').value,
          notificationTypes: types,
        }),
      }).then(r=>r.json()).then(d=>{ if(d.success) showToast('Pushover settings saved'); }).catch(()=>showToast('Save failed',true));
    }

    async function testPushover() {
      var token = document.getElementById('pushover-token').value;
      var key = document.getElementById('pushover-userkey').value;
      if (!token || !key) return showToast('Enter app token and user key first', true);
      try {
        var r = await fetch('/admin/settings/pushover/test', {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({appToken:token,userKey:key})});
        var d = await r.json();
        showToast(d.message || (d.ok ? 'Sent!' : 'Failed'), !d.ok);
      } catch(e) { showToast('Error: '+e.message, true); }
    }

    // Load agent configs
    (function loadAgentConfigs() {
      fetch('/admin/status').then(r=>r.json()).then(d=>{
        if (d.discordAgent) {
          var c = d.discordAgent;
          document.getElementById('discord-enabled').checked = !!c.enabled;
          setDiscordMode(c.mode === 'bot' ? 'bot' : 'webhook');
          if (c.webhookUrl) document.getElementById('discord-webhook').value = c.webhookUrl;
          if (c.botToken) document.getElementById('discord-bottoken').value = c.botToken;
          if (c.botUsername) document.getElementById('discord-botname').value = c.botUsername;
          if (c.notificationRoleId) document.getElementById('discord-roleid').value = c.notificationRoleId;
          if (c.enableMentions) document.getElementById('discord-mentions').checked = true;
          // embedPoster defaults to true for configs saved before this field was added
          document.getElementById('discord-poster').checked = c.embedPoster !== false;
          if (c.notificationTypes) {
            document.querySelectorAll('.discord-type').forEach(function(el){
              el.checked = c.notificationTypes.includes(el.value);
            });
            // issue_new and issue_updated default to enabled for configs created before these types existed
            ['issue_new', 'issue_updated'].forEach(function(v) {
              if (!c.notificationTypes.includes(v)) {
                var el = document.querySelector('.discord-type[value="' + v + '"]');
                if (el) el.checked = true;
              }
            });
          }
          if (c.inviteLink) document.getElementById('discord-invite-link').value = c.inviteLink;
          if (c.botUseWebhook) {
            document.getElementById('discord-bot-use-webhook').checked = true;
            document.getElementById('discord-bot-webhook-field').style.display = 'block';
          }
          if (c.botWebhookUrl) document.getElementById('discord-bot-webhook').value = c.botWebhookUrl;
          if (c.botAvatarUrl) document.getElementById('discord-avatar-url').value = c.botAvatarUrl;
        }
        if (d.pushoverAgent) {
          var p = d.pushoverAgent;
          document.getElementById('pushover-enabled').checked = !!p.enabled;
          if (p.appToken) document.getElementById('pushover-token').value = p.appToken;
          if (p.userKey) document.getElementById('pushover-userkey').value = p.userKey;
          if (p.notificationTypes) {
            document.querySelectorAll('.pushover-type').forEach(function(el){
              el.checked = p.notificationTypes.includes(el.value);
            });
            // issue_new, issue_updated, request_available default to enabled for pre-existing configs
            ['issue_new', 'issue_updated', 'request_available'].forEach(function(v) {
              if (!p.notificationTypes.includes(v)) {
                var el = document.querySelector('.pushover-type[value="' + v + '"]');
                if (el) el.checked = true;
              }
            });
          }
        }
      }).catch(function(){});
    })();

    async function clearUserRequests(userId) {
      if (!confirm('Delete all requests for this user?')) return;
      const d = await apiFetch('/admin/users/' + userId + '/requests', 'DELETE');
      if (d?.success) showToast('Requests cleared');
    }

    // ── Connections ────────────────────────────────────────────────

    function combineUrl(host, port) {
      if (!host) return '';
      if (!port) return host;
      try { const u = new URL(host); u.port = port; return u.origin; }
      catch(e) { return host.replace(/:\d+$/, '') + ':' + port; }
    }
    function getUrlValue(service) {
      const hostEl = document.getElementById('conn-' + service + '-host');
      const portEl = document.getElementById('conn-' + service + '-port');
      if (!hostEl) return '';
      return combineUrl(hostEl.value.trim(), portEl ? portEl.value.trim() : '');
    }

    // Track which services have passed a connection test this session
    var _tested = {
      radarr: <%= connections.radarrQualityProfileId ? 'true' : 'false' %>,
      sonarr: <%= connections.sonarrQualityProfileId ? 'true' : 'false' %>,
    };

    // Check if a service has required fields filled (and passed test for radarr/sonarr)
    function serviceReady(service) {
      if (service === 'discover') {
        return document.getElementById('conn-tmdb-key').value.trim() !== '';
      }
      const urlVal = getUrlValue(service);
      const key = document.getElementById('conn-' + service + '-key');
      if (!urlVal || !key || !key.value.trim()) return false;
      if (service === 'radarr' || service === 'sonarr') {
        const profile = document.getElementById(service + '-quality-profile');
        return _tested[service] && profile && profile.value !== '';
      }
      return true;
    }

    function getToggleHint(service) {
      if (service === 'discover') return 'Enter TMDB API key first';
      if (service === 'radarr' || service === 'sonarr') {
        const urlVal = getUrlValue(service);
        const key = document.getElementById('conn-' + service + '-key');
        if (!urlVal || !key || !key.value.trim()) return 'Enter URL and API key first';
        if (!_tested[service]) return 'Test the connection first';
        const profile = document.getElementById(service + '-quality-profile');
        if (!profile || !profile.value) return 'Select a quality profile first';
        return '';
      }
      return 'Enter URL and API key first';
    }

    // Just re-evaluates toggle disabled/title without touching test state
    function updateToggleState(service) {
      var toggle = document.getElementById('toggle-' + service);
      if (!toggle) return;
      var ready = serviceReady(service);
      toggle.disabled = !ready;
      toggle.closest('.slide-toggle').title = ready ? '' : getToggleHint(service);
    }

    // Called when URL/key fields change — resets test state then updates toggle
    function onFieldInput(service) {
      if ((service === 'radarr' || service === 'sonarr') && _tested[service] !== undefined) {
        _tested[service] = false;
        var qRow = document.getElementById('quality-row-' + service);
        if (qRow) qRow.style.display = 'none';
      }
      updateToggleState(service);
    }

    // Save TMDB key separately, then re-evaluate discover toggle
    async function saveTmdbKey() {
      var k = document.getElementById('conn-tmdb-key').value;
      if (!k || k === '••••••••') { showToast('No change — key unchanged'); return; }
      var d = await fetch('/admin/connections/save', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tmdb_api_key: k }),
      }).then(r => r.json());
      if (d.success) {
        showToast('TMDB API key saved');
        // Key is now saved — enable the discover toggle
        var discoverToggle = document.getElementById('toggle-discover');
        if (discoverToggle) discoverToggle.disabled = false;
        discoverToggle.closest('.slide-toggle').title = '';
      } else {
        showToast('Save failed', true);
      }
    }

    // Called when a toggle changes — auto-saves settings
    async function onToggleChange(service) {
      var toggle = document.getElementById('toggle-' + service);
      var checked = toggle.checked;
      var body = {};

      if (service === 'discover') {
        body.discover_enabled = checked ? '1' : '0';
      } else {
        var urlVal = getUrlValue(service);
        var keyVal = document.getElementById('conn-' + service + '-key').value;
        body[service + '_url'] = urlVal;
        if (keyVal !== '••••••••') body[service + '_api_key'] = keyVal;
        body[service + '_enabled'] = checked ? '1' : '0';
      }

      var d = await fetch('/admin/connections/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(r => r.json());

      if (d.success) {
        var name = service === 'discover' ? 'Diskovarr Requests' : service.charAt(0).toUpperCase() + service.slice(1);
        var lbl = document.getElementById('lbl-' + service);
        if (lbl) lbl.textContent = checked ? 'Enabled' : 'Disabled';
        showToast(name + (checked ? ' enabled' : ' disabled'));
        // Show/hide default service block when relevant toggles change
        if (['overseerr', 'radarr', 'sonarr'].includes(service)) refreshDefaultServiceBlock();
      } else {
        // Revert toggle
        toggle.checked = !checked;
        showToast('Save failed', true);
      }
    }

    function refreshDefaultServiceBlock() {
      var osOn  = document.getElementById('toggle-overseerr')?.checked && getUrlValue('overseerr');
      var rrOn  = document.getElementById('toggle-radarr')?.checked   && getUrlValue('radarr');
      var snOn  = document.getElementById('toggle-sonarr')?.checked   && getUrlValue('sonarr');
      var block = document.getElementById('default-service-block');
      if (block) block.style.display = (osOn && (rrOn || snOn)) ? '' : 'none';
    }

    // ── Password field eye / copy ───────────────────────────────────
    var EYE_ICON = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>';
    var EYE_OFF_ICON = '<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>';
    var COPY_ICON = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';

    var FIELD_KEY_MAP = {
      'conn-plex-token':    'plexToken',
      'conn-tautulli-key':  'tautulliApiKey',
      'conn-tmdb-key':      'tmdbApiKey',
      'conn-overseerr-key': 'overseerrApiKey',
      'conn-radarr-key':    'radarrApiKey',
      'conn-sonarr-key':    'sonarrApiKey',
      'settings-api-key':   'diskovarrApiKey',
    };
    var _revealedKeys = null;

    async function getRevealedKeys() {
      if (_revealedKeys) return _revealedKeys;
      _revealedKeys = await fetch('/admin/connections/reveal').then(r => r.json());
      return _revealedKeys;
    }

    // Resolve masked placeholder to real key if needed
    async function resolveFieldValue(id) {
      var input = document.getElementById(id);
      if (input.value !== '••••••••') return input.value;
      var keys = await getRevealedKeys();
      var real = keys[FIELD_KEY_MAP[id]] || '';
      if (real) input.value = real;
      return input.value;
    }

    // Initialise all eye buttons with the default icon
    document.querySelectorAll('.conn-input-btns').forEach(function (btns) {
      btns.children[0].innerHTML = EYE_ICON;
    });

    // Auto-load quality profiles on page load for already-configured services
    <% if (connections.radarrQualityProfileId) { %>loadQualityProfiles('radarr');<% } %>
    <% if (connections.sonarrQualityProfileId) { %>loadQualityProfiles('sonarr');<% } %>

    async function toggleFieldVis(id, btn) {
      var input = document.getElementById(id);
      var willShow = input.type === 'password';
      if (willShow) await resolveFieldValue(id);
      input.type = willShow ? 'text' : 'password';
      btn.innerHTML = willShow ? EYE_OFF_ICON : EYE_ICON;
      btn.title = willShow ? 'Hide' : 'Show / hide';
    }

    async function generateApiKey() {
      if (!confirm('Generate a new API key? Any existing key will stop working immediately.')) return;
      var res = await fetch('/admin/settings/generate-api-key', { method: 'POST' });
      var data = await res.json();
      if (data.success) {
        _revealedKeys = null;
        location.reload();
      }
    }

    async function copyApiKey() {
      var input = document.getElementById('settings-api-key');
      if (input.value === '••••••••') {
        await resolveFieldValue('settings-api-key');
      }
      try {
        await navigator.clipboard.writeText(input.value);
        var btn = document.getElementById('api-key-copy-btn');
        var orig = btn.innerHTML;
        btn.innerHTML = '✓';
        setTimeout(function() { btn.innerHTML = orig; }, 1500);
      } catch(e) {
        alert('Copy failed — reveal the key first and copy manually.');
      }
    }

    document.addEventListener('DOMContentLoaded', function() {
      var copyBtn = document.getElementById('api-key-copy-btn');
      if (copyBtn) copyBtn.innerHTML = COPY_ICON;
      var eyeBtn = document.getElementById('api-key-eye-btn');
      if (eyeBtn) eyeBtn.innerHTML = EYE_ICON;
    });

    // Save Plex or Tautulli (no toggle — always required)
    async function saveCoreService(service) {
      var body = {};
      if (service === 'plex') {
        var url = getUrlValue('plex');
        var token = document.getElementById('conn-plex-token').value;
        if (url) body.plex_url = url;
        if (token && token !== '••••••••') body.plex_token = token;
      } else if (service === 'tautulli') {
        var url = getUrlValue('tautulli');
        var key = document.getElementById('conn-tautulli-key').value;
        if (url) body.tautulli_url = url;
        if (key && key !== '••••••••') body.tautulli_api_key = key;
      }
      if (!Object.keys(body).length) { showToast('No changes to save', true); return; }
      var d = await fetch('/admin/connections/save', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(r => r.json());
      if (d.success) {
        _revealedKeys = null; // invalidate reveal cache
        showToast((service === 'plex' ? 'Plex' : 'Tautulli') + ' settings saved');
      } else {
        showToast('Save failed', true);
      }
    }

    async function testCoreService(service) {
      var payload = {};
      if (service === 'plex') {
        payload.url = getUrlValue('plex');
        payload.token = await resolveFieldValue('conn-plex-token');
        if (!payload.url || !payload.token) { showToast('Enter URL and token first', true); return; }
      } else if (service === 'tautulli') {
        payload.url = getUrlValue('tautulli');
        payload.apiKey = await resolveFieldValue('conn-tautulli-key');
        if (!payload.url || !payload.apiKey) { showToast('Enter URL and API key first', true); return; }
      }
      var d = await fetch('/admin/connections/test/' + service, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(r => r.json());
      showToast(d.message, !d.ok);
    }

    async function testConnection(service) {
      var payload = {};
      if (service === 'tmdb') {
        payload.apiKey = document.getElementById('conn-tmdb-key').value;
        if (payload.apiKey === '••••••••') { showToast('Enter the actual key to test it', true); return; }
      } else {
        payload.url = getUrlValue(service);
        payload.apiKey = document.getElementById('conn-' + service + '-key').value;
        if (payload.apiKey === '••••••••') {
          payload.apiKey = '<%= connections.overseerrApiKey %>';
          if (service === 'radarr') payload.apiKey = '<%= connections.radarrApiKey %>';
          if (service === 'sonarr') payload.apiKey = '<%= connections.sonarrApiKey %>';
        }
      }
      var d = await fetch('/admin/connections/test/' + service, {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      }).then(r => r.json());
      showToast(d.message, !d.ok);

      // On success for radarr/sonarr: save URL+key to DB, then load quality profiles
      if (d.ok && (service === 'radarr' || service === 'sonarr')) {
        _tested[service] = true;
        var saveBody = {};
        saveBody[service + '_url'] = payload.url;
        if (payload.apiKey) saveBody[service + '_api_key'] = payload.apiKey;
        await fetch('/admin/connections/save', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(saveBody),
        });
        _revealedKeys = null;
        var qRow = document.getElementById('quality-row-' + service);
        if (qRow) qRow.style.display = 'block';
        await loadQualityProfiles(service);
      }
    }

    // ── Default request service toggle ──────────────────────────
    async function onDefaultServiceChange(isDirect) {
      var value = isDirect ? 'direct' : 'overseerr';
      var desc = document.getElementById('default-service-desc');
      desc.textContent = isDirect ? 'Sonarr/Radarr is the default' : 'Overseerr is the default';
      var lblOs = document.getElementById('lbl-overseerr-opt');
      var lblSn = document.getElementById('lbl-sonarr-opt');
      if (lblOs) lblOs.className = isDirect ? 'service-label-inactive' : 'service-label-active';
      if (lblSn) lblSn.className = isDirect ? 'service-label-active' : 'service-label-inactive';
      var d = await fetch('/admin/connections/save', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ default_request_service: value }),
      }).then(r => r.json());
      if (d.success) showToast('Default request service saved');
      else showToast('Save failed', true);
    }

    // ── Advanced settings panels ────────────────────────────────
    function toggleAdvanced(service) {
      var panel = document.getElementById('adv-panel-' + service);
      var arrow = document.getElementById('adv-arrow-' + service);
      var open = panel.classList.toggle('open');
      arrow.textContent = open ? '▼' : '▶';
      if (open) loadQualityProfiles(service);
    }

    async function loadQualityProfiles(service) {
      var select = document.getElementById(service + '-quality-profile');
      if (!select) return;
      select.disabled = true;
      select.innerHTML = '<option value="">Loading…</option>';
      var d = await fetch('/admin/connections/quality-profiles/' + service).then(r => r.json());
      if (!d.ok) {
        select.innerHTML = '<option value="">' + (d.message || 'Failed to load') + '</option>';
        select.disabled = false;
        return;
      }
      var savedId = '<%= connections.radarrQualityProfileId %>';
      if (service === 'sonarr') savedId = '<%= connections.sonarrQualityProfileId %>';
      select.innerHTML = '<option value="">— select a profile —</option>' +
        d.profiles.map(function(p) {
          var sel = String(p.id) === String(savedId) ? ' selected' : '';
          return '<option value="' + p.id + '"' + sel + '>' + p.name + '</option>';
        }).join('');
      select.disabled = false;
      updateToggleState(service);
    }

    async function onQualityProfileChange(service) {
      var select = document.getElementById(service + '-quality-profile');
      var profileId = select.value;
      if (!profileId) { updateToggleState(service); return; }
      var body = {};
      body[service + '_quality_profile_id'] = profileId;
      body[service + '_quality_profile_name'] = select.options[select.selectedIndex].text;
      var d = await fetch('/admin/connections/save', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(r => r.json());
      if (d.success) showToast('Quality profile saved');
      updateToggleState(service);
    }

    async function saveQualityProfile(service) {
      var select = document.getElementById(service + '-quality-profile');
      var profileId = select.value;
      var body = {};
      body[service + '_quality_profile_id'] = profileId;
      var d = await fetch('/admin/connections/save', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      }).then(r => r.json());
      if (d.success) {
        showToast((service === 'radarr' ? 'Radarr' : 'Sonarr') + ' quality profile saved');
      } else {
        showToast('Save failed', true);
      }
    }

  </script>
  <script>
    (function () {
      var accent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#e5a00d';
      var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="-3 -3 30 30">'
        + '<rect x="-3" y="-3" width="30" height="30" rx="5" fill="#0f0f0f"/>'
        + '<rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="' + accent + '"/>'
        + '<rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="' + accent + '"/>'
        + '<rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="' + accent + '"/>'
        + '<rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="' + accent + '"/>'
        + '<circle cx="15" cy="9" r="5" fill="none" stroke="' + accent + '" stroke-width="2"/>'
        + '<line x1="18.5" y1="12.5" x2="22" y2="16" stroke="' + accent + '" stroke-width="2.5" stroke-linecap="round"/>'
        + '</svg>';
      var blob = new Blob([svg], { type: 'image/svg+xml' });
      var url = URL.createObjectURL(blob);
      var link = document.querySelector('link[rel*="icon"]');
      if (link) link.href = url;
      var m = document.getElementById('meta-theme-color'); if (m) m.content = accent;
      if ('serviceWorker' in navigator) navigator.serviceWorker.register('/sw.js').catch(function(){});
    })();
  </script>
</body>
</html>

<%# Server-side helper -%>
<% function relativeTime(unixTs) {
  if (!unixTs) return 'Never';
  const diff = Math.floor(Date.now() / 1000) - unixTs;
  if (diff < 60) return 'just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  return Math.floor(diff / 86400) + 'd ago';
} %>
