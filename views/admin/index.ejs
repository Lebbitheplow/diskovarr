    var _discordAvatarClear   = false;  // user clicked Remove

    document.getElementById('discord-avatar-file').addEventListener('change', function() {
      var file = this.files[0];
      if (!file) return;
      if (file.size > 2 * 1024 * 1024) { showToast('Image exceeds 2 MB limit', true); this.value = ''; return; }
      var reader = new FileReader();
      reader.onload = function(e) {
        _discordAvatarDataUri = e.target.result;
        _discordAvatarClear   = false;
        document.getElementById('discord-avatar-preview').src = _discordAvatarDataUri;
        document.getElementById('discord-avatar-clear').style.display = 'inline-flex';
      };
      reader.readAsDataURL(file);
    });

    document.getElementById('discord-avatar-clear').addEventListener('click', function() {
      _discordAvatarDataUri = null;
      _discordAvatarClear   = true;
      document.getElementById('discord-avatar-preview').src = '/discord-avatar.png?bust=' + Date.now();
      document.getElementById('discord-avatar-file').value = '';
      this.style.display = 'none';
