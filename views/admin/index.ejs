  </main>

  <script>
    // ── Relative time helper ───────────────────────────────────────
    function fmtTime(unixTs) {
      if (!unixTs) return 'Never';
      const diff = Math.floor(Date.now() / 1000) - unixTs;
      if (diff < 60) return 'just now';
      if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
      if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
      return Math.floor(diff / 86400) + 'd ago';
    }

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.className = 'toast ' + (isError ? 'toast-error' : 'toast-success');
      t.style.display = 'block';
      clearTimeout(t._timer);
      t._timer = setTimeout(() => { t.style.display = 'none'; }, 4000);
    }

    function confirmAction(msg, fn) {
      if (confirm(msg)) fn();
    }

    async function apiFetch(url, method) {
      const res = await fetch(url, { method: method || 'POST' });
      return res.json();
    }

    // ── Tabs ───────────────────────────────────────────────────────
    document.querySelectorAll('.admin-tab').forEach(function (tab) {
      tab.addEventListener('click', function () {
        document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.admin-tab-panel').forEach(p => { p.hidden = true; });
        this.classList.add('active');
        document.getElementById('panel-' + this.dataset.tab).hidden = false;
      });
    });

    // ── Library sync ───────────────────────────────────────────────
    let pollInterval = null;

    async function syncLibrary() {
      setSyncingState(true);
      const d = await apiFetch('/admin/sync/library');
      showToast(d.message);
      if (d.success) startPolling();
      else setSyncingState(false);
    }

    function startPolling() {
      if (pollInterval) return;
      pollInterval = setInterval(pollStatus, 2000);
    }

    if (<%= syncInProgress ? 'true' : 'false' %>) startPolling();

    function setSyncingState(isSyncing) {
      const badge = document.getElementById('sync-status-badge');
      const btn = document.getElementById('btn-sync-now');
      const msg = document.getElementById('sync-progress-msg');
      const text = document.getElementById('sync-status-text');

      btn.disabled = isSyncing;
      msg.style.display = isSyncing ? 'block' : 'none';
      text.textContent = isSyncing ? 'Syncing…' : 'Idle';
      badge.className = 'status-badge ' + (isSyncing ? 'status-syncing' : 'status-idle');

      const existing = badge.querySelector('.sync-spinner');
      if (isSyncing && !existing) {
        const sp = document.createElement('span');
        sp.className = 'sync-spinner';
        badge.insertBefore(sp, text);
      } else if (!isSyncing && existing) {
        existing.remove();
      }
    }

    async function pollStatus() {
      const d = await apiFetch('/admin/status', 'GET');
      setSyncingState(d.syncInProgress);
      if (!d.syncInProgress) {
        clearInterval(pollInterval);
        pollInterval = null;
        document.getElementById('stat-movies').textContent = d.stats.library.movies.toLocaleString();
        document.getElementById('stat-tv').textContent = d.stats.library.tv.toLocaleString();
        document.getElementById('stat-movies-sync').textContent = fmtTime(d.stats.library.lastSyncMovies);
        document.getElementById('stat-tv-sync').textContent = fmtTime(d.stats.library.lastSyncTV);
        if (d.lastSyncError) showToast('Sync error: ' + d.lastSyncError, true);
        else showToast('Library sync complete');
      }
    }

    // ── Logging toggle ─────────────────────────────────────────────
    async function onLoggingChange(enable) {
      await apiFetch('/admin/settings/logging', 'POST', { enabled: enable });
      showToast('Logging ' + (enable ? 'enabled' : 'disabled'));
    }

    // ── Auto-sync toggle ───────────────────────────────────────────
    async function onAutoSyncChange(enable) {
      await apiFetch('/admin/sync/auto/' + (enable ? 'enable' : 'disable'));
      showToast('Auto-sync ' + (enable ? 'enabled' : 'disabled'));
    }

    // ── Watched sync ───────────────────────────────────────────────
    async function syncWatched(userId) {
      const row = document.getElementById('user-row-' + userId);
      const syncBtn = row ? [...row.querySelectorAll('button')].find(b => b.textContent.includes('Re-sync')) : null;
      if (syncBtn) {
        syncBtn.disabled = true;
        syncBtn.dataset.origText = syncBtn.textContent;
        syncBtn.innerHTML = '<span class="sync-spinner" style="width:10px;height:10px;border-width:2px;vertical-align:middle;margin-right:4px"></span>Syncing…';
      }
      const d = await apiFetch('/admin/sync/watched/' + userId);
      if (!d.success) {
        showToast(d.message, true);
        if (syncBtn) { syncBtn.disabled = false; syncBtn.textContent = syncBtn.dataset.origText; }
        return;
      }
      showToast('Sync started for ' + userId);
      const prevCount = row ? parseInt(row.querySelector('.watched-count-cell')?.dataset.count || '0') : -1;
      let polls = 0;
      const poll = setInterval(async () => {
        polls++;
        const s = await apiFetch('/admin/status', 'GET');
        const userStat = (s.stats?.users || []).find(u => u.user_id === userId);
        if (userStat && (userStat.watched_count !== prevCount || polls > 30)) {
          clearInterval(poll);
          if (syncBtn) { syncBtn.disabled = false; syncBtn.textContent = syncBtn.dataset.origText; }
          const countCell = row?.querySelector('.watched-count-cell');
          if (countCell) {
            countCell.textContent = (userStat.watched_count || 0).toLocaleString() + ' items';
            countCell.dataset.count = userStat.watched_count || 0;
          }
          showToast('Watched sync complete — ' + (userStat.watched_count || 0).toLocaleString() + ' items');
        }
      }, 2000);
    }

    async function clearWatched(userId) {
      const d = await apiFetch('/admin/cache/clear/watched/' + userId);
      showToast(d.message);
    }
    async function clearAllWatched() {
      const d = await apiFetch('/admin/cache/clear/watched');
      showToast(d.message);
    }
    async function clearDismissals(userId) {
      const d = await apiFetch('/admin/cache/clear/dismissals/' + userId);
      showToast(d.message);
    }
    async function clearAllDismissals() {
      const d = await apiFetch('/admin/cache/clear/dismissals');
      showToast(d.message);
    }
    async function clearRecCache() {
      const d = await apiFetch('/admin/cache/clear/recommendations');
      showToast(d.message);
    }

    // ── Theme color ────────────────────────────────────────────────
    const PRESET_COLORS = [
      { label: 'Plex Gold',   hex: '#e5a00d' },
      { label: 'Netflix Red', hex: '#e50914' },
      { label: 'Neon Blue',   hex: '#00b4d8' },
      { label: 'Purple',      hex: '#9b5de5' },
      { label: 'Green',       hex: '#06d6a0' },
      { label: 'Pink',        hex: '#f72585' },
      { label: 'Orange',      hex: '#fb5607' },
      { label: 'White',       hex: '#e0e0e0' },
    ];
    let selectedColor = null;

    function initColorPicker() {
      fetch('/admin/theme/color').then(r => r.json()).then(d => {
        selectedColor = d.color || '#e5a00d';
        document.getElementById('custom-color-input').value = selectedColor;
        renderSwatches(selectedColor);
      });
    }
    function renderSwatches(activeColor) {
      const wrap = document.getElementById('color-swatches');
      wrap.innerHTML = '';
      PRESET_COLORS.forEach(p => {
        const s = document.createElement('div');
        s.className = 'color-swatch' + (p.hex.toLowerCase() === activeColor.toLowerCase() ? ' active' : '');
        s.style.background = p.hex;
        s.title = p.label;
        s.onclick = () => { selectedColor = p.hex; document.getElementById('custom-color-input').value = p.hex; renderSwatches(p.hex); };
        wrap.appendChild(s);
      });
    }
    document.getElementById('custom-color-input').oninput = function () { selectedColor = this.value; renderSwatches(this.value); };

    async function applyColor() {
      if (!selectedColor) return;
      const d = await fetch('/admin/theme/color', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ color: selectedColor }),
      }).then(r => r.json());
      if (d.success) {
        const link = document.getElementById('theme-css');
        if (link) link.href = '/theme.css?c=' + encodeURIComponent(d.color);
        showToast('Theme color updated');
      } else {
        showToast(d.error || 'Failed to update color', true);
      }
    }
    initColorPicker();

    // ── Server owner ───────────────────────────────────────────────
    async function saveOwnerUser() {
      const userId = document.getElementById('owner-user-select').value;
      if (!userId) { showToast('Please select a user first', true); return; }
      const d = await fetch('/admin/settings/owner-user', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId }),
      }).then(r => r.json());
      if (d.success) { showToast('Server owner account saved'); window.location.reload(); }
      else showToast(d.error || 'Failed to save owner', true);
    }

    // ── Watchlist mode ─────────────────────────────────────────────
    async function onWatchlistModeChange(isPlaylist) {
      const newMode = isPlaylist ? 'playlist' : 'watchlist';
      const lblW = document.getElementById('lbl-watchlist-opt');
      const lblP = document.getElementById('lbl-playlist-opt');
      if (lblW) lblW.className = isPlaylist ? 'service-label-inactive' : 'service-label-active';
      if (lblP) lblP.className = isPlaylist ? 'service-label-active' : 'service-label-inactive';
      const d = await fetch('/admin/settings/watchlist-mode', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ mode: newMode }),
      }).then(r => r.json());
      if (d.success) showToast('Switched to ' + (isPlaylist ? 'Diskovarr Playlist' : 'Plex Watchlist') + ' mode');
      else {
        document.getElementById('toggle-watchlist-mode').checked = !isPlaylist;
        if (lblW) lblW.className = isPlaylist ? 'service-label-active' : 'service-label-inactive';
        if (lblP) lblP.className = isPlaylist ? 'service-label-inactive' : 'service-label-active';
