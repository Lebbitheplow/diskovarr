    async function openUserSettingsModal(userId, username) {
      _umsUserId = userId;
      document.getElementById('user-settings-modal-name').textContent = username + ' (' + userId + ')';
      try {
        const r = await fetch('/admin/users/' + userId + '/settings');
        const s = await r.json();
        // Override toggle
        const overrideEl = document.getElementById('ums-override-toggle');
        overrideEl.checked = !!s.overrideGlobal;
        document.getElementById('ums-limits-fields').style.display = s.overrideGlobal ? 'flex' : 'none';
        // Movie limits
        const movieLimit = s.movieLimit || 0;
        document.getElementById('ums-movie-unlimited').checked = (movieLimit === 0);
        document.getElementById('ums-movie-fields').style.display = (movieLimit === 0) ? 'none' : 'flex';
        document.getElementById('ums-movie-count').value = movieLimit || 1;
        document.getElementById('ums-movie-days').value = s.movieWindowDays || 7;
        // Season limits
        const seasonLimit = s.seasonLimit || 0;
        document.getElementById('ums-season-unlimited').checked = (seasonLimit === 0);
        document.getElementById('ums-season-fields').style.display = (seasonLimit === 0) ? 'none' : 'flex';
        document.getElementById('ums-season-count').value = seasonLimit || 1;
        document.getElementById('ums-season-days').value = s.tvWindowDays || 7;
        // Auto-approve override
        const hasAutoApproveOverride = s.auto_approve_movies !== null || s.auto_approve_tv !== null;
        document.getElementById('ums-auto-approve-override').checked = hasAutoApproveOverride;
        document.getElementById('ums-auto-approve-fields').style.display = hasAutoApproveOverride ? 'flex' : 'none';
        // Default toggle to global value when first enabling override (or use saved value)
        document.getElementById('ums-auto-approve-movies-toggle').checked = s.auto_approve_movies !== null ? !!s.auto_approve_movies : true;
        document.getElementById('ums-auto-approve-tv-toggle').checked = s.auto_approve_tv !== null ? !!s.auto_approve_tv : true;
        // Admin
        document.getElementById('ums-is-admin').checked = !!s.is_admin;
      } catch (err) {
        showToast('Failed to load settings: ' + err.message, true);
        return;
      }
      document.getElementById('user-settings-modal').style.display = 'flex';
    }

