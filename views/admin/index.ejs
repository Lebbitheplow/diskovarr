    async function saveUserSettings() {
      if (!_umsUserId) return;
      const overrideGlobal = document.getElementById('ums-override-toggle').checked;
      const movieUnlimited = document.getElementById('ums-movie-unlimited').checked;
      const movieLimit = movieUnlimited ? 0 : (parseInt(document.getElementById('ums-movie-count').value) || 1);
      const movieWindowDays = movieUnlimited ? 7 : (parseInt(document.getElementById('ums-movie-days').value) || 7);
      const seasonUnlimited = document.getElementById('ums-season-unlimited').checked;
      const seasonLimit = seasonUnlimited ? 0 : (parseInt(document.getElementById('ums-season-count').value) || 1);
      const tvWindowDays = seasonUnlimited ? 7 : (parseInt(document.getElementById('ums-season-days').value) || 7);
      const autoApproveOverride = document.getElementById('ums-auto-approve-override').checked;
      const amVal = autoApproveOverride ? (document.getElementById('ums-auto-approve-movies-toggle').checked ? '1' : '0') : null;
      const atVal = autoApproveOverride ? (document.getElementById('ums-auto-approve-tv-toggle').checked ? '1' : '0') : null;
      const is_admin = document.getElementById('ums-is-admin').checked;
      try {
        const r = await fetch('/admin/users/' + _umsUserId + '/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            movieLimit, seasonLimit, movieWindowDays, tvWindowDays,
            overrideGlobal: overrideGlobal ? '1' : '0',
            auto_approve_movies: amVal,
            auto_approve_tv: atVal,
            is_admin: is_admin ? '1' : '0',
          }),
        });
        const data = await r.json();
        if (data.success) {
          showToast('User settings saved');
          closeUserSettingsModal();
        } else {
          showToast('Save failed: ' + (data.error || ''), true);
        }
      } catch (err) {
        showToast('Save failed: ' + err.message, true);
      }
    }

