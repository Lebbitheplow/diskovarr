    // ── Library sync ───────────────────────────────────────────────
    let pollInterval = null;

    async function syncLibrary() {
      setSyncingState(true);
      const d = await apiFetch('/admin/sync/library');
      showToast(d.message);
      if (d.success) startPolling();
      else setSyncingState(false);
    }

    function startPolling() {
      if (pollInterval) return;
      pollInterval = setInterval(pollStatus, 2000);
    }

    if (<%= syncInProgress ? 'true' : 'false' %>) startPolling();

    function setSyncingState(isSyncing) {
      const badge = document.getElementById('sync-status-badge');
      const btn = document.getElementById('btn-sync-now');
      const msg = document.getElementById('sync-progress-msg');
      const text = document.getElementById('sync-status-text');

      btn.disabled = isSyncing;
      msg.style.display = isSyncing ? 'block' : 'none';
      text.textContent = isSyncing ? 'Syncing…' : 'Idle';
      badge.className = 'status-badge ' + (isSyncing ? 'status-syncing' : 'status-idle');

      const existing = badge.querySelector('.sync-spinner');
      if (isSyncing && !existing) {
        const sp = document.createElement('span');
        sp.className = 'sync-spinner';
        badge.insertBefore(sp, text);
      } else if (!isSyncing && existing) {
        existing.remove();
      }
    }

    async function pollStatus() {
      const d = await apiFetch('/admin/status', 'GET');
      setSyncingState(d.syncInProgress);
      if (!d.syncInProgress) {
        clearInterval(pollInterval);
        pollInterval = null;
        document.getElementById('stat-movies').textContent = d.stats.library.movies.toLocaleString();
        document.getElementById('stat-tv').textContent = d.stats.library.tv.toLocaleString();
        document.getElementById('stat-total').textContent = (d.stats.library.movies + d.stats.library.tv).toLocaleString();
        document.getElementById('stat-movies-sync').textContent = fmtTime(d.stats.library.lastSyncMovies);
        document.getElementById('stat-tv-sync').textContent = fmtTime(d.stats.library.lastSyncTV);
        if (d.lastSyncError) showToast('Sync error: ' + d.lastSyncError, true);
        else showToast('Library sync complete');
      }
    }

