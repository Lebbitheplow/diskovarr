    const PRESET_COLORS = [
      { label: 'Plex Gold',   hex: '#e5a00d' },
      { label: 'Netflix Red', hex: '#e50914' },
      { label: 'Neon Blue',   hex: '#00b4d8' },
      { label: 'Purple',      hex: '#9b5de5' },
