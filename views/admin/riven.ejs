<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — Torrent Browser</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=45">
  <link rel="stylesheet" href="/css/admin.css?v=31">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>" id="theme-css">
  <style>
    /* ── Layout ── */
    html, body { height: 100%; overflow: hidden; }
    body { display: flex; flex-direction: column; }
    .rv-body { display: flex; flex-direction: column; flex: 1; min-height: 0; }

    /* ── Top bar ── */
    .rv-topbar { padding: 10px 16px; border-bottom: 1px solid var(--border); background: var(--bg-surface); flex-shrink: 0; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .rv-topbar-back { color: var(--text-muted); font-size: 0.82rem; text-decoration: none; white-space: nowrap; }
    .rv-topbar-back:hover { color: var(--text); }
    .rv-search-wrap { position: relative; flex: 1; min-width: 180px; max-width: 420px; }
    .rv-search-input { width: 100%; background: var(--bg-card); border: 1px solid var(--border); color: var(--text); border-radius: 7px; padding: 8px 12px; font-size: 0.88rem; font-family: inherit; box-sizing: border-box; }
    .rv-search-input:focus { outline: none; border-color: var(--accent); }
    .rv-suggest-box { position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; z-index: 300; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.5); max-height: 380px; overflow-y: auto; }
    .rv-suggest-item { display: flex; align-items: center; gap: 10px; padding: 8px 12px; cursor: pointer; border-bottom: 1px solid var(--border); transition: background 0.1s; }
    .rv-suggest-item:last-child { border-bottom: none; }
    .rv-suggest-item:hover { background: rgba(255,255,255,0.06); }
    .rv-suggest-poster { width: 30px; height: 44px; object-fit: cover; border-radius: 3px; flex-shrink: 0; }
    .rv-suggest-poster-empty { width: 30px; height: 44px; background: var(--bg-surface); border-radius: 3px; flex-shrink: 0; }
    .rv-suggest-name { font-size: 0.85rem; font-weight: 600; }
    .rv-suggest-meta { display: flex; gap: 6px; align-items: center; margin-top: 2px; }
    .rv-suggest-year { font-size: 0.72rem; color: var(--text-muted); }
    .rv-type-badge { font-size: 0.65rem; padding: 1px 5px; border-radius: 3px; background: rgba(255,255,255,0.08); color: var(--text-muted); }
    .rv-suggest-hint { padding: 10px 14px; font-size: 0.8rem; color: var(--text-muted); text-align: center; }

    /* ── Selected item chip ── */
    .rv-item-chip { display: flex; align-items: center; gap: 8px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 7px; padding: 5px 10px; flex-shrink: 0; }
    .rv-item-chip-poster { width: 20px; height: 30px; object-fit: cover; border-radius: 2px; }
    .rv-item-chip-poster-empty { width: 20px; height: 30px; background: var(--bg-surface); border-radius: 2px; }
    .rv-item-chip-title { font-size: 0.82rem; font-weight: 600; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .rv-item-chip-meta { font-size: 0.72rem; color: var(--text-muted); }
    .rv-item-chip-clear { font-size: 0.75rem; color: var(--text-muted); cursor: pointer; padding: 2px 4px; margin-left: 2px; }
    .rv-item-chip-clear:hover { color: var(--text); }

    /* ── Season tabs strip ── */
    .rv-season-strip { padding: 6px 12px; border-bottom: 1px solid var(--border); background: var(--bg-surface); flex-shrink: 0; display: flex; gap: 5px; flex-wrap: wrap; overflow-x: auto; }
    .rv-season-tab { font-size: 0.75rem; padding: 3px 10px; border-radius: 5px; border: 1px solid var(--border); background: transparent; color: var(--text-muted); cursor: pointer; transition: all 0.15s; white-space: nowrap; }
    .rv-season-tab:hover:not(.active) { border-color: var(--text-muted); color: var(--text); }
    .rv-season-tab.active { border-color: var(--accent); background: var(--accent); color: #000; font-weight: 600; }

    /* ── iframe area ── */
    .rv-frame-area { flex: 1; min-height: 0; position: relative; }
    .rv-frame-placeholder { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: var(--text-muted); gap: 10px; }
    .rv-frame-placeholder-icon { font-size: 2.5rem; opacity: 0.3; }
    .rv-frame-placeholder-text { font-size: 0.9rem; }
    #rv-dmm-frame { width: 100%; height: 100%; border: none; display: none; }

    /* ── Paste bar (fixed bottom) ── */
    .rv-paste-bar { flex-shrink: 0; border-top: 1px solid var(--border); background: var(--bg-surface); padding: 8px 16px; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .rv-paste-hint { font-size: 0.78rem; color: var(--text-muted); flex: 1; min-width: 160px; }
    .rv-paste-hint strong { color: var(--text); }
    .rv-paste-input { flex: 1; min-width: 200px; max-width: 480px; background: var(--bg-card); border: 1px solid var(--border); color: var(--text); border-radius: 6px; padding: 7px 12px; font-size: 0.82rem; font-family: monospace; }
    .rv-paste-input:focus { outline: none; border-color: var(--accent); }
    .rv-paste-status { font-size: 0.8rem; font-weight: 600; color: #4ade80; display: none; }
    .rv-paste-status.show { display: block; }
    .rv-paste-status.error { color: #f87171; }

    /* ── Toast ── */
    #rv-toast { position: fixed; bottom: 70px; left: 50%; transform: translateX(-50%); background: var(--bg-card); border: 1px solid var(--border); color: var(--text); padding: 10px 20px; border-radius: 8px; font-size: 0.85rem; z-index: 9999; opacity: 0; transition: opacity 0.2s; pointer-events: none; white-space: nowrap; max-width: 90vw; text-align: center; }
    #rv-toast.show { opacity: 1; }
    #rv-toast.error { border-color: #f87171; color: #f87171; }
    #rv-toast.ok { border-color: #4ade80; color: #4ade80; }
  </style>
</head>
<body>
  <style id="bg-gradient-style"><%- bgGradientCss %></style>
  <nav class="nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">
        <span class="logo-icon">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="none" aria-hidden="true">
            <rect x="0.5" y="17.5" width="13" height="1.5" rx="0.5" fill="currentColor"/>
            <rect x="1" y="8.5" width="2.5" height="9" rx="0.4" fill="currentColor"/>
            <rect x="4.5" y="11" width="3" height="6.5" rx="0.4" fill="currentColor"/>
            <rect x="8.5" y="10" width="2.5" height="7.5" rx="0.4" fill="currentColor"/>
            <circle cx="15" cy="9" r="5" stroke="currentColor" stroke-width="2"/>
            <line x1="18.5" y1="12.5" x2="22" y2="16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
          </svg>
        </span>
        <span class="logo-text">Diskovarr</span>
        <span class="admin-badge">admin</span>
      </a>
      <div class="nav-user">
        <a href="/admin#connections" class="nav-logout">&#8592; Admin</a>
        <form method="POST" action="/admin/logout" style="display:inline">
          <button type="submit" class="nav-logout" style="background:none;border:none;cursor:pointer">Sign out</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="rv-body">

    <!-- Top bar: search + selected item chip -->
    <div class="rv-topbar">
      <div class="rv-search-wrap" id="rv-search-wrap">
        <input type="text" id="rv-search-input" class="rv-search-input" placeholder="Search for a movie or TV show…" autocomplete="off">
        <div class="rv-suggest-box" id="rv-suggest-box" style="display:none"></div>
      </div>
      <!-- Reload DMM iframe (shown when item selected — restores page after RD auth navigates away) -->
      <button id="rv-reload-btn" onclick="loadDMM()" style="display:none;flex-shrink:0;font-size:0.78rem;color:var(--text-muted);background:none;border:1px solid var(--border);border-radius:6px;padding:5px 8px;cursor:pointer;white-space:nowrap" title="Reload DMM to the selected title">&#8635; Reload</button>
      <!-- Open DMM in new tab (shown when item selected — useful for RD auth) -->
      <a id="rv-open-tab" href="#" target="_blank" rel="noopener" style="display:none;flex-shrink:0;font-size:0.78rem;color:var(--text-muted);text-decoration:none;padding:5px 8px;border:1px solid var(--border);border-radius:6px;white-space:nowrap" title="Open in new tab if RD auth needed">Open in new tab &#8599;</a>
      <!-- Item chip (shown when item selected) -->
      <div id="rv-item-chip" style="display:none" class="rv-item-chip">
        <img id="rv-chip-poster" class="rv-item-chip-poster" src="" alt="" style="display:none">
        <div id="rv-chip-poster-empty" class="rv-item-chip-poster-empty" style="display:none"></div>
        <div>
          <div class="rv-item-chip-title" id="rv-chip-title"></div>
          <div class="rv-item-chip-meta" id="rv-chip-meta"></div>
        </div>
        <span class="rv-item-chip-clear" onclick="clearSelection()" title="Clear">&#10005;</span>
      </div>
    </div>

    <!-- Season tabs (TV only) -->
    <div id="rv-season-strip" class="rv-season-strip" style="display:none"></div>

    <!-- DMM iframe or placeholder -->
    <div class="rv-frame-area">
      <div id="rv-placeholder" class="rv-frame-placeholder">
        <div class="rv-frame-placeholder-icon">&#128269;</div>
        <div class="rv-frame-placeholder-text">Search for a title above to open Debrid Media Manager</div>
      </div>
      <iframe id="rv-dmm-frame" src="" title="Debrid Media Manager" allowfullscreen sandbox="allow-same-origin allow-scripts allow-forms allow-popups allow-popups-to-escape-sandbox allow-top-navigation-by-user-activation"></iframe>
    </div>

    <!-- Paste bar (always visible once item selected) -->
    <div class="rv-paste-bar" id="rv-paste-bar" style="display:none">
      <span class="rv-paste-hint">Copy a magnet link in DMM — then <strong>paste it here</strong> to add to Riven instantly:</span>
      <input type="text" id="rv-paste-input" class="rv-paste-input" placeholder="Paste magnet link…" autocomplete="off">
      <span class="rv-paste-status" id="rv-paste-status"></span>
    </div>

  </div>

  <div id="rv-toast"></div>

  <script>
    // ── State ──────────────────────────────────────────────────────────────────
    var _sel = null;     // { tmdbId, mediaType, title, year, posterUrl, imdbId }
    var _seasons = [];
    var _curSeason = 1;
    var _suggestTimeout = null;
    var _lastQuery = '';
    var _suggestResults = [];

    // ── Toast ──────────────────────────────────────────────────────────────────
    function showToast(msg, type) {
      var el = document.getElementById('rv-toast');
      el.textContent = msg;
      el.className = 'show' + (type === 'error' ? ' error' : type === 'ok' ? ' ok' : '');
      clearTimeout(el._t);
      el._t = setTimeout(function() { el.className = ''; }, 3800);
    }

    // ── TMDB search ────────────────────────────────────────────────────────────
    var _inp = document.getElementById('rv-search-input');
    var _sbox = document.getElementById('rv-suggest-box');

    _inp.addEventListener('input', function() {
      clearTimeout(_suggestTimeout);
      var q = this.value.trim();
      _lastQuery = q;
      if (q.length < 2) { _sbox.style.display = 'none'; return; }
      _suggestTimeout = setTimeout(function() { fetchSuggestions(q); }, 280);
    });

    _inp.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') _sbox.style.display = 'none';
    });

    document.addEventListener('click', function(e) {
      if (!document.getElementById('rv-search-wrap').contains(e.target)) {
        _sbox.style.display = 'none';
      }
    });

    async function fetchSuggestions(q) {
      try {
        var d = await fetch('/admin/riven/tmdb/search?q=' + encodeURIComponent(q)).then(r => r.json());
        _suggestResults = d.results || [];
        renderSuggestions(_suggestResults);
      } catch { _sbox.style.display = 'none'; }
    }

    function renderSuggestions(results) {
      if (!results.length) {
        _sbox.innerHTML = '<div class="rv-suggest-hint">No results found</div>';
        _sbox.style.display = 'block';
        return;
      }
      _sbox.innerHTML = results.slice(0, 8).map(function(r) {
        var poster = r.posterUrl
          ? '<img class="rv-suggest-poster" src="' + esc(r.posterUrl) + '" alt="" loading="lazy">'
          : '<div class="rv-suggest-poster-empty"></div>';
        var data = esc(JSON.stringify(r));
        return '<div class="rv-suggest-item" onclick="selectItem(' + data + ')">'
          + poster
          + '<div style="flex:1;min-width:0">'
          + '<div class="rv-suggest-name">' + esc(r.title) + '</div>'
          + '<div class="rv-suggest-meta">'
          + (r.year ? '<span class="rv-suggest-year">' + r.year + '</span>' : '')
          + '<span class="rv-type-badge">' + (r.mediaType === 'tv' ? 'TV' : 'Movie') + '</span>'
          + '</div></div></div>';
      }).join('');
      _sbox.style.display = 'block';
    }

    // ── Select item ────────────────────────────────────────────────────────────
    async function selectItem(r) {
      _sbox.style.display = 'none';
      _inp.value = '';
      _sel = Object.assign({}, r, { imdbId: null });
      renderChip();
      document.getElementById('rv-item-chip').style.display = 'flex';
      document.getElementById('rv-placeholder').style.display = 'none';

      // Fetch IMDB ID
      try {
        var d = await fetch('/admin/riven/tmdb/imdb-id?tmdbId=' + r.tmdbId + '&mediaType=' + r.mediaType).then(x => x.json());
        _sel.imdbId = d.imdbId || null;
      } catch { _sel.imdbId = null; }

      if (!_sel.imdbId) {
        showToast('No IMDB ID found for this title', 'error');
        clearSelection();
        return;
      }

      // TV: load season tabs
      if (r.mediaType === 'tv') {
        try {
          var sd = await fetch('/admin/riven/tmdb/seasons?tmdbId=' + r.tmdbId).then(x => x.json());
          _seasons = sd.seasons || [];
        } catch { _seasons = []; }
        _curSeason = 1;
        renderSeasonTabs();
      } else {
        _seasons = [];
        document.getElementById('rv-season-strip').style.display = 'none';
      }

      loadDMM();
      document.getElementById('rv-paste-bar').style.display = 'flex';
      // Focus paste input so user can paste immediately
      setTimeout(function() { document.getElementById('rv-paste-input').focus(); }, 300);
    }

    function renderChip() {
      if (!_sel) return;
      document.getElementById('rv-chip-title').textContent = _sel.title;
      document.getElementById('rv-chip-meta').textContent = (_sel.year || '') + (_sel.year && _sel.mediaType ? ' · ' : '') + (_sel.mediaType === 'tv' ? 'TV' : 'Movie');
      var pImg = document.getElementById('rv-chip-poster');
      var pEmpty = document.getElementById('rv-chip-poster-empty');
      if (_sel.posterUrl) {
        pImg.src = _sel.posterUrl;
        pImg.style.display = 'block'; pEmpty.style.display = 'none';
      } else {
        pImg.style.display = 'none'; pEmpty.style.display = 'block';
      }
    }

    function renderSeasonTabs() {
      var strip = document.getElementById('rv-season-strip');
      if (!_seasons.length) { strip.style.display = 'none'; return; }
      strip.innerHTML = _seasons.map(function(s) {
        var lbl = 'S' + String(s.number).padStart(2, '0');
        return '<button class="rv-season-tab' + (s.number === _curSeason ? ' active' : '') + '" onclick="switchSeason(' + s.number + ')">' + lbl + '</button>';
      }).join('');
      strip.style.display = 'flex';
    }

    function switchSeason(n) {
      _curSeason = n;
      renderSeasonTabs();
      // Don't reload the DMM iframe — DMM has its own season navigation inside.
      // _curSeason is only used so we know the season context when injecting a torrent.
    }

    function loadDMM() {
      if (!_sel || !_sel.imdbId) return;
      var dmmUrl = 'https://debridmediamanager.com/x/' + _sel.imdbId + '/';
      var frame = document.getElementById('rv-dmm-frame');
      frame.src = dmmUrl;
      frame.style.display = 'block';
      var tabLink = document.getElementById('rv-open-tab');
      tabLink.href = dmmUrl;
      tabLink.style.display = 'flex';
      document.getElementById('rv-reload-btn').style.display = 'flex';
    }

    function clearSelection() {
      _sel = null; _seasons = [];
      _inp.value = ''; _lastQuery = '';
      document.getElementById('rv-item-chip').style.display = 'none';
      document.getElementById('rv-season-strip').style.display = 'none';
      document.getElementById('rv-paste-bar').style.display = 'none';
      document.getElementById('rv-open-tab').style.display = 'none';
      document.getElementById('rv-reload-btn').style.display = 'none';
      document.getElementById('rv-paste-input').value = '';
      document.getElementById('rv-placeholder').style.display = 'flex';
      var frame = document.getElementById('rv-dmm-frame');
      frame.style.display = 'none';
      frame.src = '';
    }

    // ── Magnet paste → Riven ──────────────────────────────────────────────────
    var _pasteInput = document.getElementById('rv-paste-input');

    _pasteInput.addEventListener('paste', function(e) {
      var text = (e.clipboardData || window.clipboardData).getData('text').trim();
      if (text.startsWith('magnet:')) {
        e.preventDefault();
        _pasteInput.value = text;
        doAddMagnet(text);
      }
    });

    // Also catch Ctrl+V anywhere on the page (when focus is not in an input inside the iframe)
    document.addEventListener('paste', function(e) {
      var active = document.activeElement;
      // Only handle if focus is on the page body (not in our own inputs)
      if (active && active.id === 'rv-paste-input') return; // handled above
      if (active && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) return;
      if (!_sel || !_sel.imdbId) return;
      var text = (e.clipboardData || window.clipboardData).getData('text').trim();
      if (text.startsWith('magnet:')) {
        e.preventDefault();
        _pasteInput.value = text;
        doAddMagnet(text);
      }
    });

    async function doAddMagnet(magnet) {
      if (!_sel || !_sel.imdbId) { showToast('Select a title first', 'error'); return; }
      var status = document.getElementById('rv-paste-status');
      status.textContent = 'Adding to Riven…';
      status.className = 'rv-paste-status show';

      try {
        var body = { imdbId: _sel.imdbId, mediaType: _sel.mediaType, magnet };
        if (_sel.mediaType === 'tv') body.season = _curSeason;
        var d = await fetch('/admin/riven/torrents/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        }).then(r => r.json());

        if (d.error) throw new Error(d.error);
        status.textContent = '&#10003; Added to Riven';
        status.className = 'rv-paste-status show';
        showToast('Added to Riven — symlink and Plex notify will follow', 'ok');
        setTimeout(function() {
          _pasteInput.value = '';
          status.className = 'rv-paste-status';
        }, 4000);
      } catch (err) {
        status.textContent = 'Failed: ' + err.message;
        status.className = 'rv-paste-status show error';
        showToast('Failed: ' + err.message, 'error');
      }
    }

    // ── Utility ────────────────────────────────────────────────────────────────
    function esc(str) {
      if (str == null) return '';
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  </script>
</body>
</html>
