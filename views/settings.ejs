<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — My Settings</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f0f0f">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=30">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>" id="theme-css">
  <style>
    .settings-page { max-width: 700px; margin: 0 auto; padding: 0 16px 64px; }
    .settings-hero { padding: 32px 0 24px; }
    .settings-hero h1 { font-size: 1.6rem; font-weight: 700; margin: 0 0 6px; }
    .settings-hero p { color: var(--text-secondary); margin: 0; font-size: 0.9rem; }
    .settings-section { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px; padding: 24px; margin-bottom: 20px; }
    .settings-section-title { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-secondary); margin: 0 0 16px; }
    .settings-field { margin-bottom: 16px; }
    .settings-field:last-child { margin-bottom: 0; }
    .settings-label { display: block; font-size: 0.85rem; font-weight: 500; color: #fff; margin-bottom: 6px; }
    .settings-desc { font-size: 0.78rem; color: var(--text-secondary); margin-bottom: 8px; }
    .settings-select { width: 100%; padding: 8px 10px; border-radius: 7px; border: 1px solid var(--border); background: var(--bg-elevated); color: var(--text); font-size: 0.88rem; max-width: 320px; }
    .settings-select:focus { outline: none; border-color: var(--accent); }
    .btn-settings-save { padding: 8px 22px; border-radius: 7px; border: none; background: var(--accent); color: #000; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .btn-settings-save:hover { background: var(--accent-hover); }
    .settings-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: #1e1e1e; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 0.88rem; z-index: 9999; opacity: 0; transition: opacity 0.25s; pointer-events: none; border: 1px solid var(--border); }
    .settings-toast.show { opacity: 1; }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <div class="settings-page">
    <div class="settings-hero">
      <h1>My Settings</h1>
      <p>Your personal preferences for Diskovarr.</p>
    </div>

    <div id="settings-toast" class="settings-toast"></div>

    <div class="settings-section">
      <p class="settings-section-title">Content Preferences</p>
      <p class="settings-desc" style="margin-bottom:20px">These preferences will be used to filter content recommendations.</p>

      <div class="settings-field">
        <label class="settings-label" for="pref-region">Region</label>
        <select id="pref-region" class="settings-select">
          <option value="">All Regions</option>
          <option value="US" <%= prefs.region === 'US' ? 'selected' : '' %>>United States</option>
          <option value="GB" <%= prefs.region === 'GB' ? 'selected' : '' %>>United Kingdom</option>
          <option value="CA" <%= prefs.region === 'CA' ? 'selected' : '' %>>Canada</option>
          <option value="AU" <%= prefs.region === 'AU' ? 'selected' : '' %>>Australia</option>
          <option value="DE" <%= prefs.region === 'DE' ? 'selected' : '' %>>Germany</option>
          <option value="FR" <%= prefs.region === 'FR' ? 'selected' : '' %>>France</option>
          <option value="ES" <%= prefs.region === 'ES' ? 'selected' : '' %>>Spain</option>
          <option value="IT" <%= prefs.region === 'IT' ? 'selected' : '' %>>Italy</option>
          <option value="JP" <%= prefs.region === 'JP' ? 'selected' : '' %>>Japan</option>
          <option value="KR" <%= prefs.region === 'KR' ? 'selected' : '' %>>South Korea</option>
          <option value="IN" <%= prefs.region === 'IN' ? 'selected' : '' %>>India</option>
          <option value="BR" <%= prefs.region === 'BR' ? 'selected' : '' %>>Brazil</option>
          <option value="MX" <%= prefs.region === 'MX' ? 'selected' : '' %>>Mexico</option>
          <option value="NL" <%= prefs.region === 'NL' ? 'selected' : '' %>>Netherlands</option>
          <option value="SE" <%= prefs.region === 'SE' ? 'selected' : '' %>>Sweden</option>
          <option value="NO" <%= prefs.region === 'NO' ? 'selected' : '' %>>Norway</option>
          <option value="DK" <%= prefs.region === 'DK' ? 'selected' : '' %>>Denmark</option>
          <option value="FI" <%= prefs.region === 'FI' ? 'selected' : '' %>>Finland</option>
          <option value="PL" <%= prefs.region === 'PL' ? 'selected' : '' %>>Poland</option>
          <option value="RU" <%= prefs.region === 'RU' ? 'selected' : '' %>>Russia</option>
          <option value="CN" <%= prefs.region === 'CN' ? 'selected' : '' %>>China</option>
          <option value="AR" <%= prefs.region === 'AR' ? 'selected' : '' %>>Argentina</option>
          <option value="CL" <%= prefs.region === 'CL' ? 'selected' : '' %>>Chile</option>
          <option value="NZ" <%= prefs.region === 'NZ' ? 'selected' : '' %>>New Zealand</option>
          <option value="ZA" <%= prefs.region === 'ZA' ? 'selected' : '' %>>South Africa</option>
          <option value="BE" <%= prefs.region === 'BE' ? 'selected' : '' %>>Belgium</option>
          <option value="CH" <%= prefs.region === 'CH' ? 'selected' : '' %>>Switzerland</option>
          <option value="AT" <%= prefs.region === 'AT' ? 'selected' : '' %>>Austria</option>
          <option value="PT" <%= prefs.region === 'PT' ? 'selected' : '' %>>Portugal</option>
          <option value="IE" <%= prefs.region === 'IE' ? 'selected' : '' %>>Ireland</option>
        </select>
      </div>

      <div class="settings-field">
        <label class="settings-label" for="pref-language">Language</label>
        <select id="pref-language" class="settings-select">
          <option value="">All Languages</option>
          <option value="en" <%= prefs.language === 'en' ? 'selected' : '' %>>English</option>
          <option value="es" <%= prefs.language === 'es' ? 'selected' : '' %>>Spanish</option>
          <option value="fr" <%= prefs.language === 'fr' ? 'selected' : '' %>>French</option>
          <option value="de" <%= prefs.language === 'de' ? 'selected' : '' %>>German</option>
          <option value="it" <%= prefs.language === 'it' ? 'selected' : '' %>>Italian</option>
          <option value="ja" <%= prefs.language === 'ja' ? 'selected' : '' %>>Japanese</option>
          <option value="ko" <%= prefs.language === 'ko' ? 'selected' : '' %>>Korean</option>
          <option value="zh" <%= prefs.language === 'zh' ? 'selected' : '' %>>Chinese</option>
          <option value="pt" <%= prefs.language === 'pt' ? 'selected' : '' %>>Portuguese</option>
          <option value="ru" <%= prefs.language === 'ru' ? 'selected' : '' %>>Russian</option>
          <option value="nl" <%= prefs.language === 'nl' ? 'selected' : '' %>>Dutch</option>
          <option value="pl" <%= prefs.language === 'pl' ? 'selected' : '' %>>Polish</option>
          <option value="sv" <%= prefs.language === 'sv' ? 'selected' : '' %>>Swedish</option>
          <option value="da" <%= prefs.language === 'da' ? 'selected' : '' %>>Danish</option>
          <option value="no" <%= prefs.language === 'no' ? 'selected' : '' %>>Norwegian</option>
          <option value="fi" <%= prefs.language === 'fi' ? 'selected' : '' %>>Finnish</option>
          <option value="ar" <%= prefs.language === 'ar' ? 'selected' : '' %>>Arabic</option>
          <option value="hi" <%= prefs.language === 'hi' ? 'selected' : '' %>>Hindi</option>
          <option value="tr" <%= prefs.language === 'tr' ? 'selected' : '' %>>Turkish</option>
          <option value="th" <%= prefs.language === 'th' ? 'selected' : '' %>>Thai</option>
        </select>
      </div>

      <button class="btn-settings-save" onclick="savePreferences()">Save Preferences</button>
    </div>

    <!-- Notifications -->
    <div class="settings-section">
      <p class="settings-section-title">Notification Settings</p>

      <div class="settings-field">
        <div style="display:flex;flex-direction:column;gap:10px">
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notif-approved" <%= notificationPrefs.notify_approved ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Request Approved</strong>
              <span style="color:var(--text-secondary)"> — Get notified when your media requests are approved</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notif-denied" <%= notificationPrefs.notify_denied ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Request Declined</strong>
              <span style="color:var(--text-secondary)"> — Get notified when your media requests are declined</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notif-available" <%= notificationPrefs.notify_available ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Request Available</strong>
              <span style="color:var(--text-secondary)"> — Get notified when your requested media is available in the library</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notify_issue_update" <%= notificationPrefs.notify_issue_update ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Issue Status Updated</strong>
              <span style="color:var(--text-secondary)"> — Get notified when an issue you reported changes status</span>
            </span>
          </label>
          <% if (isElevated) { %>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notify_pending" <%= notificationPrefs.notify_pending ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">New Request Pending</strong>
              <span style="color:var(--text-secondary)"> — Get notified when a user submits a request awaiting approval</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notify_auto_approved" <%= notificationPrefs.notify_auto_approved ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Request Auto-Approved</strong>
              <span style="color:var(--text-secondary)"> — Get notified when a request is automatically submitted</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notify_process_failed" <%= notificationPrefs.notify_process_failed ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">Processing Failed</strong>
              <span style="color:var(--text-secondary)"> — Get notified when a request fails to submit to Radarr/Sonarr/Overseerr</span>
            </span>
          </label>
          <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
            <input type="checkbox" class="themed-checkbox" id="notify_issue_new" <%= notificationPrefs.notify_issue_new ? 'checked' : '' %>>
            <span style="font-size:0.88rem">
              <strong style="color:#fff">New Issue Reported</strong>
              <span style="color:var(--text-secondary)"> — Get notified when a user reports a new issue</span>
            </span>
          </label>
          <% } %>
        </div>
      </div>

      <% if (discordAgentEnabled) { %>
      <div class="settings-field" style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
        <% if (discordMode === 'bot') { %>
          <label class="settings-label">Discord (Bot DMs)</label>
          <p class="settings-desc">Enter your Discord User ID to receive direct message notifications from the Diskovarr bot.</p>
          <p style="font-size:0.78rem;color:var(--text-secondary);margin:0 0 4px"><strong style="color:var(--text-primary)">Desktop:</strong> A 17–19 digit number — not your username. Enable Developer Mode (Settings → Advanced), then right-click your avatar on any message you've sent → Copy User ID.</p>
          <p style="font-size:0.78rem;color:var(--text-secondary);margin:0 0 6px"><strong style="color:var(--text-primary)">Mobile:</strong> Tap on your profile in a message, then tap the ⋯ in the top-right corner → Copy User ID. (Requires Developer Mode enabled in Appearance settings.)</p>
          <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px">
            <input type="text" id="notif-discord-userid" class="settings-select" style="flex:1;font-family:monospace;font-size:0.82rem"
              placeholder="e.g. 185234567891234560"
              value="<%= notificationPrefs.discord_user_id || '' %>">
            <button type="button" class="btn-settings-save" style="white-space:nowrap;padding:8px 14px;font-size:0.82rem" onclick="testDiscordDm()">Send Test</button>
          </div>
          <% if (discordInviteLink) { %>
          <div style="background:rgba(255,165,0,0.08);border:1px solid rgba(255,165,0,0.25);border-radius:8px;padding:10px 14px;margin-top:10px;font-size:0.82rem;color:var(--text-secondary)">
            &#9888; You must be a member of the admin's Discord server for the bot to send you DMs.
            <a href="<%= discordInviteLink %>" target="_blank" rel="noopener" style="display:inline-block;margin-top:8px;padding:6px 14px;background:var(--accent);color:#000;border-radius:6px;font-weight:600;text-decoration:none;font-size:0.82rem">Join Server</a>
          </div>
          <% } %>
        <% } else { %>
          <label class="settings-label">Discord Webhook</label>
          <p class="settings-desc">Receive personal notifications in a Discord channel.</p>
          <input type="text" id="notif-discord-webhook" class="settings-select" style="max-width:100%;font-family:monospace;font-size:0.82rem"
            placeholder="https://discord.com/api/webhooks/..."
            value="<%= notificationPrefs.discord_webhook || '' %>">
        <% } %>
        <div class="toggle-row" style="margin-top:10px">
          <label class="slide-toggle">
            <input type="checkbox" id="notif-discord-enabled" <%= notificationPrefs.discord_enabled ? 'checked' : '' %>>
            <span class="slide-track"></span>
          </label>
          <span class="toggle-label">Enable Discord notifications</span>
        </div>
      </div>
      <% } %>

      <% if (pushoverAgentEnabled) { %>
      <div class="settings-field" style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
        <label class="settings-label">Pushover</label>
        <p class="settings-desc">Receive personal push notifications via Pushover.</p>
        <div style="display:flex;gap:8px;align-items:center;margin-bottom:4px">
          <input type="text" id="notif-pushover-key" class="settings-select" style="flex:1;font-family:monospace;font-size:0.82rem"
            placeholder="User key..."
            value="<%= notificationPrefs.pushover_user_key || '' %>">
          <button type="button" class="btn-settings-save" style="white-space:nowrap;padding:8px 14px;font-size:0.82rem" onclick="testPushover()">Send Test</button>
        </div>
        <div class="toggle-row" style="margin-top:10px">
          <label class="slide-toggle">
            <input type="checkbox" id="notif-pushover-enabled" <%= notificationPrefs.pushover_enabled ? 'checked' : '' %>>
            <span class="slide-track"></span>
          </label>
          <span class="toggle-label">Enable Pushover notifications</span>
        </div>
      </div>
      <% } %>

      <button class="btn-settings-save" onclick="savePreferences()" style="margin-top:16px">Save Notification Settings</button>

    </div>
  </div>

  <script>
    function showToast(msg, isError) {
      var t = document.getElementById('settings-toast');
      t.textContent = msg;
      t.style.background = isError ? '#3a1a1a' : '#1e1e1e';
      t.classList.add('show');
      clearTimeout(t._timer);
      t._timer = setTimeout(function () { t.classList.remove('show'); }, 3000);
    }

    async function savePreferences() {
      var region   = document.getElementById('pref-region').value;
      var language = document.getElementById('pref-language').value;
      var getChecked = function(id, def) { var el = document.getElementById(id); return el ? el.checked : def; };
      var payload = {
        region:   region   || null,
        language: language || null,
        notify_approved:  getChecked('notif-approved', true),
        notify_denied:    getChecked('notif-denied', true),
        notify_available: getChecked('notif-available', true),
        discord_webhook:   (document.getElementById('notif-discord-webhook')  || {}).value || null,
        discord_user_id:   (document.getElementById('notif-discord-userid')   || {}).value || null,
        discord_enabled:   (document.getElementById('notif-discord-enabled')  || {}).checked || false,
        pushover_user_key: (document.getElementById('notif-pushover-key')     || {}).value || null,
        pushover_enabled:  (document.getElementById('notif-pushover-enabled') || {}).checked || false,
        notify_pending:        getChecked('notify_pending', true),
        notify_auto_approved:  getChecked('notify_auto_approved', true),
        notify_process_failed: getChecked('notify_process_failed', true),
        notify_issue_update:   getChecked('notify_issue_update', true),
        notify_issue_new:      getChecked('notify_issue_new', true),
      };
      try {
        var res = await fetch('/api/user/settings', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        var data = await res.json();
        if (!res.ok || !data.ok) throw new Error(data.error || 'Save failed');
        showToast('Preferences saved');
      } catch (err) {
        showToast('Error: ' + err.message, true);
      }
    }

    async function testPushover() {
      var key = (document.getElementById('notif-pushover-key') || {}).value || '';
      if (!key.trim()) { showToast('Enter your Pushover user key first', true); return; }
      try {
        var d = await fetch('/api/user/pushover/test', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userKey: key.trim() }),
        }).then(r => r.json());
        if (d.ok) showToast('Test message sent!');
        else showToast(d.error || 'Send failed', true);
      } catch (err) {
        showToast('Send failed', true);
      }
    }

    async function testDiscordDm() {
      var userId = (document.getElementById('notif-discord-userid') || {}).value || '';
      if (!userId.trim()) { showToast('Enter your Discord User ID first', true); return; }
      try {
        var d = await fetch('/api/user/discord/test', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ discordUserId: userId.trim() }),
        }).then(r => r.json());
        if (d.ok) showToast('Test message sent!');
        else showToast(d.error || 'Send failed', true);
      } catch (err) {
        showToast('Send failed', true);
      }
    }
  </script>
</body>
</html>
