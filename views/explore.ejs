<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr Requests</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <%- include('partials/pwa-head') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=45">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>">
</head>
<body>
  <%- include('partials/nav', { username, thumb, currentPath, discoverEnabled }) %>

  <main class="main-content">
    <div class="hero">
      <h1 class="hero-title">Diskovarr <span class="accent">Requests</span></h1>
      <p class="hero-sub">Everything here is <strong>not yet in the library</strong> — picked for your taste based on your watch history. <em style="opacity:0.6;font-size:0.9em">Your first visit may take a minute to process.</em></p>
      <div class="hero-controls hero-controls-split">
        <label class="toggle-label">
          <input type="checkbox" id="mature-toggle" class="toggle-checkbox">
          <span class="toggle-switch"></span>
          <span class="toggle-text">Show mature content <span style="opacity:0.55;font-size:0.82em;font-weight:400">(R &amp; TV-MA)</span></span>
        </label>
        <button type="button" id="btn-shuffle-all" class="btn-shuffle-all" title="Refresh picks">↺</button>
      </div>

    </div>

    <!-- Top Picks -->
    <section class="section" id="section-top-picks">
      <div class="section-header">
        <h2 class="section-title">Top Picks for You</h2>
        <span class="section-badge">Outside Your Library</span>
        
      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid skeleton-grid" id="grid-top-picks">
          <% for(let i = 0; i < 12; i++) { %>
            <div class="card card-skeleton">
              <div class="skeleton-poster shimmer"></div>
              <div class="skeleton-info">
                <div class="skeleton-line shimmer" style="width:80%"></div>
                <div class="skeleton-line shimmer" style="width:50%"></div>
              </div>
            </div>
          <% } %>
        </div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>

    <!-- Movies -->
    <section class="section" id="section-movies">
      <div class="section-header">
        <h2 class="section-title">Movies</h2>
        
      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid skeleton-grid" id="grid-movies">
          <% for(let i = 0; i < 12; i++) { %>
            <div class="card card-skeleton">
              <div class="skeleton-poster shimmer"></div>
              <div class="skeleton-info">
                <div class="skeleton-line shimmer" style="width:70%"></div>
                <div class="skeleton-line shimmer" style="width:40%"></div>
              </div>
            </div>
          <% } %>
        </div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>

    <!-- TV Shows -->
    <section class="section" id="section-tv">
      <div class="section-header">
        <h2 class="section-title">TV Shows</h2>
        
      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid skeleton-grid" id="grid-tv">
          <% for(let i = 0; i < 12; i++) { %>
            <div class="card card-skeleton">
              <div class="skeleton-poster shimmer"></div>
              <div class="skeleton-info">
                <div class="skeleton-line shimmer" style="width:75%"></div>
                <div class="skeleton-line shimmer" style="width:45%"></div>
              </div>
            </div>
          <% } %>
        </div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>

    <!-- Anime -->
    <section class="section" id="section-anime">
      <div class="section-header">
        <h2 class="section-title">Anime</h2>

      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid skeleton-grid" id="grid-anime">
          <% for(let i = 0; i < 12; i++) { %>
            <div class="card card-skeleton">
              <div class="skeleton-poster shimmer"></div>
              <div class="skeleton-info">
                <div class="skeleton-line shimmer" style="width:65%"></div>
                <div class="skeleton-line shimmer" style="width:35%"></div>
              </div>
            </div>
          <% } %>
        </div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>

    <!-- Trending Movies -->
    <section class="section" id="section-trending-movies" style="display:none">
      <div class="section-header">
        <h2 class="section-title">Trending Movies</h2>
        <span class="section-badge">Outside Your Library</span>
      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid" id="grid-trending-movies"></div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>

    <!-- Trending TV Shows -->
    <section class="section" id="section-trending-tv" style="display:none">
      <div class="section-header">
        <h2 class="section-title">Trending TV Shows</h2>
        <span class="section-badge">Outside Your Library</span>
      </div>
      <div class="carousel-wrap">
        <button class="carousel-arrow carousel-arrow-prev" aria-label="Previous" disabled>❮</button>
        <div class="card-grid" id="grid-trending-tv"></div>
        <button class="carousel-arrow carousel-arrow-next" aria-label="Next">❯</button>
      </div>
    </section>
  </main>

  <!-- Detail modal -->
  <div class="detail-modal-wrap" id="detail-modal" aria-hidden="true">
    <div class="detail-modal-card" role="dialog" aria-modal="true">
      <button class="detail-modal-close" id="detail-modal-close" aria-label="Close">✕</button>
      <div class="detail-modal-hero" id="detail-modal-hero"></div>
      <div class="detail-modal-body">
        <img class="detail-modal-poster" id="detail-modal-poster" src="" alt="">
        <div class="detail-modal-info">
          <div class="detail-modal-title" id="detail-modal-title"></div>
          <div class="detail-modal-meta" id="detail-modal-meta"></div>
          <div class="detail-modal-reasons" id="detail-modal-reasons"></div>
          <div class="detail-modal-genres" id="detail-modal-genres"></div>
          <p class="detail-modal-overview" id="detail-modal-overview"></p>
          <div class="detail-modal-credits" id="detail-modal-credits"></div>
          <div class="detail-modal-actions" id="detail-modal-actions"></div>
        </div>
      </div>
      <div class="detail-modal-trailer" id="detail-modal-trailer"></div>
    </div>
  </div>

  <!-- Request confirm dialog -->
  <div class="request-dialog-backdrop" id="request-dialog" aria-hidden="true">
    <div class="request-dialog-card" role="dialog" aria-modal="true">
      <div class="request-dialog-body">
        <div class="request-dialog-title" id="request-dialog-title">Request this title?</div>
        <div class="request-dialog-sub" id="request-dialog-sub"></div>
        <div class="request-dialog-actions" id="request-dialog-actions">
          <button class="btn-dialog-cancel" id="request-dialog-cancel">Cancel</button>
        </div>
      </div>
      <img class="request-dialog-poster" id="request-dialog-poster" src="" alt="" aria-hidden="true">
    </div>
  </div>

  <script>
    window.EXPLORE_CONFIG = {
      userId: "<%= userId %>",
      services: {
        overseerr: <%= services.overseerr ? 'true' : 'false' %>,
        radarr: <%= services.radarr ? 'true' : 'false' %>,
        sonarr: <%= services.sonarr ? 'true' : 'false' %>,
        riven: <%= services.riven ? 'true' : 'false' %>,
        defaultService: "<%= services.defaultService %>",
      },
      hasAnyService: <%= hasAnyService ? 'true' : 'false' %>,
      individualSeasonsEnabled: <%= individualSeasonsEnabled ? 'true' : 'false' %>,
      directRequestAccess: "<%= directRequestAccess %>",
      isOwner: <%= isOwner ? 'true' : 'false' %>,
    };
  </script>
  <script src="/js/discover-app.js?v=27"></script>
</body>
</html>
