<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diskovarr — Request Queue</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f0f0f">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css?v=51">
  <link rel="stylesheet" href="/theme.css?c=<%= themeParam %>" id="theme-css">
  <style>
    .queue-page { max-width: 1100px; margin: 0 auto; padding: 0 16px 48px; }
    .queue-hero { padding: 32px 0 24px; }
    .queue-hero h1 { font-size: 1.6rem; font-weight: 700; margin: 0 0 6px; }
    .queue-hero p { color: var(--text-secondary); margin: 0; font-size: 0.9rem; }
    .queue-filter-row { display: flex; gap: 8px; margin-bottom: 20px; flex-wrap: wrap; }
    .queue-filter-btn { padding: 6px 16px; border-radius: 20px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-secondary); cursor: pointer; font-size: 0.85rem; transition: all 0.15s; }
    .queue-filter-btn.active { background: var(--accent); border-color: var(--accent); color: #000; font-weight: 600; }
    .queue-filter-btn:hover:not(.active) { border-color: var(--accent); color: var(--accent); }
    .queue-table { width: 100%; border-collapse: collapse; }
    .queue-table th { text-align: left; padding: 10px 12px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-secondary); border-bottom: 1px solid var(--border); }
    .queue-table td { padding: 12px 12px; border-bottom: 1px solid var(--border); font-size: 0.88rem; vertical-align: middle; }
    .queue-table tr:last-child td { border-bottom: none; }
    .queue-table tr.pending-row { background: rgba(255,170,0,0.04); }
    .status-badge-pending { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; background: rgba(255,170,0,0.15); color: #ffaa00; border: 1px solid rgba(255,170,0,0.3); }
    .status-badge-requested { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; background: rgba(0,180,216,0.12); color: #00b4d8; border: 1px solid rgba(0,180,216,0.3); }
    .status-badge-available { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; background: rgba(0,200,100,0.12); color: #00c864; border: 1px solid rgba(0,200,100,0.25); }
    .status-badge-denied { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; background: rgba(255,60,60,0.12); color: #ff5252; border: 1px solid rgba(255,60,60,0.25); }
    .queue-poster { width: 52px; height: 78px; border-radius: 4px; object-fit: cover; background: var(--bg-elevated); flex-shrink: 0; }
    .queue-poster-placeholder { width: 52px; height: 78px; border-radius: 4px; background: var(--bg-elevated); border: 1px solid var(--border); flex-shrink: 0; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); font-size: 0.7rem; }
    .queue-table th.sortable { cursor: pointer; user-select: none; }
    .queue-table th.sortable:hover { color: var(--text-primary); }
    .queue-table th.sort-asc::after { content: ' ↑'; color: var(--accent); }
    .queue-table th.sort-desc::after { content: ' ↓'; color: var(--accent); }
    .queue-title-cell { display: flex; align-items: center; gap: 10px; }
    .queue-title-info { display: flex; flex-direction: column; gap: 2px; }
    .queue-year { font-size: 0.75rem; color: var(--text-secondary); }
    .queue-rating { font-size: 0.75rem; color: #e5a00d; font-weight: 600; }
    .queue-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .btn-queue-approve { padding: 4px 12px; border-radius: 6px; border: none; background: rgba(0,200,100,0.15); color: #00c864; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .btn-queue-approve:hover { background: rgba(0,200,100,0.28); }
    .btn-queue-deny { padding: 4px 12px; border-radius: 6px; border: none; background: rgba(255,60,60,0.12); color: #ff5252; font-size: 0.82rem; font-weight: 600; cursor: pointer; transition: background 0.15s; }
    .btn-queue-deny:hover { background: rgba(255,60,60,0.25); }
    .btn-queue-delete { padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text-secondary); font-size: 0.82rem; cursor: pointer; transition: all 0.15s; }
    .btn-queue-delete:hover { border-color: #ff5252; color: #ff5252; }
    .queue-pagination { display: flex; align-items: center; gap: 10px; margin-top: 20px; font-size: 0.85rem; color: var(--text-secondary); }
    .btn-page { padding: 5px 14px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-secondary); color: var(--text-secondary); cursor: pointer; font-size: 0.83rem; }
    .btn-page:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
    .btn-page:disabled { opacity: 0.4; cursor: not-allowed; }
    .queue-empty { text-align: center; padding: 48px 20px; color: var(--text-secondary); font-size: 0.9rem; }
    .queue-loading { text-align: center; padding: 48px 20px; color: var(--text-secondary); }
    .queue-toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%); background: #1e1e1e; color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 0.88rem; z-index: 9999; opacity: 0; transition: opacity 0.25s; pointer-events: none; border: 1px solid var(--border); }
    .queue-toast.show { opacity: 1; }
    .type-badge { display: inline-block; padding: 1px 7px; border-radius: 6px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
    .type-movie { background: rgba(229,160,13,0.15); color: var(--accent); }
    .type-tv { background: rgba(0,180,216,0.12); color: #00b4d8; }
    .queue-user { font-size: 0.82rem; color: var(--text-secondary); }
    .queue-title { font-weight: 500; }
    .deny-note { font-size: 0.78rem; color: var(--text-secondary); margin-top: 2px; font-style: italic; }
    .content-rating-badge { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 0.7rem; font-weight: 700; border: 1px solid var(--border); color: var(--text-secondary); background: var(--bg-elevated); letter-spacing: 0.04em; font-family: monospace; }
    .btn-queue-edit { padding: 4px 10px; border-radius: 6px; border: 1px solid var(--border); background: transparent; color: var(--text-secondary); font-size: 0.82rem; cursor: pointer; transition: all 0.15s; }
    .btn-queue-edit:hover { border-color: var(--accent); color: var(--accent); }
    .edit-modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 9000; display: none; align-items: center; justify-content: center; }
    .edit-modal-backdrop.open { display: flex; }
    .edit-modal-card { background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 12px; padding: 24px; width: min(460px,90vw); max-height: 85vh; overflow-y: auto; }
    .edit-modal-card h3 { margin: 0 0 16px; font-size: 1rem; font-weight: 600; }
    .edit-field-label { display: block; font-size: 0.82rem; margin-bottom: 5px; color: var(--text-secondary); }
    .edit-select { width: 100%; padding: 7px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg-elevated); color: var(--text); font-size: 0.88rem; }
    .edit-season-list { display: flex; flex-wrap: wrap; gap: 6px 12px; margin-top: 6px; }
    .edit-season-list label { font-size: 0.82rem; }
    .edit-modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 16px; }
    .edit-modal-cancel { padding: 7px 16px; border-radius: 7px; border: 1px solid var(--border); background: var(--bg-elevated); color: var(--text); font-size: 0.88rem; cursor: pointer; transition: background 0.15s; }
    .edit-modal-cancel:hover { background: var(--bg-hover, var(--border)); }
    .edit-modal-save { padding: 7px 16px; border-radius: 7px; border: none; background: var(--accent); color: #fff; font-size: 0.88rem; font-weight: 600; cursor: pointer; transition: opacity 0.15s; }
    .edit-modal-save:hover { opacity: 0.85; }
    .table-scroll-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    @media (max-width: 600px) {
      .queue-table th:nth-child(3), .queue-table td:nth-child(3) { display: none; }
      .queue-table th:nth-child(4), .queue-table td:nth-child(4) { display: none; }
      body { overflow-x: hidden; }
    }
  </style>
</head>
<body>
  <%- include('partials/nav') %>

  <div class="queue-page">
    <div class="queue-hero">
      <h1><%= (typeof isAdmin !== 'undefined' && isAdmin) ? 'Request Queue' : 'My Requests' %></h1>
      <p><%= (typeof isAdmin !== 'undefined' && isAdmin) ? 'Review and manage media requests from all users.' : 'Your media requests and their status.' %></p>
    </div>

    <div id="queue-toast" class="queue-toast"></div>

    <div class="queue-filter-row">
      <button class="queue-filter-btn active" data-status="all">All</button>
      <button class="queue-filter-btn" data-status="pending">Pending <span id="pending-count-label"></span></button>
      <button class="queue-filter-btn" data-status="requested">Requested</button>
      <button class="queue-filter-btn" data-status="available">Available</button>
      <button class="queue-filter-btn" data-status="approved">Approved</button>
      <button class="queue-filter-btn" data-status="denied">Denied</button>
    </div>

    <div id="queue-container">
      <div class="queue-loading">Loading requests...</div>
    </div>

    <div class="queue-pagination" id="queue-pagination" style="display:none">
      <button class="btn-page" id="btn-prev-page" onclick="changePage(-1)">&#8249; Prev</button>
      <span id="page-info"></span>
      <button class="btn-page" id="btn-next-page" onclick="changePage(1)">Next &#8250;</button>
      <select id="queue-per-page" onchange="onPerPageChange()" style="background:var(--bg-elevated);color:var(--text-secondary);border:1px solid var(--border);border-radius:20px;padding:5px 12px;font-size:0.85rem;cursor:pointer">
        <option value="25">25 / page</option>
        <option value="50">50 / page</option>
        <option value="100">100 / page</option>
      </select>
    </div>
  </div>

  <!-- Edit Request Modal -->
  <!-- Delete confirmation modal -->
  <div class="edit-modal-backdrop" id="delete-confirm-modal">
    <div class="edit-modal-card" style="max-width:380px">
      <h3>Delete Request</h3>
      <p style="color:var(--text-secondary);font-size:0.9rem;margin:8px 0 16px">Are you sure you want to permanently delete this request?</p>
      <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:var(--text-secondary);margin-bottom:20px;cursor:pointer">
        <input type="checkbox" id="delete-dont-ask"> Don't ask again on this device
      </label>
      <div class="edit-modal-actions">
        <button class="edit-modal-cancel" onclick="closeDeleteModal()">Cancel</button>
        <button class="edit-modal-save" style="background:var(--accent-red,#e53e3e)" onclick="confirmDelete()">Delete</button>
      </div>
    </div>
  </div>

  <div class="edit-modal-backdrop" id="edit-request-modal">
    <div class="edit-modal-card">
      <h3>Edit Request</h3>
      <div style="margin-bottom:14px">
        <label class="edit-field-label">Service</label>
        <select id="edit-service" class="edit-select">
          <%
            var c = locals.connections || {};
            if (c.overseerrEnabled && c.overseerrUrl) {
          %><option value="overseerr">Overseerr</option><%
            }
            if (c.radarrEnabled && c.radarrUrl) {
          %><option value="radarr">Radarr</option><%
            }
            if (c.sonarrEnabled && c.sonarrUrl) {
          %><option value="sonarr">Sonarr</option><%
            }
          %>
        </select>
      </div>
      <div id="edit-season-section">
        <label class="edit-field-label">Seasons</label>
        <div>
          <label style="font-size:0.82rem;margin-bottom:6px;display:block"><input type="checkbox" id="edit-select-all" onchange="editToggleAll(this.checked)"> <strong>Select all</strong></label>
        </div>
        <div class="edit-season-list" id="edit-seasons-list"></div>
      </div>
      <div class="edit-modal-actions">
        <button class="btn-queue-delete" onclick="editModalClose()">Cancel</button>
        <button class="btn-queue-approve" style="font-weight:600" onclick="editModalSave()">Save</button>
      </div>
    </div>
  </div>

  <script>
    var IS_ADMIN = <%= (typeof isAdmin !== 'undefined' && isAdmin) ? 'true' : 'false' %>;
    var currentStatus = 'all';
    var currentPage = 1;
    var totalPages = 1;
    var perPage = parseInt(localStorage.getItem('diskovarr_queue_per_page')) || 25;

    function showToast(msg, isError) {
      var t = document.getElementById('queue-toast');
      t.textContent = msg;
      t.style.background = isError ? '#3a1a1a' : '#1e1e1e';
      t.classList.add('show');
      clearTimeout(t._timer);
      t._timer = setTimeout(function () { t.classList.remove('show'); }, 3500);
    }

    function fmtDate(ts) {
      if (!ts) return '';
      var diff = Math.floor(Date.now() / 1000) - ts;
      if (diff < 3600) {
        var m = Math.max(1, Math.floor(diff / 60));
        return m + ' min' + (m === 1 ? '' : 's') + ' ago';
      }
      if (diff < 86400) {
        var h = Math.floor(diff / 3600);
        return h + ' hour' + (h === 1 ? '' : 's') + ' ago';
      }
      var d = Math.floor(diff / 86400);
      return d + ' day' + (d === 1 ? '' : 's') + ' ago';
    }

    var currentSortCol = 'requested_at';
    var currentSortDir = 'DESC';

    async function loadQueue(status, page) {
      currentStatus = status || 'all';
      currentPage = page || 1;

      var container = document.getElementById('queue-container');
      container.innerHTML = '<div class="queue-loading">Loading...</div>';

      try {
        var res = await fetch('/api/queue?status=' + encodeURIComponent(currentStatus) + '&page=' + currentPage + '&limit=' + perPage + '&sort=' + currentSortCol + '&sortDir=' + currentSortDir);
        if (!res.ok) throw new Error('Failed to load queue');
        var data = await res.json();
        totalPages = data.totalPages || 1;
        renderQueue(data);
        updateSortHeaders();
        updatePagination(data.page, data.totalPages, data.total);
        updatePendingCount();
      } catch (err) {
        container.innerHTML = '<div class="queue-empty">Failed to load requests: ' + err.message + '</div>';
      }
    }

    function updateSortHeaders() {
      document.querySelectorAll('th.sortable').forEach(function (t) {
        t.classList.remove('sort-asc', 'sort-desc');
        if (t.dataset.col === currentSortCol) {
          t.classList.add(currentSortDir === 'ASC' ? 'sort-asc' : 'sort-desc');
        }
      });
    }

    var STATUS_LABELS = {
      pending:   'Pending Approval',
      requested: 'Requested',
      available: 'Available',
      denied:    'Denied',
    };

    function renderQueue(data) {
      var container = document.getElementById('queue-container');
      if (!data.requests || data.requests.length === 0) {
        container.innerHTML = '<div class="queue-empty">No requests found.</div>';
        return;
      }

      var html = '<table class="queue-table"><thead><tr>' +
        '<th class="sortable" data-col="title">Title</th>' + (IS_ADMIN ? '<th class="sortable" data-col="user">User</th>' : '') + '<th class="sortable" data-col="type">Type</th><th class="sortable" data-col="age">Age</th><th class="sortable" data-col="status">Status</th><th>Actions</th>' +
        '</tr></thead><tbody>';

      data.requests.forEach(function (r) {
        var isPending = r.status === 'pending';
        var ds = r.displayStatus || r.status;
        html += '<tr class="' + (isPending ? 'pending-row' : '') + '" id="req-row-' + r.id + '"'
          + ' data-sort_title="' + escHtml((r.title||'').toLowerCase()) + '"'
          + ' data-sort_user="' + escHtml((r.username||'').toLowerCase()) + '"'
          + ' data-sort_type="' + escHtml((r.media_type||'').toLowerCase()) + '"'
          + ' data-sort_age="' + (r.requested_at||0) + '"'
          + ' data-sort_status="' + escHtml((r.displayStatus||r.status||'').toLowerCase()) + '"'
          + '>';

        // Title cell with poster
        html += '<td>';
        html += '<div class="queue-title-cell">';
        if (r.posterUrl) {
          html += '<img class="queue-poster" src="' + escHtml(r.posterUrl) + '" alt="" loading="lazy">';
        } else {
          html += '<div class="queue-poster-placeholder">?</div>';
        }
        html += '<div class="queue-title-info">';
        html += '<div class="queue-title">' + escHtml(r.title || 'Untitled') + '</div>';
        var meta = [];
        if (r.year) meta.push('<span class="queue-year">' + r.year + '</span>');
        if (r.contentRating) meta.push('<span class="content-rating-badge">' + escHtml(r.contentRating) + '</span>');
        if (meta.length) html += '<div style="display:flex;gap:8px;align-items:center">' + meta.join('') + '</div>';
        if (r.media_type === 'tv') {
          var seaNums = null;
          if (r.seasons_json) {
            try { seaNums = JSON.parse(r.seasons_json); } catch(e) {}
          }
          html += '<div class="season-bubbles">';
          if (Array.isArray(seaNums) && seaNums.length > 0) {
            var sorted = seaNums.slice().sort(function(a,b){return a-b;});
            if (sorted.length > 9) {
              html += '<span class="season-bubble season-bubble-ellipsis">...</span>';
              sorted.slice(-8).forEach(function(s) {
                html += '<span class="season-bubble">S' + s + '</span>';
              });
            } else {
              sorted.forEach(function(s) {
                html += '<span class="season-bubble">S' + s + '</span>';
              });
            }
          } else {
            html += '<span class="season-bubble season-bubble-all">All Seasons</span>';
          }
          html += '</div>';
        }
        if (r.denial_note) html += '<div class="deny-note">' + escHtml(r.denial_note) + '</div>';
        html += '</div></div>';
        html += '</td>';

        if (IS_ADMIN) {
          var isBot = r.user_id && r.user_id.startsWith('__svc_');
          var userCell = isBot
            ? '<span style="display:inline-flex;align-items:center;gap:5px">'
              + '<span style="font-size:0.7rem;background:var(--accent);color:#000;padding:1px 5px;border-radius:4px;font-weight:700;letter-spacing:0.02em">bot</span>'
              + escHtml(r.username || r.user_id)
              + '</span>'
            : escHtml(r.username || r.user_id);
          html += '<td class="queue-user">' + userCell + '</td>';
        }
        html += '<td><span class="type-badge ' + (r.media_type === 'movie' ? 'type-movie' : 'type-tv') + '">' + (r.media_type === 'movie' ? 'Movie' : 'TV') + '</span></td>';
        html += '<td>' + fmtDate(r.requested_at) + '</td>';
        html += '<td><span class="status-badge-' + ds + '">' + (STATUS_LABELS[ds] || ds) + '</span></td>';
        html += '<td><div class="queue-actions">';
        if (IS_ADMIN) {
          if (isPending) {
            html += '<button class="btn-queue-approve" onclick="approveRequest(' + r.id + ')">Approve</button>';
            html += '<button class="btn-queue-deny" onclick="denyRequest(' + r.id + ')">Deny</button>';
            html += '<button class="btn-queue-edit" onclick="editRequest(' + r.id + ', \'' + escHtml(r.media_type) + '\', ' + r.tmdb_id + ', \'' + escHtml(r.service) + '\', ' + JSON.stringify(r.seasons_json || null) + ')">Edit</button>';
          }
          html += '<button class="btn-queue-delete" onclick="deleteRequest(' + r.id + ')">Delete</button>';
        } else {
          if (isPending) {
            html += '<button class="btn-queue-edit" onclick="editRequest(' + r.id + ', \'' + escHtml(r.media_type) + '\', ' + r.tmdb_id + ', \'' + escHtml(r.service) + '\', ' + JSON.stringify(r.seasons_json || null) + ')">Edit</button>';
            html += '<button class="btn-queue-delete" onclick="deleteRequest(' + r.id + ')">Delete</button>';
          }
        }
        html += '</div></td>';
        html += '</tr>';
      });

      html += '</tbody></table>';
      container.innerHTML = '<div class="table-scroll-wrap">' + html + '</div>';
    }

    function updatePagination(page, pages, total) {
      var pag = document.getElementById('queue-pagination');
      if (!total) { pag.style.display = 'none'; return; }
      pag.style.display = 'flex';
      var prevBtn = document.getElementById('btn-prev-page');
      var nextBtn = document.getElementById('btn-next-page');
      prevBtn.style.display = pages > 1 ? '' : 'none';
      nextBtn.style.display = pages > 1 ? '' : 'none';
      document.getElementById('page-info').textContent = pages > 1 ? 'Page ' + page + ' of ' + pages + ' (' + total + ' total)' : total + ' total';
      if (prevBtn) prevBtn.disabled = page <= 1;
      if (nextBtn) nextBtn.disabled = page >= pages;
    }

    async function updatePendingCount() {
      try {
        var res = await fetch('/api/queue?status=pending&page=1');
        if (res.ok) {
          var data = await res.json();
          var el = document.getElementById('pending-count-label');
          if (el) el.textContent = data.total > 0 ? '(' + data.total + ')' : '';
        }
      } catch {}
    }

    function onPerPageChange() {
      perPage = parseInt(document.getElementById('queue-per-page').value) || 25;
      localStorage.setItem('diskovarr_queue_per_page', perPage);
      loadQueue(currentStatus, 1);
    }

    function changePage(delta) {
      var newPage = currentPage + delta;
      if (newPage < 1 || newPage > totalPages) return;
      loadQueue(currentStatus, newPage);
    }

    function updateRowStatus(id, newStatus) {
      var row = document.getElementById('req-row-' + id);
      if (!row) return;
      row.classList.remove('pending-row');
      var badge = row.querySelector('[class^="status-badge-"]');
      if (badge) {
        badge.className = 'status-badge-' + newStatus;
        badge.textContent = STATUS_LABELS[newStatus] || newStatus;
      }
      // Remove approve/deny/edit buttons; keep delete
      var actions = row.querySelector('.queue-actions');
      if (actions) {
        var deleteBtn = actions.querySelector('.btn-queue-delete');
        actions.innerHTML = '';
        if (deleteBtn) actions.appendChild(deleteBtn);
      }
    }

    async function approveRequest(id) {
      try {
        var res = await fetch('/api/queue/' + id + '/approve', { method: 'POST' });
        var data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Approve failed');
        showToast('Request approved and submitted');
        updateRowStatus(id, 'requested');
      } catch (err) {
        showToast('Error: ' + err.message, true);
      }
    }

    async function denyRequest(id) {
      var note = prompt('Denial reason (optional):');
      if (note === null) return; // cancelled
      try {
        var res = await fetch('/api/queue/' + id + '/deny', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ note: note || null }),
        });
        var data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Deny failed');
        showToast('Request denied');
        updateRowStatus(id, 'denied');
      } catch (err) {
        showToast('Error: ' + err.message, true);
      }
    }

    var _deleteTargetId = null;

    async function deleteRequest(id) {
      if (localStorage.getItem('diskovarr_skip_delete_confirm') === '1') {
        await doDelete(id);
      } else {
        _deleteTargetId = id;
        document.getElementById('delete-dont-ask').checked = false;
        document.getElementById('delete-confirm-modal').classList.add('open');
      }
    }

    function closeDeleteModal() {
      _deleteTargetId = null;
      document.getElementById('delete-confirm-modal').classList.remove('open');
    }

    async function confirmDelete() {
      if (document.getElementById('delete-dont-ask').checked) {
        localStorage.setItem('diskovarr_skip_delete_confirm', '1');
      }
      var id = _deleteTargetId;
      closeDeleteModal();
      await doDelete(id);
    }

    async function doDelete(id) {
      try {
        var res = await fetch('/api/queue/' + id, { method: 'DELETE' });
        var data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Delete failed');
        showToast('Request deleted');
        var row = document.getElementById('req-row-' + id);
        if (row) row.remove();
      } catch (err) {
        showToast('Error: ' + err.message, true);
      }
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Edit Request ─────────────────────────────────────────────
    var _editId = null;

    async function editRequest(id, mediaType, tmdbId, service, seasonsJson) {
      _editId = id;
      var modal = document.getElementById('edit-request-modal');
      var seasonSection = document.getElementById('edit-season-section');
      var serviceSelect = document.getElementById('edit-service');
      var seasonsList = document.getElementById('edit-seasons-list');

      serviceSelect.value = service || '';

      if (mediaType === 'tv') {
        seasonSection.style.display = '';
        seasonsList.innerHTML = '<span style="color:var(--text-secondary);font-size:0.82rem">Loading seasons...</span>';
        try {
          var res = await fetch('/api/search/seasons?tmdbId=' + tmdbId);
          var data = res.ok ? await res.json() : { seasons: [] };
          var storedSeasons = seasonsJson ? JSON.parse(seasonsJson) : null;
          var selectedSet = storedSeasons ? new Set(storedSeasons.map(Number)) : null;
          var html = '';
          (data.seasons || []).forEach(function (s) {
            var checked = !selectedSet || selectedSet.has(s);
            html += '<label style="font-size:0.82rem"><input type="checkbox" class="edit-season-cb" value="' + s + '"' + (checked ? ' checked' : '') + '> Season ' + s + '</label>';
          });
          seasonsList.innerHTML = html;
          var allChecked = (data.seasons || []).every(function (s) { return !selectedSet || selectedSet.has(s); });
          document.getElementById('edit-select-all').checked = allChecked;
        } catch (err) {
          seasonsList.innerHTML = '<span style="color:var(--text-secondary);font-size:0.82rem">Could not load seasons.</span>';
        }
      } else {
        seasonSection.style.display = 'none';
      }

      modal.classList.add('open');
    }

    function editToggleAll(checked) {
      document.querySelectorAll('.edit-season-cb').forEach(function (cb) { cb.checked = checked; });
    }

    function editModalClose() {
      document.getElementById('edit-request-modal').classList.remove('open');
      _editId = null;
    }

    async function editModalSave() {
      if (!_editId) return;
      var service = document.getElementById('edit-service').value;
      var seasonCbs = document.querySelectorAll('.edit-season-cb');
      var seasons = null;
      if (seasonCbs.length > 0) {
        seasons = Array.from(seasonCbs).filter(function (cb) { return cb.checked; }).map(function (cb) { return Number(cb.value); });
        if (seasons.length === seasonCbs.length) seasons = null;
      }
      try {
        var res = await fetch('/api/queue/' + _editId, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ service: service || undefined, seasons: seasons }),
        });
        var data = await res.json();
        if (!res.ok || !data.success) throw new Error(data.error || 'Save failed');
        showToast('Request updated');
        editModalClose();
        // Update season bubbles in place
        var row = document.getElementById('req-row-' + _editId);
        if (row) {
          var bubblesDiv = row.querySelector('.season-bubbles');
          if (bubblesDiv) {
            var newHtml = '';
            if (Array.isArray(seasons) && seasons.length > 0) {
              seasons.slice().sort(function(a,b){return a-b;}).forEach(function(s) {
                newHtml += '<span class="season-bubble">S' + s + '</span>';
              });
            } else {
              newHtml = '<span class="season-bubble season-bubble-all">All Seasons</span>';
            }
            bubblesDiv.innerHTML = newHtml;
          }
        }
      } catch (err) {
        showToast('Error: ' + err.message, true);
      }
    }

    // Close modals on backdrop click
    document.getElementById('edit-request-modal').addEventListener('click', function (e) {
      if (e.target === this) editModalClose();
    });
    document.getElementById('delete-confirm-modal').addEventListener('click', function (e) {
      if (e.target === this) closeDeleteModal();
    });

    // Filter buttons
    document.querySelectorAll('.queue-filter-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        document.querySelectorAll('.queue-filter-btn').forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        loadQueue(btn.dataset.status, 1);
      });
    });

    // Column sort — server-side
    var COL_TO_SORT = { title: 'title', user: 'username', type: 'media_type', age: 'requested_at', status: 'status' };
    document.addEventListener('click', function (e) {
      var th = e.target.closest('th.sortable');
      if (!th) return;
      var col = COL_TO_SORT[th.dataset.col] || 'requested_at';
      if (currentSortCol === col) {
        currentSortDir = currentSortDir === 'ASC' ? 'DESC' : 'ASC';
      } else {
        currentSortCol = col;
        currentSortDir = 'ASC';
      }
      loadQueue(currentStatus, 1);
    });

    // Restore saved per-page selection
    document.getElementById('queue-per-page').value = perPage;

    // Initial load — respect ?filter= URL param
    var initFilter = new URLSearchParams(window.location.search).get('filter') || 'all';
    var initBtn = document.querySelector('.queue-filter-btn[data-status="' + initFilter + '"]');
    if (initBtn) {
      document.querySelectorAll('.queue-filter-btn').forEach(function(b) { b.classList.remove('active'); });
      initBtn.classList.add('active');
    }
    loadQueue(initFilter, 1);
    setInterval(updatePendingCount, 30000);
  </script>
</body>
</html>
