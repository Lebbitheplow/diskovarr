# ── Required ──────────────────────────────────────────────────────────────────
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=your_plex_admin_token
PLEX_SERVER_ID=your_plex_machine_identifier
PLEX_SERVER_NAME=Your Server Name
ADMIN_PASSWORD=change_this_to_a_secure_password
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# ── Optional ──────────────────────────────────────────────────────────────────
# Tautulli integration (can also be configured in the admin panel)
TAUTULLI_URL=http://192.168.1.x:8181
TAUTULLI_API_KEY=your_tautulli_api_key

# Plex library section IDs (can also be set in admin panel)
PLEX_MOVIES_SECTION_ID=1
PLEX_TV_SECTION_ID=2

# TMDB API key for movie/show metadata
TMDB_API_KEY=your_tmdb_api_key

# Riven settings file path (for Riven integration)
RIVEN_SETTINGS_PATH=/opt/riven/settings.json

# Public URL of your Diskovarr instance (used for Plex OAuth callback)
APP_URL=http://localhost:3232

# Server port (default: 3232)
PORT=3232
